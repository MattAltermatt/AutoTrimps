// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`rendered settings tooltips (#107) > census: the composed text of every setting 1`] = `
{
  "45stacks": "Changes how AT estimates your damage bonus from Anticipation stacks.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>On always calculates as if you had a full 45 Anticipation stacks, useful while windstacking. Off uses your actual current stack count.<br><br><i>Default: Off</i>",
  "AMUblock": "Makes AutoTrimps run the unique map <b>The Block</b> every time it becomes available, to unlock the Shieldblock upgrade.<br><br><b>Ignored:</b> Ignored once Shieldblock is already unlocked, and ignored unless <b>Auto Maps: Unique</b> is selected above.<br><br>Only takes effect once you have reached roughly zone 11 (scaled by the map's own difficulty).<br><br><i>Default: Off</i>",
  "AMUbw": "Makes AutoTrimps run the unique map <b>Bionic Wonderland</b> every time it becomes available.<br><br><b>Ignored:</b> Ignored during Challenge² runs, and adds nothing during the Crushed challenge &mdash; AutoTrimps already runs Bionic Wonderland there regardless of this setting. Also requires <b>Auto Maps: Unique</b> to be selected above.<br><br>Only takes effect once you have reached roughly zone 125 (scaled by the map's own difficulty).<br><br><i>Default: Off</i>",
  "AMUprison": "Makes AutoTrimps run the unique map <b>The Prison</b> every time it becomes available.<br><br><b>Ignored:</b> Ignored during Challenge² runs, and adds nothing during the Electricity or Mapocalypse challenges &mdash; AutoTrimps already runs The Prison there regardless of this setting. Also requires <b>Auto Maps: Unique</b> to be selected above.<br><br>Only takes effect once you have reached roughly zone 80 (scaled by the map's own difficulty).<br><br><i>Default: Off</i>",
  "AMUstar": "Makes AutoTrimps run the unique map <b>Imploding Star</b> every time it becomes available.<br><br><b>Ignored:</b> Ignored unless <b>Auto Maps: Unique</b> is selected above.<br><br>Only takes effect once you have reached roughly zone 170 (scaled by the map's own difficulty). Unlike the other AMU options above, this one still applies during Challenge² runs.<br><br><i>Default: Off</i>",
  "AMUtrimple": "Makes AutoTrimps run <b>Trimple Of Doom</b> every time it becomes available, to claim its one-time Ancient Treasure reward.<br><br><b>Ignored:</b> Ignored once you have already claimed the Ancient Treasure, and ignored unless <b>Auto Maps: Unique</b> is selected above.<br><br>Only takes effect once you have reached roughly zone 33 (scaled by the map's own difficulty). This is independent of the <b>Trimple Z</b> setting elsewhere on this panel, which triggers Trimple Of Doom by a specific zone regardless of Unique Maps mode.<br><br><i>Default: Off</i>",
  "ATGA2": "Master switch for ATGA (AT Geneticist Assist): hires and fires Geneticists to hit a target breed timer, instead of the game's own Auto Geneticist.<br><br><b>Ignored:</b> The <b>Trapper</b> challenge is active, or Geneticist is still locked.<br><br><b>Cannot:</b> Turning this on by itself does nothing &mdash; <b>ATGA: Timer</b> must also be a positive number, or ATGA never runs no matter how the other ATGA settings are configured. Conflicts with the game's own Auto Geneticist (vanilla GA) if both are left on &mdash; use one or the other.<br><br><i>Default: Off</i>",
  "ATGA2gen": "Caps how much of your current food ATGA is willing to spend on the next single Geneticist hire.<br><br>Example: set to <b>1</b> and ATGA only hires the next Geneticist if it costs under 1% of your current food. This is checked fresh each time, not cumulatively.<br><br><i>Default: 1</i>",
  "ATGA2timer": "The base breed timer, in seconds, ATGA tries to hit by hiring or firing Geneticists.<br><br><b>Cannot:</b> <b>This value gates the entire ATGA tab.</b> Every override below (Before/After Z, Spire, C2, Daily) only takes effect while this is a positive number &mdash; leave it at 0 or -1 and nothing in ATGA runs, however the overrides are configured.<br><br><i>Default: -1</i>",
  "ATGA2timerz": "Zone at or above which ATGA switches from the base timer to <b>ATGA: T: AZT</b>.<br><br><b>Ignored:</b> <b>ATGA: T: AZT</b> is not a positive number, or <b>ATGA: Timer</b> is not a positive number.<br><br>Useful for super-push runs.<br><br><i>Default: -1</i>",
  "ATGA2timerzt": "Breed timer ATGA uses at or above the zone set in <b>ATGA: T: After Z</b>, overriding the base timer.<br><br><b>Ignored:</b> <b>ATGA: T: After Z</b> is not a positive number, or <b>ATGA: Timer</b> is not a positive number.<br><br><b>Cannot:</b> Does not apply during challenges.<br><br><i>Default: -1</i>",
  "AdvMapSpecialModifier": "Lets AutoTrimps automatically pick the best affordable map special modifier, instead of leaving whatever was last selected by hand.<br><br><b>Ignored:</b> The special-modifier pick only takes effect once you have cleared zone 59; the extra-map-levels bump on top of it only takes effect from zone 209 on.<br><br>Picks <i>Prestigious</i> when creating a map for Prestige, a metal-cache/loot modifier while farming or short on health, and <i>Fast Attacks</i> otherwise &mdash; always the best one it can afford, downgrading choice by choice until it fits your fragments. Also adds extra map levels on top of your zone once unlocked.<br><br><i>Default: On</i>",
  "AutoAllocatePerks": "Controls what happens to your unspent helium when you portal in U1.<br><br><b>Auto Allocate On</b> runs the ratio-based AutoPerks preset to spend your helium (it never touches the Fixed Perks: siphonology, anticipation, meditation, relentlessness, range, agility, bait, trumps, packrat, capable). <b>Dump into Looting II</b> instead spends your available helium to max out the Looting II perk on every portal, ahead of any ratio-based allocation.<br><br><i>Default: Auto Allocate Off</i>",
  "AutoBoneChargeMax": "Spends a Bone Charge from the Bone Shrine once you are at max charges, so they never sit wasted at the cap.<br><br><b>Bone Charge (Daily Only)</b> does the same but only while you are on a daily challenge.<br><br>Set the zone it starts from under <b>Bone Charge Start Z</b>.<br><br><i>Default: Manual Bone Charge</i>",
  "AutoBoneChargeMaxStartZone": "The zone from which Bone Charges start being used.<br><br><b>Ignored:</b> <b>Auto Bone Charge</b> is set to <b>Manual Bone Charge</b>.<br><br><b>-1</b> tracks your progress automatically: it uses charges from 10% below your highest zone cleared. (Cleared zone 400 &rarr; charges from zone 360 on.)<br><br>Any other number starts from exactly that zone.<br><br><i>Default: -1</i>",
  "AutoEggs": "Clicks the Easter Egg automatically whenever it appears on entering a new zone.<br><br><b>Ignored:</b> You have not unlocked the Easter Egg — the control is hidden until then.<br><br>Warning: this is quite overpowered. Please solemnly swear that you are up to no good.<br><br><i>Default: Off</i>",
  "AutoGenC2": "Overrides the Generator mode for the whole Challenge Squared (C2) run.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br><b>Normal</b> just uses your regular Before/After Fuel and Start/End Fuel Z settings. <b>Fuel</b> and <b>Hybrid</b> lock the generator to that mode for the entire C2 run. Hybrid requires the Hybridization upgrade.<br><br><i>Default: C2: Fuel</i>",
  "AutoGenDC": "Overrides the Generator mode for the whole Daily Challenge.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br><b>Normal</b> just uses your regular Before/After Fuel and Start/End Fuel Z settings. <b>Fuel</b> and <b>Hybrid</b> lock the generator to that mode for the entire Daily. Hybrid requires the Hybridization upgrade.<br><br><i>Default: Daily: Fuel</i>",
  "AutoGigas": "Automates buying your first Gigastation of a run and calculates the Warpstation pattern (<b>First</b> / <b>Delta Gigastation</b>) to use for the rest of it.<br><br><b>Ignored:</b> <b>Buy Upgrades</b> is set to Manual — no upgrade purchases happen at all, Gigastation included. Also ignored while <b>Buy Buildings</b> is Buy Neither with <b>Hide Buildings</b> on: Gigastation purchases are skipped in that combination too.<br><br>Buys the first Gigastation once: A) you have more than 2 Warpstations, B) you can't afford more Coordination, C) (only if <b>Custom Delta Factor</b> is above 20) you're lacking health or damage, and D) (only if <b>Custom Delta Factor</b> is above 20) you've run at least one map stack — or the console is used to force it.<br><br>It then computes the delta from <b>Custom Delta Factor</b> against your Auto Portal / Void Maps zone (whichever is higher), or the Daily / C2 equivalent, or <b>Custom Target Zone</b> if set.<br><br><i>Default: On</i>",
  "AutoGoldenUpgrades": "Automatically buys Golden Upgrades outside Dailies and Challenge2. <b>Helium</b> buys from the Helium pool, <b>Battle</b> buys from the Battle pool, <b>Void</b> spends on the Void pool (the game caps this at 8 purchases) and falls back to Helium once it runs out, <b>Void + Battle</b> does the same but falls back to Battle instead.<br><br><b>Ignored:</b> Only active outside Dailies and Challenge2 &mdash; see <b>Daily AutoGoldenUpgrades</b> / <b>C2 AutoGoldenUpgrades</b> for those.<br><br><b>Helium Battle</b> / <b>Battle Helium</b> can switch the Helium/Battle choice over after a purchase count; <b>Void Battle</b> can switch the Void fallback to Battle from a zone onward. See those settings.<br><br><i>Default: Off</i>",
  "AutoIce": "What AT does with your Ice tokens.<br><br><b>Empowerment</b> levels up Ice Empowerment. <b>Transfer</b> raises its retain level (capped at 80 by the game). <b>Convert to Poison/Wind</b> trades Ice tokens for the other nature at whatever rate your Nature talents give you. <b>Convert to Both</b> splits the trade evenly between Poison and Wind, and costs twice as many tokens per trade as converting to just one.<br><br><i>Default: Off</i>",
  "AutoMagmamancers": "Auto-hires Magmamancers once you've spent a while sitting on the current zone.<br><br><b>Cannot:</b> Can eat into gems you were saving for something else &mdash; it does not check what else you might want them for.<br><br>Fires after the current zone has been active for 10 minutes (5 minutes with the Magmamancer talent), spending up to 10% of your gems on hires. That 10%-of-gems spend then repeats every further 10 minutes on the same zone.<br><br><i>Default: On</i>",
  "AutoMaps": "Lets AutoTrimps send you into maps on its own — to farm, to gain map bonus, and to clear what it needs. Recommended ON.<br><br><b>AT writes this box.</b> This is the same switch as the <b>AutoMaps</b> button on the game screen. Clicking that button changes this setting, and vice versa — they are one control in two places, so this box can change without you touching this panel.<br><br><b>Cannot:</b> Work alongside <b>MaZ</b>. Do not run both.<br><br><b>Auto Maps: Unique</b> works the same, and additionally unlocks a per-map setting for each unique map so you can pick which ones to run.<br><br><i>Default: Auto Maps On</i>",
  "AutoNatureTokens": "Master switch for automatically spending or converting Nature tokens.<br><br><b>Ignored:</b> Ignored in Universe 2 (no U2 equivalent exists).<br><br>Applies from z230 onward.<br><br><i>Default: Off</i>",
  "AutoPoison": "What AT does with your Poison tokens.<br><br><b>Empowerment</b> levels up Poison Empowerment. <b>Transfer</b> raises its retain level (capped at 80 by the game). <b>Convert to Wind/Ice</b> trades Poison tokens for the other nature at whatever rate your Nature talents give you. <b>Convert to Both</b> splits the trade evenly between Wind and Ice, and costs twice as many tokens per trade as converting to just one.<br><br><i>Default: Off</i>",
  "AutoPortal": "Automatically portals in U1 once the condition for the selected mode is met.<br><br><b>Cannot:</b> Selecting Helium Per Hour can portal you immediately if your He/hr is already below your run best — use Pause AutoTrimps first if you want to check before it fires.<br><br><b>Helium Per Hour</b> portals at cell 1 of the first level where your He/hr dips below your best for the run by more than the <b>He/Hr Portal Buffer %</b> (subject to <b>Don't Portal Before</b>). <b>Custom</b> portals right after clearing the zone set in <b>Custom Portal</b>. Any named challenge (Balance, Nom, Watch, Lead, and so on) portals as soon as the portal becomes available, provided no challenge is currently active.<br><br>Never fires while you have a challenge active — every mode portals immediately once that challenge ends, regardless of setting.<br><br><i>Default: Off</i>",
  "AutoPortalDaily": "Automatically portals you out of a Daily challenge once a condition is met.<br><br><b>DP: He/Hr:</b> portals once your world zone is above the minimum you've set (if any) and your Helium/Hour has dropped below the buffer you've defined. <b>DP: Custom:</b> portals immediately after clearing the zone set in Daily Custom Portal.<br><br><i>Default: Daily Portal Off</i>",
  "AutoRoboTrimp": "Fires the RoboTrimp MagnetoShriek ability once you reach this zone, and every 5 zones after.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>Checked only when you enter a new zone (not every tick), and skipped in liquid zones or while Shriek is already active. Use 0 to turn it off.<br><br><i>Default: 60</i>",
  "AutoStance": "Chooses how AT switches your battle formation to keep your squad alive.<br><br><b>Ignored:</b> Universe 2 (Radon) does not read this setting at all &mdash; U2 formation control comes from Better AutoFight, Manage Equality and Armor Magic instead, with no manual stance dial.<br><br><b>Auto Stance</b> picks the safest formation each tick from a survival calc. <b>D Stance</b> locks you into D regardless of health. <b>Windstacking</b> (for after z230) stays in D except while you're actively windstacking, and swaps your High/Low Damage heirlooms (set on the Heirlooms tab) to do it &mdash; only useful once Transfer is maxed and Wind Empowerment is high.<br><br><i>Default: Auto Stance</i>",
  "AutoStartDaily": "Automatically starts a Daily challenge for you when you portal.<br><br>Selects and starts the oldest available Daily. The other settings in this tab decide what AT then does during it.<br><br><i>Default: Off</i>",
  "AutoWind": "What AT does with your Wind tokens.<br><br><b>Empowerment</b> levels up Wind Empowerment. <b>Transfer</b> raises its retain level (capped at 80 by the game). <b>Convert to Poison/Ice</b> trades Wind tokens for the other nature at whatever rate your Nature talents give you. <b>Convert to Both</b> splits the trade evenly between Poison and Ice, and costs twice as many tokens per trade as converting to just one.<br><br><i>Default: Off</i>",
  "BWraid": "Turns on BW (Bionic World) Raiding: hunts every gear prestige out of your furthest Bionic World, at the zone(s) you set below.<br><br><b>AT writes this box.</b> AT turns your game's <b>Climb BW</b> option off itself while this runs, so BW leveling doesn't compete with the raid.<br><br><i>Default: Off</i>",
  "BWraidingmax": "How far into each Bionic World to raid, paired position-by-position with <b>Z to BW Raid</b>.<br><br>See <b>Z to BW Raid</b> for how the pairing works.<br><br><i>Default: -1</i>",
  "BWraidingz": "Zones to BW Raid at, paired position-by-position with <b>Max BW to raid</b>.<br><br><b>Cannot:</b> The two lists must be the same length, or BW Raiding can fail.<br><br>Example: <b>480, 495</b> paired with Max BW to raid <b>500, 515</b> raids up to BW level 500 starting at zone 480, then up to 515 starting at zone 495. Lower BWs are skipped once you already have enough damage for them. Once every prestige is obtained, AT returns to regular farming.<br><br><i>Default: -1</i>",
  "BetterAutoFight": "Decides how AT gets your squad into a fight.<br><br><b>Cannot:</b> If you run AutoPortal with this set to Off, the game can sit idle after a portal until you click Fight yourself &mdash; not great for AFK play.<br><br>Off leaves fighting to you or the vanilla AutoFight button. <b>Better Auto Fight</b> sends your squad whenever it's dead, a new squad is ready, the breed-timer target is exceeded, or breeding will finish in under 0.5s. <b>Vanilla</b> layers the game's own AutoFight logic on top and makes sure you fight before portaling. Works the same way in both universes.<br><br><i>Default: Better Auto Fight</i>",
  "BuyArmorNew": "Controls U1 armor automation: buying Prestiges, leveling up the most cost-efficient armor piece, or both.<br><br>Buying the Gymystic prestige upgrade specifically is controlled by this setting's Prestiges option (Buy Both or Prestiges).<br><br><i>Default: Armor: Buy Both</i>",
  "BuyBuildingsNew": "Controls whether AT buys non-storage Buildings (Huts, Warpstations, Gateways, Nurseries, etc.), Storage (Barn/Shed/Forge), both, or neither.<br><br><b>Buy Buildings & Storage</b> runs both automations. <b>Buy Buildings</b> buys non-storage buildings only — hand Storage to the game's own AutoStorage instead. <b>Buy Storage</b> buys Storage only. <b>Buy Neither</b> stops both (Gyms are the one exception — see <b>Hide Buildings</b>).<br><br>Storage purchases anticipate Jestimp and buy shortly before a resource would overflow, rather than waiting for it to actually cap out.<br><br><i>Default: Buy Buildings & Storage</i>",
  "BuyJobsNew": "Hires Farmers, Lumberjacks and Miners for you.<br><br><b>Cannot:</b> While this is on you cannot assign workers by hand — the bot will undo you. Choose <b>Don't Buy Jobs</b> to take over.<br><br><b>Auto Worker Ratios</b> picks the split for you from this table, and rewrites the three ratio boxes below every tick:<br>1 / 1 / 98 &mdash; from zone 300 (this beats every rule below)<br>1 / 7 / 12 &mdash; over 3000 Tributes, in Magma<br>1 / 2 / 22 &mdash; over 1500 Tributes<br>1 / 1.1 / 10 &mdash; over 1000 Tributes<br>3 / 1 / 4 &mdash; over 3M max Trimps<br>3 / 3.1 / 5 &mdash; over 300k max Trimps<br>1.1 / 1.15 / 1.2 &mdash; otherwise<br><br>The Watch challenge forces the bottom row; the Metal challenge forces 4 / 5 / 0.<br><br><b>Manual Worker Ratios</b> uses the three boxes below as you set them. Give them three <i>different</i> values — two equal ratios can put the bot in a hire/fire loop.<br><br><i>Default: Auto Worker Ratios</i>",
  "BuyShieldblock": "Buys the Shield Block upgrade, and prioritizes running The Block map to unlock it.<br><br>Caution: if you are progressing past zone 60, you probably do not want this.<br><br><i>Default: Off</i>",
  "BuyUpgradesNew": "Autobuys non-equipment upgrades in U1 (equipment upgrades are controlled from the Gear tab).<br><br><b>Manual Upgrades</b> buys nothing. <b>Buy All Upgrades</b> buys everything it can, including Coordination. <b>Upgrades no Coords</b> buys everything except Coordination — use this only if you specifically want to hold your population cap down.<br><br><i>Default: Buy All Upgrades</i>",
  "BuyWeaponsNew": "Controls U1 weapon automation: buying Prestiges, leveling up the most cost-efficient weapon, or both.<br><br><i>Default: Weapons: Buy Both</i>",
  "CapEquip2": "Do not level weapons past this level.<br><br>Helps avoid wasting metal leveling a weapon high only to prestige it right after. Disable with -1 or 0. During liquified or heavily-overkilled zones the effective cap drops to a tenth of this value.<br><br>Levels only get bought while AT judges it does not have enough damage yet (or, with <b>Invest Spare Metal</b> on, whenever it can afford a level) — reaching this cap does not by itself force any leveling. During Spire, weapons are leveled to this cap unconditionally.<br><br><i>Default: 10</i>",
  "CapEquiparm": "Do not level armor past this level.<br><br>Helps avoid wasting metal leveling armor high only to prestige it right after. Disable with -1 or 0. During liquified or heavily-overkilled zones the effective cap drops to a tenth of this value.<br><br>Levels only get bought while AT judges it does not have enough survivability yet (or, with <b>Invest Spare Metal</b> on, whenever it can afford a level) — reaching this cap does not by itself force any leveling. During Spire, armor is leveled to this cap unconditionally.<br><br><i>Default: 10</i>",
  "ChangeLog": "A button, not a toggle — reopens the changelog popup AT shows on startup, in case you missed it.",
  "CleanupAutoTrimps": "Removes leftover keys in your saved settings file from settings that older versions of AutoTrimps used to define, but this version no longer does.<br><br>Previews the exact key list first and only deletes after you explicitly confirm — your live settings are never touched.",
  "CustomAutoPortal": "The zone AT portals after clearing, when AutoPortal is set to Custom.<br><br><b>Ignored:</b> AutoPortal is not set to Custom.<br><br>E.g. setting this to 200 portals the moment you first reach level 201.<br><br><i>Default: 999</i>",
  "CustomDeltaFactor": "Tunes how aggressively Auto Gigas' delta grows — think of it as how long your target zone takes to clear, divided by the zone you bought your first Gigastation in.<br><br><b>Ignored:</b> Only matters for your FIRST Gigastation of a run — Auto Gigas computes a pattern once, when <b>Gigastation</b> is still at 0.<br><br><b>Cannot:</b> Values below 1 are silently discarded — AT uses 10 instead.<br><br>A higher number means a higher delta. <b>Recommended range from the community:</b> 1-2 for very quick runs, 5-10 for regular runs that slow down at the end, 20-100+ for very pushy runs. Above 20 it also unlocks the health/damage and map-stack conditions on <b>Auto Gigas</b> itself (see its tooltip).<br><br><i>Default: -1</i>",
  "CustomTargetZone": "The target zone Auto Gigas uses when calculating its Warpstation delta, instead of letting AT guess one from your portal/void settings.<br><br><b>Ignored:</b> Only matters for your FIRST Gigastation of a run — Auto Gigas computes a pattern once, when <b>Gigastation</b> is still at 0.<br><br><b>Cannot:</b> Values below 60 are silently discarded — AT falls back to computing its own target zone.<br><br><i>Default: -1</i>",
  "DailyVoidMod": "The zone at which AT runs Void Maps during a Daily.<br><br>-1 disables Daily Void Maps entirely.<br><br><i>Default: -1</i>",
  "Dailybwraid": "Master switch for Daily BW (Bionic Werewolf) Raiding.<br><br>Turns off the game's native \\"Climb BW\\" option while active, since AT is now driving BW selection itself.<br><br><i>Default: Off</i>",
  "DefaultAutoTrimps": "Wipes your saved AutoTrimps settings and reloads the script's factory defaults.<br><br><b>Cannot:</b> This is permanent — export your current settings first if you might want them back.",
  "DelayArmorWhenNeeded": "Delays buying armor prestige upgrades while in Want More Damage or Farming automap modes.<br><br><b>Cannot:</b> Only applies to Prestiges — armor level purchases are unaffected.<br><br>If you need both health and damage at the same time, armor prestiges still get bought regardless of this setting.<br><br><i>Default: Off</i>",
  "DeltaGigastation": "How many extra Warpstations to buy for each Gigastation after the first.<br><br><b>AT writes this box.</b> While <b>Auto Gigas</b> is on (the default), AT computes this itself when it buys your first Gigastation of a run and writes its answer back here — overwriting what you typed. Turn <b>Auto Gigas</b> off to drive it by hand.<br><br><b>Ignored:</b> Buying upgrades is off — Gigastations are an upgrade, so nothing is bought at all.<br><br>Decimals are supported: <b>2.5</b> buys +2 / +3 / +2 / +3…<br><br><i>Default: 2</i>",
  "DisableFarm": "Sets the Health:Damage ratio above which AutoTrimps switches into Farming mode &mdash; repeating maps for prestige items and map bonus instead of pushing forward.<br><br><b>-1</b> disables Farming mode entirely, however strong you get.<br><br><i>Default: -1</i>",
  "DynamicGyms": "Stops AT from buying more Gyms once your block comfortably beats the enemy's attack.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>Checks your block against both the current enemy's attack and a projected cell-99 enemy at your zone, plus a health / Crushed / Explosive-daily safety check. Works alongside Max Gyms and Gym Wall (whichever stops buying first wins) rather than replacing them.<br><br><i>Default: Off</i>",
  "DynamicPrestige2": "Set a target zone to gradually work up to your chosen Prestige setting, instead of running it from the start.<br><br><b>AT writes this box.</b> While active (and while <b>Force Prestige Z</b> has not yet been reached), AT recalculates and overwrites the <b>Prestige</b> dropdown itself every tick — what you pick there stops being read directly.<br><br><b>Ignored:</b> Your Prestige dropdown is set to Dagadder or an earlier option (index 2 or below) — Dynamic Prestige only kicks in for later targets.<br><br>Runs with a cheap early weapon (Dagadder) to save time until better gear is actually needed, then raises the effective prestige target as you approach the zone you set here. Disable with 0 or -1.<br><br><i>Default: -1</i>",
  "DynamicSiphonology": "Lets AutoTrimps pick the lowest map level within your Siphonology range that you can still one-shot, instead of always diving to the deepest level Siphonology allows.<br><br>Siphonology is a portal perk that grants map-bonus stacks for running maps below your current zone, one zone of leeway per perk level. With this <b>ON</b>, AutoTrimps searches upward from the deepest allowed level until it finds one your current damage can clear in one hit. With this <b>OFF</b>, it always dives to the deepest level Siphonology allows, whether or not you can one-shot it.<br><br><i>Default: On</i>",
  "EnableAFK": "A button, not a toggle — clicking it puts AutoTrimps into AFK Mode: a black overlay covers the game and the browser stops repainting the Trimps UI, to save CPU while you're away.<br><br>Also silences console debug output. Click <b>I'm Back</b> on the overlay to resume normal updates. You can also click the zone/world-info area at the top of the game at any time to trigger AFK Mode without using this button.",
  "EnhanceGrids": "Adds a drop-shadow highlight to exotic, powerful and skeleton-type Trimps on the world and map grids, so they stand out at a glance.<br><br>Purely visual — it changes nothing about how AT plays.<br><br><i>Default: Off</i>",
  "ExitSpireCell": "Exits the Spire once you have cleared this cell (1-100; e.g. 40 = Row 4).<br><br><b>Ignored:</b> Universe 2 (Radon) — the Mega-Spire has no per-cell exit implemented yet.<br><br><b>Cannot:</b> 0 or a negative number disables it. Values above 100 never trigger — a Spire floor only has 100 cells.<br><br>Also feeds AT's enemy-difficulty planning for the Spire, so it gears up for the difficulty at your exit cell rather than for the full run.<br><br><i>Default: -1</i>",
  "Export550": "Shows a canned example AutoTrimps settings string tuned for a late game (roughly zone 550+).<br><br>This is a fixed example, not a snapshot of your own settings — use it as a starting point to import and adjust, not as a perfect fit.",
  "Export60": "Shows a canned example AutoTrimps settings string tuned for an early game (roughly zone 60).<br><br>This is a fixed example, not a snapshot of your own settings — use it as a starting point to import and adjust, not as a perfect fit.",
  "ExportAutoTrimps": "Opens your current AutoTrimps settings as a JSON string you can copy and save.<br><br>Paste it back in later via <b>Import AutoTrimps</b> to restore this exact configuration.",
  "FarmWhenNomStacks7": "During the Nom challenge, forces AutoTrimps into Farming mode once Improbability builds up enough Nom stacks &mdash; even if <b>Farming H:D</b> is set to -1 (disabled).<br><br><b>Ignored:</b> Only relevant during the Nom challenge.<br><br>At 5+ stacks it stacks 30 Anticipation. Past 7 stacks it gets +200% damage from Map Bonus. If it still can't win the fight, it forces Farming at 30 stacks (exiting once the ratio drops back under 10x), and again at 100 stacks anywhere in the world &mdash; including inside a void map, which it also exits and blocks from restarting until the stack pressure clears.<br><br><i>Default: Off</i>",
  "FarmerRatio": "Farmer's share of your Farmer / Lumberjack / Miner workforce.<br><br><b>AT writes this box.</b> In <b>Auto Worker Ratios</b> mode (the default) AutoTrimps rewrites this box every tick from its own table, so a value you type here is discarded. Switch <b>Buy Jobs</b> to <b>Manual Worker Ratios</b> to set it yourself.<br><br><b>Only the proportions matter.</b> Each is divided by the sum of all three, so <b>1 / 1 / 1</b>, <b>10 / 10 / 10</b> and <b>33 / 33 / 33</b> are the same setting. The live percentage is shown on the button.<br><br><i>Default: 1</i>",
  "FinishC2": "Ends whatever Challenge² run is active once you reach this zone, then abandons it (portals out).<br><br><b>Ignored:</b> No Challenge² is currently running — it has no effect on a normal run.<br><br><b>Do not combine with C2 Runner.</b> C2 Runner's own <b>C2 Runner Portal</b> zone can abandon the same run at a different target, and the two will race each other. Set to -1 to disable.<br><br><i>Default: -1</i>",
  "FirstGigastation": "How many Warpstations to buy before your first Gigastation.<br><br><b>AT writes this box.</b> While <b>Auto Gigas</b> is on (the default), AT computes this itself when it buys your first Gigastation of a run and writes its answer back here — overwriting what you typed. Turn <b>Auto Gigas</b> off to drive it by hand.<br><br><i>Default: 20</i>",
  "ForceAbandon": "Sacrifices your current squad to fetch a fresh one once your Anticipation stacks fall behind.<br><br><b>Ignored:</b> Never fires in the Spire. Ignored in Universe 2.<br><br>Fires once your breed timer has run past 30 seconds (45 with the Patience talent) and Anticipation stacks have not caught up. Kills the squad (Trimpicide) for a new one on the World map, or abandons the current map if you are in a void.<br><br><i>Default: On</i>",
  "ForcePresZ": "On and after this zone is reached, always try to prestige for everything immediately, ignoring Dynamic Prestige and Prestige Skip.<br><br>Disable with -1.<br><br><i>Default: -1</i>",
  "GymWall": "Slows Gym buying to conserve wood — only buys 1 Gym at a time once you can afford <b>X</b> Gyms' worth of wood (at the first one's price), instead of AT's normal bulk-buy amount.<br><br><b>Ignored:</b> <b>-1</b> or <b>0</b> — both fully disable it, restoring AT's normal bulk Gym buying. <b>1</b> only stops Gyms being bought 2-at-a-time by the mastery; above <b>1</b> the wood wall applies as well. Also ignored in Universe 2, where Gyms are not automated at all.<br><br>Takes decimals. In other words, only allows a Gym purchase once it costs less than 1/X of your current wood — handy for saving wood for Nurseries once you're on the z230+ Magma nursery strategy.<br><br><i>Default: -1</i>",
  "Hdshrine": "Spends Bone Shrine charges automatically while you are on a Daily.<br><br><b>Daily AutoShrine On</b> uses the Daily zone/cell/amount list — click <b>Daily AutoShrine Settings</b> to edit it.<br><br><b>DAS: Normal</b> uses your ordinary (non-daily) <b>AutoShrine</b> settings from the Maps tab instead, so you do not have to configure a second list. Your normal AutoShrine must be switched on for it to do anything.<br><br><i>Default: Daily AutoShrine Off</i>",
  "Hdshrineamount": "The charge-amount list for Daily AutoShrine, matched by position to Daily AutoShrine's zone and cell lists.<br><br>Edited through the <b>Daily AutoShrine Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: -1</i>",
  "Hdshrinecell": "The cell list for Daily AutoShrine, matched by position to Daily AutoShrine's zone and amount lists.<br><br>Edited through the <b>Daily AutoShrine Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: -1</i>",
  "Hdshrinemaz": "Opens the Daily AutoShrine settings popup, where you configure the zone/cell/amount list Daily AutoShrine uses.<br><br><b>Zone:</b> world zone to spend a charge at. <b>Cell:</b> cell within that zone to spend it at — past cell 80 you get the benefit of all Bone Shrine books. <b>Amount:</b> how many charges to spend there. Example: Zone 40, Cell 10, Amount 3 spends 3 charges at zone 40, cell 10, during a Daily.",
  "Hdshrinezone": "The zone list for Daily AutoShrine, matched by position to Daily AutoShrine's cell and amount lists.<br><br>Edited through the <b>Daily AutoShrine Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: -1</i>",
  "HeHrDontPortalBefore": "Blocks the Helium Per Hour AutoPortal from firing before this zone is reached, even if your He/hr has already dropped.<br><br><b>Ignored:</b> AutoPortal is not set to Helium Per Hour.<br><br>Set to 0 or -1 to remove the check entirely.<br><br><i>Default: 999</i>",
  "HeliumHourChallenge": "The challenge AT auto-selects for your next run.<br><br><b>Ignored:</b> AutoPortal is not set to Helium Per Hour or Custom — with any other AutoPortal mode, the mode's own challenge choice is used instead and this setting is not read.<br><br><i>Default: None</i>",
  "HeliumHrBuffer": "How far your He/hr has to drop below your run-best before Helium Per Hour AutoPortal triggers.<br><br><b>Ignored:</b> AutoPortal is not set to Helium Per Hour.<br><br>E.g. 5 portals once your He/hr falls to 95% of your best this run. Includes stuck protection: if you overshoot the buffer by 5x while stuck mid-zone, it portals anyway instead of waiting for cell 1.<br><br><i>Default: 0</i>",
  "Hshrine": "Turns on automatic Bone Shrine charge use at the zone(s), cell(s), and amount(s) you configure in <b>AutoShrine Settings</b> below.<br><br><b>Cannot:</b> Requires Bone Shrine charges to actually be available, and is a separate mechanism from <b>Auto Bone Charge Max</b> elsewhere &mdash; the two do not interact.<br><br><i>Default: Off</i>",
  "Hshrineamount": "The list of charge counts (one per zone) AutoShrine spends &mdash; the raw storage behind the <b>AutoShrine Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length, in the same order, as its <b>Zone</b> and <b>Cell</b> siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Hshrinecell": "The list of cells (one per zone) AutoShrine waits for before spending charges &mdash; the raw storage behind the <b>AutoShrine Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length, in the same order, as its <b>Zone</b> and <b>Amount</b> siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Hshrinecharge": "Internal bookkeeping AutoTrimps uses to track how many Bone Shrine charges it has already spent at the current zone.<br><br><b>Cannot:</b> Not meant to be edited by hand &mdash; it resets to 0 automatically every time you enter a new zone.<br><br><i>Default: 0</i>",
  "Hshrinemaz": "Opens the AutoShrine editor: pick the zone, cell, and how many Bone Shrine charges to spend there.<br><br><b>Cannot:</b> The charge count resets every time you enter a new zone, so <b>Amount</b> means \\"how many to use at this zone\\", not a lifetime total.<br><br>Example: Zone 40, Cell 10, Amount 3 uses 3 Bone Shrine charges the first time you reach cell 10 of zone 40. Using it after cell 80 gets the benefit of all the books.",
  "Hshrinezone": "The list of zones AutoShrine triggers at &mdash; the raw storage behind the <b>AutoShrine Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length, in the same order, as its <b>Cell</b> and <b>Amount</b> siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "IgnoreCrits": "Controls which crit multipliers AT's survival math accounts for when picking a stance.<br><br><b>Ignored:</b> Ignored in Universe 2, and hidden whenever AutoStance is set to Windstacking (option 3) &mdash; windstacking does not run this calc.<br><br><b>Cannot:</b> This only changes what AT plans for, not what the game actually rolls &mdash; a more aggressive option does not stop real crits from landing.<br><br><b>Safety First</b> counts every crit source: corrupted-enemy crits, Corrupted Precision / void-strength crits, and challenge crits. <b>Ignore Void Strength</b> drops only the void-strength crit multiplier from the calc; mutation and challenge crits are still counted. <b>Ignore All Crits</b> drops every crit multiplier, treating every hit as non-crit.<br><br><i>Default: Safety First</i>",
  "IgnoreSpiresUntil": "The zone gate for every Spire-specific setting on this tab, plus the Scryer's in-Spire stance option: none of them take effect while your current world zone is below this value — even while you are standing inside an active Spire.<br><br>0 makes every Spire setting active from Spire 1 onward.<br><br><i>Default: 200</i>",
  "ImportAutoTrimps": "Opens a box to paste in a previously exported AutoTrimps settings string and load it.<br><br><b>Cannot:</b> This replaces your entire current settings file — there is no merge, and no undo once you confirm.<br><br>After importing, AT asks for a name to save it as a new settings profile.",
  "InvestSpareMetal": "Keep leveling the most efficient gear whenever you can afford it, instead of stopping once you are \\"strong enough\\" for the current zone.<br><br>Normally AT buys armor only while it cannot survive enough hits, and weapons only while it cannot kill fast enough (see <b>Equipment Cut Off</b>). Once both are satisfied it buys nothing and banks the metal. Measured on a real z21 save: it declined an affordable gear level on <b>18,503 of 20,000 ticks</b>. Turning this on reaches the next zone <b>~19.5% sooner</b> — not by buying much more gear (only ~3 extra levels), but by buying it <b>early</b>, where the damage compounds into faster clears and more income.<br><br>The level caps (<b>Weapon/Armor Level Cap</b>) and the efficiency choice are still respected — this only removes the \\"I am strong enough, stop buying\\" brake.<br><br><i>Default: Off</i>",
  "LowerFarmingZone": "While farming, lets AutoTrimps drop to a lower zone it can one-shot instead of staying at your current zone.<br><br>Uses the same one-shot search as <b>Dynamic Siphonology</b> to find the lowest map level your damage can clear, but only kicks in after your first 10 map-bonus stacks &mdash; before that it still farms within Siphonology's normal range. It can go as far as 10 zones below your current zone if your damage is that far behind, which usually means it is time to portal instead.<br><br><i>Default: On</i>",
  "LumberjackRatio": "Lumberjack's share of your Farmer / Lumberjack / Miner workforce.<br><br><b>AT writes this box.</b> In <b>Auto Worker Ratios</b> mode (the default) AutoTrimps rewrites this box every tick from its own table, so a value you type here is discarded. Switch <b>Buy Jobs</b> to <b>Manual Worker Ratios</b> to set it yourself.<br><br><b>Only the proportions matter.</b> Each is divided by the sum of all three, so <b>1 / 1 / 1</b>, <b>10 / 10 / 10</b> and <b>33 / 33 / 33</b> are the same setting. The live percentage is shown on the button.<br><br><i>Default: 1</i>",
  "MagmiteExplain": "Reference: the order AT spends Magmite in Normal mode.<br><br>Buys the one-and-done permanent upgrades in a fixed order &mdash; Slowburn, Shielding, Storage, Hybridization, Supervision, Simulacrum &mdash; not sorted by price (Supervision and Simulacrum are the two most expensive of the six, and are bought last). Then Overclocker if affordable (skipped past its first level under some Magmite Spending Behaviour options). Then Efficiency, if it beats Capacity's cost-per-percent. Otherwise Capacity or Supply, whichever the Throttle Supply setting favors.",
  "ManualGather2": "Controls how AT gathers resources and builds in U1 (Helium).<br><br><b>Manual Gather/Build</b> does nothing — you gather and build entirely by hand.<br><br><b>Auto Gather/Build</b> runs the full gather/build/trap/research loop.<br><br><b>Mining/Building Only</b> switches to a much simpler loop that just gathers metal or works your build queue, skipping trapping and research entirely — meant for once you have the Foremany mastery and no longer need food or wood.<br><br><b>Science Research OFF</b> behaves like Auto Gather/Build but never gathers science by hand (useful for the \\"reach Z120 without manual research\\" achievement).<br><br><i>Default: Auto Gather/Build</i>",
  "MaxCollector": "Caps how many Collectors AT will build.<br><br>-1 = no cap.<br><br><i>Default: -1</i>",
  "MaxExplorers": "Hard ceiling on how many Explorers AutoTrimps will keep.<br><br><b>Cannot:</b> <b>This is a cap, not a target.</b> It can only ever LOWER the count — raising it never hires anyone.<br><br><b>-1</b> = no cap. An exact number caps at that many.<br><br><i>Default: -1</i>",
  "MaxGateway": "Caps how many Gateways AT will build.<br><br>-1 = no cap.<br><br><i>Default: 25</i>",
  "MaxGym": "Caps how many Gyms AT will build.<br><br><b>Ignored:</b> You are playing Universe 2 (Radon) — AT has no Gym automation there at all; this setting (and <b>Gym Wall</b>) only affects Universe 1.<br><br>-1 = no cap.<br><br><i>Default: -1</i>",
  "MaxHotel": "Caps how many Hotels AT will build.<br><br>0 or lower removes the cap entirely.<br><br><i>Default: 100</i>",
  "MaxHouse": "Caps how many Houses AT will build.<br><br>0 or lower removes the cap entirely.<br><br><i>Default: 100</i>",
  "MaxHut": "Caps how many Huts AT will build.<br><br>0 or lower removes the cap entirely.<br><br><i>Default: 100</i>",
  "MaxMansion": "Caps how many Mansions AT will build.<br><br>0 or lower removes the cap entirely.<br><br><i>Default: 100</i>",
  "MaxMapBonusAfterZone": "Forces AutoTrimps to farm up to your full Map Bonus cap starting at this zone (inclusive), every time you reach it.<br><br><b>Cannot:</b> Cannot lower the actual stack target below what the sibling setting <b>Max MapBonus Limit</b> allows &mdash; that is what sets the cap, not a console command. (An earlier version of this tooltip pointed at a hidden console command, <code>MODULES[\\"maps\\"].maxMapBonusAfterZ</code>, that nothing in the code reads &mdash; ignore it.)<br><br><b>0</b> applies it from the very first zone. <b>-1</b> disables it entirely. While active, this also delays weapon/armor purchases until the map-bonus cap is hit for that zone.<br><br><i>Default: -1</i>",
  "MaxMapBonushealth": "Caps how many extra Map Bonus stacks AutoTrimps will farm purely to raise your health, when health is short.<br><br>Only kicks in below this many stacks, while AutoTrimps isn't already mapping for another reason and doesn't need to prestige. Above this many stacks, health-farming stops even if health is still short.<br><br><i>Default: 10</i>",
  "MaxMapBonuslimit": "Caps how many Map Bonus stacks AutoTrimps will farm for before moving on.<br><br>Once you reach this many stacks, AutoTrimps stops farming for more and continues the run &mdash; or, if it was already farming, drops to <b>Lower Farming Zone</b> instead.<br><br><i>Default: 10</i>",
  "MaxNursery": "Caps how many Nurseries AT will build.<br><br>-1 = no cap. Nurseries only become worth stacking once you've reached Magma (zone 230+) — pair with <b>No Nurseries Until z</b> to gate when AT starts building them at all.<br><br><i>Default: -1</i>",
  "MaxPraidZone": "How far past each P Raiding zone Hardcore P Raiding is allowed to push, paired position-by-position with <b>P Raiding Z</b>.<br><br><b>Ignored:</b> <b>Hardcore P Raiding</b> is off.<br><br>Example: P Raiding Z is <b>491, 495</b> and this is <b>495, 505</b> &mdash; AT raids up to 495 starting from 491, then up to 505 starting from 495. <b>-1</b>, a missing pair, or an invalid value all default to the highest available prestige (up to +10).<br><br><i>Default: -1</i>",
  "MaxResort": "Caps how many Resorts AT will build.<br><br>0 or lower removes the cap entirely.<br><br><i>Default: 100</i>",
  "MaxScientists": "Hard ceiling on how many Scientists AutoTrimps will keep.<br><br><b>Cannot:</b> <b>This is a cap, not a target.</b> It can only ever LOWER the count — raising it never hires anyone. To hire <i>more</i> Scientists, use <b>Scientist %</b>.<br><br><b>-1</b> = no cap. An exact number caps at that many.<br><br><i>Default: -1</i>",
  "MaxStacksForSpire": "Farms Map Bonus stacks up to 10 (the practical max) before continuing a Spire run, instead of entering or continuing at whatever stack you happened to have.<br><br><b>Ignored:</b> Below your <b>Ignore Spires Until</b> zone, or you are not currently in an active Spire.<br><br><i>Default: Off</i>",
  "MaxTrainers": "Hard ceiling on how many Trainers AutoTrimps will keep.<br><br><b>Cannot:</b> <b>This is a cap, not a target.</b> It can only ever LOWER the count — raising it never hires anyone.<br><br><b>-1</b> = no cap. An exact number caps at that many.<br><br><i>Default: -1</i>",
  "MaxTribute": "Caps how many Tributes AT will build.<br><br>-1 = no cap.<br><br><i>Default: -1</i>",
  "MaxWormhole": "Caps how many Wormholes AT will build.<br><br><b>Cannot:</b> Cannot be set to \\"unlimited\\" the way the other Max settings can — there is no -1 sentinel here. 0 or lower means AT never buys a Wormhole at all; you must set a specific positive number to allow any.<br><br>Wormholes cost <b>helium</b>, not gold — a Wormhole bought is helium you can't spend on perks that portal.<br><br><i>Default: 0</i>",
  "MetalEfficiencyPriority": "During the Metal challenge, buys the Efficiency upgrade before any other upgrade while below your Metal Efficiency Zone.<br><br><b>Ignored:</b> You are not in the Metal challenge, or your world zone is at or above Metal Efficiency Zone.<br><br>During Metal all metal comes from manual mining, and each Efficiency level doubles it, so rushing Efficiency early can save time per zone. Opt-in — off is the unchanged, pre-existing behavior.<br><br><i>Default: Off</i>",
  "MetalEfficiencyZone": "The zone cutoff for <b>Metal: Efficiency First</b> — Efficiency is only rushed while your world zone is below this value.<br><br><b>Ignored:</b> Metal: Efficiency First is off.<br><br>Past that zone, map farming dominates metal income and rushing Efficiency stops mattering, so the priority turns itself off.<br><br><i>Default: 6</i>",
  "MinerRatio": "Miner's share of your Farmer / Lumberjack / Miner workforce.<br><br><b>AT writes this box.</b> In <b>Auto Worker Ratios</b> mode (the default) AutoTrimps rewrites this box every tick from its own table, so a value you type here is discarded. Switch <b>Buy Jobs</b> to <b>Manual Worker Ratios</b> to set it yourself.<br><br><b>Only the proportions matter.</b> Each is divided by the sum of all three, so <b>1 / 1 / 1</b>, <b>10 / 10 / 10</b> and <b>33 / 33 / 33</b> are the same setting. The live percentage is shown on the button.<br><br><i>Default: 1</i>",
  "MinutestoFarmBeforeSpire": "Farms zone-200 (or Boss World) maps for this many minutes after entering a Spire, before actually continuing into it.<br><br><b>Ignored:</b> Below your <b>Ignore Spires Until</b> zone, or you are not currently in an active Spire.<br><br><b>Cannot:</b> Cannot be set to run forever — a negative number does not mean \\"infinite\\". It behaves exactly like 0, because the elapsed-time comparison it drives can never be true for a negative target. Use a very large number of minutes instead.<br><br>0 disables it.<br><br><i>Default: 0</i>",
  "NoNurseriesUntil": "Builds Nurseries starting from this zone, not before.<br><br><b>Ignored:</b> Overridden by <b>Nurseries pre-Spire</b> while you are farming for or already in a Spire — that setting can build Nurseries earlier to prepare, regardless of this zone.<br><br>-1 builds them as soon as they unlock.<br><br><i>Default: -1</i>",
  "NurseryWall": "Withholds a percentage of your wood, gems, and metal from Nursery purchases, so one big Nursery buy can't eat resources you need elsewhere that tick.<br><br><b>Cannot:</b> 0 or lower disables the wall entirely (no percentage cap).<br><br>Set N and AT only spends up to N% of your <i>current</i> wood/gems/metal on a single Nursery purchase — if the Nursery would cost more than that share of any one of those resources, AT skips buying it that tick.<br><br><i>Default: -1</i>",
  "PauseScript": "Pauses all of AutoTrimps.<br><br>The Graphs module keeps running while paused — only the automation loop stops.<br><br><i>Default: Off</i>",
  "PowerSaving": "Controls whether AT will jump into Maps/void/prestige early, before your squad is ideally ready, when it judges you need to.<br><br><b>Ignored:</b> U1 only (#44): not read in Universe 2 (Radon). To rush void maps in U2, use <b>Void Maps</b> / <b>Voids Cell</b> / <b>New Voids Mod</b> on the Maps tab instead.<br><br><b>Cannot:</b> With Don't Abandon selected, AT can no longer auto-recover from a stuck Scryer stance through this path.<br><br><b>AutoAbandon</b> lets AT commit early whenever it detects you need a prestige, need to void, are in a Lead-parity or farming window, or your Scryer stance is stuck. <b>Don't Abandon</b> turns this early-entry check off entirely &mdash; AT keeps waiting on World even if that risks getting stuck. <b>Only Rush Voids</b> keeps the early-entry check for voiding only, not for prestige or farming triggers.<br><br><i>Default: AutoAbandon</i>",
  "PraidBeforeFarmZ": "Zones where Hardcore P Raiding buys the best map it can afford right away, instead of farming fragments for a better one first.<br><br><b>Ignored:</b> <b>Hardcore P Raiding</b> is off.<br><br>Mostly useful for a lucky Speedexplorer pickup, or when fragment farming is unusually slow. <b>-1</b> = always try farming fragments first.<br><br><i>Default: -1</i>",
  "PraidFarmFragsZ": "Zones where Hardcore P Raiding is allowed to farm fragments if it can't afford the map it wants for that raid.<br><br><b>Ignored:</b> <b>Hardcore P Raiding</b> is off.<br><br><b>-1</b> = never farm fragments for P Raiding.<br><br><i>Default: -1</i>",
  "PraidHarder": "<b>EXPERIMENTAL.</b> Replaces the normal P Raiding engine with a more aggressive one, for the same zones you list in <b>P Raiding Z</b>.<br><br><b>Cannot:</b> Does nothing if <b>P Raiding Z</b> is empty, even with this on.<br><br>Always buys the highest-prestige map it can afford at each P Raiding zone, farming fragments for it if it can't. This does not add a separate raid list &mdash; it takes over <b>P Raiding Z</b> and ignores P Raiding HD, Poison, and Ice entirely.<br><br><i>Default: Off</i>",
  "PraidingHD": "How far into the five +N prestige maps to push, based on your H:D ratio.<br><br><b>Ignored:</b> <b>Hardcore P Raiding</b> is on &mdash; that mode replaces this check with its own fragment-farming logic.<br><br>AT compares this against the H:D each +N map would take to clear; the higher you set it, the higher +N maps it will attempt (up to +5, or further with Hardcore P Raiding). <b>-1 or 0</b> removes the check entirely, so it always attempts every +N map.<br><br><i>Default: -1</i>",
  "PraidingI": "Caps how far into the +N prestige maps AT will push while empowered by <b>Ice</b>.<br><br><b>Ignored:</b> <b>Hardcore P Raiding</b> is on.<br><br>Example: <b>10</b> allows up to +10 maps in Ice. Use this instead of P Raiding HD if its math looks off for Ice zones &mdash; both can be set at once. <b>-1 or 0</b> = no max.<br><br><i>Default: -1</i>",
  "PraidingP": "Caps how far into the +N prestige maps AT will push while empowered by <b>Poison</b>.<br><br><b>Ignored:</b> <b>Hardcore P Raiding</b> is on.<br><br>Example: <b>10</b> allows up to +10 maps in Poison. Use this instead of P Raiding HD if its math looks off for Poison zones &mdash; both can be set at once. <b>-1 or 0</b> = no max.<br><br><i>Default: -1</i>",
  "Praidingcell": "Cell to start P Raiding at, once you reach a P Raiding zone.<br><br><b>-1</b> starts at cell 1. If you also run BW Raiding, set this below your BW Raiding cell.<br><br><i>Default: -1</i>",
  "Praidingzone": "Zones to Prestige-Raid at &mdash; hunts down every gear prestige in the maps above the zone(s) you list here.<br><br>Example: <b>495</b> raids maps 501-505 in sequence. Once every prestige from those maps is obtained, AT reverts to regular farming. <b>Multiple values work, like this: 495,506,525.</b> Use <b>P Raiding HD</b> to control how many of the five +maps it actually attempts &mdash; helpful for Spire, and best used in Poison zones.<br><br><i>Default: -1</i>",
  "PreSpireNurseries": "Sets a separate Nursery cap that applies specifically while preparing for or running a Spire, above zone 200 (or any zone once <b>Ignore Spires Until</b> allows Spire settings that early).<br><br><b>Cannot:</b> -1 disables it.<br><br>Overrides both <b>No Nurseries Until z</b> and <b>Max Nurseries</b> while active, so you can keep your general Nursery settings tight and still stock up before a Spire push.<br><br><i>Default: -1</i>",
  "PreferMetal": "Prefers metal-biome (Mountain) maps over Gardens/Plentiful maps when AutoTrimps reuses an already-owned map.<br><br><b>Ignored:</b> Only affects map selection during pre-Spire farming, when AutoTrimps is searching your owned maps for one to reuse. It has no effect on newly created maps or on ordinary map runs.<br><br>Intended for manual use, such as farming metal ahead of a Spire push. Remember to turn it back off afterward.<br><br><i>Default: Off</i>",
  "Prestige": "Acquire prestiges through the selected item (inclusive) as soon as they become available in maps.<br><br><b>AT writes this box.</b> If <b>Dynamic Prestige z</b> is on, AT recalculates and overwrites this box itself every tick until <b>Force Prestige Z</b> is reached.<br><br><b>Ignored:</b> Automap is not enabled — this forces equip-first mode but has no effect if AT is not running maps.<br><br><b>Cannot:</b> The last two options (Harmbalest, GambesOP) are only selectable once the game's Slow mastery is unlocked — otherwise the game resets your selection back down to Bestplate.<br><br>This is an important setting for speed-climbing — it should almost always be set to something. If AT gets stuck somewhere it should easily be able to clear, picking an option lower in the list makes you more powerful at all times, at the cost of spending more time acquiring prestiges in maps.<br><br><i>Default: Polierarm</i>",
  "PrestigeSkip1_2": "Skips entering (or exits) Prestige Mode in maps under either or both of two conditions, so AT does not stall chasing prestiges you are unlikely to need.<br><br><b>Prestige Skip 1</b> skips Prestige Mode while more than 2 unbought Prestiges (besides Shield) are sitting in your upgrades window unaffordable — that count is configurable via the console: <code>MODULES[\\"maps\\"].SkipNumUnboughtPrestiges</code>.<br><br><b>Prestige Skip 2</b> skips Prestige Mode while 2 or fewer weapon Prestiges remain unobtained in maps — for players who tend not to need the last few due to resource gain not keeping up; configurable via <code>MODULES.maps.UnearnedPrestigesRequired</code>.<br><br>With both selected, both conditions must hold before AT exits Prestige Mode.<br><br><i>Default: Prestige Skip Off</i>",
  "PurchaseCoordinator": "EXPERIMENTAL (#57). Makes AT save metal toward a high-value purchase instead of always spending it on whatever is affordable right now.<br><br><b>Cannot:</b> Cannot reserve for anything else yet — there is no general priority list, just this one Warpstation-for-Coordination case.<br><br>Today it only reserves metal toward your next Warpstation when Coordination is pending and you still need the population it grants — every other building purchase still runs first-come-first-served. Turning it on with no Coordination pending is a no-op. Turning it OFF gives exactly the behavior AT has always had.<br><br><i>Default: Off</i>",
  "RAB": "Master switch for SA (the game's Auto Battle minigame) automation below.<br><br><b>Ignored:</b> You have not reached SA level 75 yet.<br><br><b>Cannot:</b> Do not open Auto Battle's own manual input settings while this is on &mdash; doing so can crash the page.<br><br><i>Default: Off</i>",
  "RABdustsimple": "Auto-upgrades Auto Battle items with your dust, cheapest first.<br><br><b>Ignored:</b> <b>SA</b> (the master switch) is off, or you have not reached SA level 75.<br><br><b>SD: Equipped</b> only upgrades items you already have equipped. <b>SD: Non-hidden</b> upgrades items that are neither hidden nor equipped instead.<br><br><i>Default: Simple Dust Off</i>",
  "RABfarm": "Keeps a scoreboard of your best-ever Auto Battle dust/s and saves the level + loadout that earned it into <b>String</b> below.<br><br><b>AT writes this box.</b> Continuously checks your current dust/s and, whenever it beats the recorded best, overwrites the saved string with the new one.<br><br><b>Ignored:</b> <b>SA</b> (the master switch) is off, or you have not reached SA level 75.<br><br><i>Default: Off</i>",
  "RABfarmstring": "Your best-performing Auto Battle farming string.<br><br><b>AT writes this box.</b> AT writes its own best string here whenever it finds one that farms more dust, so a string you paste in can be replaced by AT's own.<br><br>Safe to share with other AT users. If you paste in someone else's string, set the <b>second</b> value (the dust figure) to <b>0</b> so AT measures the dust <i>you</i> actually get rather than trusting theirs.<br><br><i>Default: -1</i>",
  "RABfarmswitch": "Jumps Auto Battle straight to the level and loadout saved in <b>String</b> below.<br><br><b>Ignored:</b> <b>SA</b> (the master switch) is off, or you have not reached SA level 75.<br><br><i>Default: Off</i>",
  "RABpreset": "Auto-switches your equipped Auto Battle preset to match the enemy's weakest resistance.<br><br><b>Ignored:</b> <b>SA</b> (the master switch) is off, or you have not reached SA level 75.<br><br>Preset 1 must be built for Poison, Preset 2 for Bleed, Preset 3 for Shock. If the enemy resists fewer than two of the three, AT alternates between the non-resisted presets until it dies. It never buys or swaps individual items for you &mdash; if none of your presets fit, it can get stuck until you update them.<br><br><i>Default: Off</i>",
  "RABsolve": "Auto-plays Auto Battle for you: levels the right items, accepts and buys the right contracts, and picks the right enemy level, tier by tier up to level 10.<br><br><b>Ignored:</b> <b>SA</b> (the master switch) is off, or you have not reached SA level 75.<br><br>While an accepted Auto Battle contract needs a deeper zone than you've reached, this also pushes AT to void into that zone for you.<br><br><i>Default: Off</i>",
  "RAMPraid": "<b>MASTER BUTTON.</b> Turns on Prestige Raiding for U2: hunts down every gear prestige in the maps you configure under PR: Zone / PR: Raid / PR: Cell.<br><br><b>Cannot:</b> Does nothing until PR: Zone and PR: Raid both have a first entry above 0.<br><br>Example: world is 95, PR: Zone is <b>[95,105]</b>, PR: Raid is <b>[105,115]</b>, PR: Cell is <b>1</b>. AT enters map creation at cell 1 and creates prestige maps 101-105 in sequence, falling back to a non-prestige map (then the highest map it can afford) if it can't afford a prestige one. Once all five are created it runs them lowest-first, then recycles them if <b>PR: Recycle</b> is on.<br><br><i>Default: Off</i>",
  "RAMPraidcell": "Cell to start Prestige Raiding at, once you reach a PR: Zone entry.<br><br>Paired position-by-position with PR: Zone. Leaving an entry at <b>-1</b> starts at cell 1.<br><br><i>Default: -1</i>",
  "RAMPraidfrag": "Whether to farm fragments to afford the maps Prestige Raiding wants.<br><br><b>PR: Frag Min</b> targets the cheapest maps that still get all five prestiges (no special modifier, perfect sliders, or size/difficulty beyond what's needed) and prioritizes buying the most maps for a smooth sequential raid. <b>PR: Frag Max</b> goes for the strongest possible raid and may take longer to farm for. Prefer Min if your heirloom lacks frag drop or explorer efficiency; Max if you're confident in your fragment income.<br><br><i>Default: PR: Frag</i>",
  "RAMPraidmaz": "Opens the Praiding settings popup: PR: Zone / Raid / Cell / Frag / Recycle.",
  "RAMPraidraid": "How far to raid to, paired position-by-position with <b>PR: Zone</b>.<br><br>Example: PR: Zone <b>95</b> paired with PR: Raid <b>105</b> raids every prestige between zone 95 and 105.<br><br><i>Default: -1</i>",
  "RAMPraidrecycle": "Recycles the maps Prestige Raiding created, once the raid is done with them.<br><br><i>Default: Off</i>",
  "RAMPraidzone": "Zones that trigger Prestige Raiding, paired position-by-position with <b>PR: Raid</b>.<br><br><i>Default: -1</i>",
  "RAutoAllocatePerks": "Controls what happens to your unspent radon when you portal in U2.<br><br><b>Auto Allocate On</b> runs the ratio-based AutoPerks preset to spend your radon (it never touches the Fixed Perks). <b>Dump into Looting</b> instead spends your available radon to max out the Looting perk (or the Greed perk, if <b>Greed Dump</b> is on) on every portal, ahead of any ratio-based allocation.<br><br><i>Default: Auto Allocate Off</i>",
  "RAutoGoldenUpgrades": "The U2 (Radon) version of AutoGoldenUpgrades: automatically buys Golden Upgrades outside Dailies and Challenge2. <b>Radon</b> buys from the same underlying golden pool Helium uses (U2 has no separate golden pool of its own), <b>Battle</b> buys from the Battle pool, <b>Void</b> spends on the Void pool (the game caps this at 8 purchases) and falls back to Radon once it runs out, <b>Void + Battle</b> falls back to Battle instead.<br><br><b>Ignored:</b> Only active outside Dailies and Challenge2 &mdash; see <b>Daily AutoGoldenUpgrades</b> / <b>C2 AutoGoldenUpgrades</b> below.<br><br><b>Radon Battle</b> / <b>Battle Radon</b> can switch the Radon/Battle choice over after a purchase count; <b>Void Battle</b> can switch the Void fallback to Battle from a zone onward. See those settings.<br><br><i>Default: Off</i>",
  "RAutoMaps": "Lets AutoTrimps send you into maps on its own — to farm, to gain map bonus, and to clear what it needs. Recommended ON.<br><br><b>AT writes this box.</b> This is the same switch as the <b>AutoMaps</b> button on the game screen. Clicking that button changes this setting, and vice versa — they are one control in two places, so this box can change without you touching this panel.<br><br><b>Auto Maps No Unique</b> works the same but never runs unique maps such as Dimension of Rage.<br><br><i>Default: Auto Maps On</i>",
  "RAutoPortal": "Automatically portals in U2 once the condition for the selected mode is met.<br><br><b>Cannot:</b> Selecting Radon Per Hour can portal you immediately if your Rn/hr is already below your run best — use Pause AutoTrimps first if you want to check before it fires.<br><br><b>Radon Per Hour</b> portals at cell 1 of the first level where your Rn/hr dips below your best for the run by more than the <b>Rn/Hr Portal Buffer %</b> (subject to <b>Don't Portal Before</b>). <b>Custom</b> portals right after clearing the zone set in <b>Custom Portal</b>. Any named challenge (Bublé, Melt, Insanity, Hypothermia, and so on) portals as soon as the portal becomes available, provided no challenge is currently active.<br><br><i>Default: Off</i>",
  "RAutoPortalDaily": "Universe 2 twin of Daily Portal: automatically portals you out of a Daily challenge once a condition is met.<br><br><b>DP: Rn/Hr:</b> portals once your world zone is above the minimum you've set (if any) and your Radon/Hour has dropped below the buffer you've defined. <b>DP: Custom:</b> portals immediately after clearing the zone set in Daily Custom Portal.<br><br><i>Default: Daily Portal Off</i>",
  "RAutoStartDaily": "Universe 2 twin of Auto Start Daily: automatically starts a Daily challenge for you when you portal.<br><br>Selects and starts the oldest available Daily. The other settings in this tab decide what AT then does during it.<br><br><i>Default: Off</i>",
  "RBuyBuildingsNew": "Buys buildings for Universe 2 (Radon): Housing, Tributes, Smithy, Microchip, Labs, and Storage during Hypothermia.<br><br><b>Cannot:</b> Unlike Universe 1's <b>Buy Buildings</b>, this is a single on/off switch — there is no \\"buildings but not storage\\" split in Universe 2.<br><br>Also force-enables the game's own AutoStorage once, the first time it finds it off, so your resources don't overflow while you're setting up — after that one nudge it leaves your AutoStorage button alone, even if you turn AutoStorage back off yourself.<br><br><i>Default: On</i>",
  "RBuyJobsNew": "Hires Farmers, Lumberjacks and Miners for you.<br><br><b>Ignored:</b> During the <b>Quest</b> challenge past zone 5, AutoTrimps stops buying jobs entirely, whatever this is set to.<br><br><b>Cannot:</b> While this is on you cannot assign workers by hand — the bot will undo you. Choose <b>Don't Buy Jobs</b> to take over.<br><br><b>Auto Worker Ratios</b> picks the split for you from this table, and rewrites the three ratio boxes below every tick:<br>1 / 1 / 98 &mdash; from zone 300 (this beats every rule below)<br>1 / 7 / 12 &mdash; over 3000 Tributes, in Magma<br>1 / 2 / 22 &mdash; over 1500 Tributes<br>1 / 1.1 / 10 &mdash; over 1000 Tributes<br>3 / 1 / 4 &mdash; over 3M max Trimps<br>3 / 3.1 / 5 &mdash; over 300k max Trimps<br>1.1 / 1.15 / 1.2 &mdash; otherwise<br><br>The Transmute challenge forces 4 / 5 / 0.<br><br><b>Manual Worker Ratios</b> uses the three boxes below as you set them. Give them three <i>different</i> values — two equal ratios can put the bot in a hire/fire loop.<br><br><i>Default: Auto Worker Ratios</i>",
  "RBuyUpgradesNew": "Autobuys non-equipment upgrades in U2 (equipment upgrades are controlled from the Gear tab).<br><br><b>Manual Upgrades</b> buys nothing. <b>Buy All Upgrades</b> buys everything it can, including Coordination. <b>Upgrades no Coords</b> buys everything except Coordination.<br><br><i>Default: Buy All Upgrades</i>",
  "RCustomAutoPortal": "The zone AT portals after clearing, when RAutoPortal is set to Custom.<br><br><b>Ignored:</b> RAutoPortal is not set to Custom.<br><br>E.g. setting this to 200 portals the moment you first reach level 201.<br><br><i>Default: 999</i>",
  "RDailyVoidMod": "The zone at which AT runs Void Maps during a Universe 2 Daily.<br><br>-1 disables Daily Void Maps entirely.<br><br><i>Default: -1</i>",
  "RDisableFarm": "Sets the Health:Damage ratio above which AutoTrimps switches into Farming mode &mdash; the Universe 2 twin of <b>Farming H:D</b>.<br><br><b>-1</b> disables Farming mode entirely, however strong you get.<br><br><i>Default: -1</i>",
  "RFarmerRatio": "Farmer's share of your Farmer / Lumberjack / Miner workforce.<br><br><b>AT writes this box.</b> In <b>Auto Worker Ratios</b> mode (the default) AutoTrimps rewrites this box every tick from its own table, so a value you type here is discarded. Switch <b>Buy Jobs</b> to <b>Manual Worker Ratios</b> to set it yourself.<br><br><b>Only the proportions matter.</b> Each is divided by the sum of all three, so <b>1 / 1 / 1</b>, <b>10 / 10 / 10</b> and <b>33 / 33 / 33</b> are the same setting. The live percentage is shown on the button.<br><br><i>Default: 1</i>",
  "RLumberjackRatio": "Lumberjack's share of your Farmer / Lumberjack / Miner workforce.<br><br><b>AT writes this box.</b> In <b>Auto Worker Ratios</b> mode (the default) AutoTrimps rewrites this box every tick from its own table, so a value you type here is discarded. Switch <b>Buy Jobs</b> to <b>Manual Worker Ratios</b> to set it yourself.<br><br><b>Only the proportions matter.</b> Each is divided by the sum of all three, so <b>1 / 1 / 1</b>, <b>10 / 10 / 10</b> and <b>33 / 33 / 33</b> are the same setting. The live percentage is shown on the button.<br><br><i>Default: 1</i>",
  "RManualGather2": "Controls how AT gathers resources and builds in U2 (Radon).<br><br><b>Manual Gather/Build</b> does nothing. <b>Auto Gather/Build</b> and <b>Mining/Building Only</b> both run the same U2 gather logic; Mining/Building Only additionally suppresses the science-gathering branches inside it and defaults to gathering metal instead, rather than switching to a wholly separate loop the way its U1 counterpart does.<br><br><i>Default: Auto Gather/Build</i>",
  "RMaxCollector": "Caps how many Collectors AT will build.<br><br>-1 = no cap.<br><br><i>Default: -1</i>",
  "RMaxExplorers": "Hard ceiling on how many Explorers AutoTrimps will keep.<br><br><b>Cannot:</b> <b>This is a cap, not a target.</b> It can only ever LOWER the count — raising it never hires anyone.<br><br><b>-1</b> = no cap. An exact number caps at that many.<br><br><i>Default: -1</i>",
  "RMaxGateway": "Caps how many Gateways AT will build.<br><br>-1 = no cap.<br><br><i>Default: 25</i>",
  "RMaxHotel": "Caps how many Hotels AT will build.<br><br>-1 = no cap.<br><br><i>Default: 100</i>",
  "RMaxHouse": "Caps how many Houses AT will build.<br><br>-1 = no cap.<br><br><i>Default: 100</i>",
  "RMaxHut": "Caps how many Huts AT will build.<br><br>-1 = no cap.<br><br><i>Default: 100</i>",
  "RMaxLabs": "Caps how many Laboratories AT will build.<br><br><b>Ignored:</b> The <b>Nurture</b> setting (Challenges tab) is off — AT does not build Laboratories at all without it.<br><br>-1 = no cap.<br><br><i>Default: 0</i>",
  "RMaxMansion": "Caps how many Mansions AT will build.<br><br>-1 = no cap.<br><br><i>Default: 100</i>",
  "RMaxMapBonusAfterZone": "Forces AutoTrimps to farm up to your full Map Bonus cap starting at this zone (inclusive), every time you reach it &mdash; the Universe 2 twin of <b>Max MapBonus After</b>.<br><br><b>Ignored:</b> <b>-1</b> disables it entirely.<br><br><b>Cannot:</b> Cannot lower the actual stack target below what the sibling setting <b>Max MapBonus Limit</b> allows &mdash; that is what sets the cap.<br><br><b>0</b> applies it from the very first zone.<br><br><i>Default: -1</i>",
  "RMaxMapBonushealth": "Caps how many extra Map Bonus stacks AutoTrimps will farm purely to raise your health, when health is short &mdash; the Universe 2 twin of <b>Max MapBonus Health</b>.<br><br>Only kicks in below this many stacks, while AutoTrimps isn't already mapping for another reason. Above this many stacks, health-farming stops even if health is still short.<br><br><i>Default: 10</i>",
  "RMaxMapBonuslimit": "Caps how many Map Bonus stacks AutoTrimps will farm for before moving on &mdash; the Universe 2 twin of <b>Max MapBonus Limit</b>.<br><br>Once you reach this many stacks, AutoTrimps stops farming for more and continues the run.<br><br><i>Default: 10</i>",
  "RMaxResort": "Caps how many Resorts AT will build.<br><br>-1 = no cap.<br><br><i>Default: 100</i>",
  "RMaxTribute": "Caps how many Tributes AT will build.<br><br>-1 = no cap. Tributes cost food only.<br><br><i>Default: -1</i>",
  "RMinerRatio": "Miner's share of your Farmer / Lumberjack / Miner workforce.<br><br><b>AT writes this box.</b> In <b>Auto Worker Ratios</b> mode (the default) AutoTrimps rewrites this box every tick from its own table, so a value you type here is discarded. Switch <b>Buy Jobs</b> to <b>Manual Worker Ratios</b> to set it yourself.<br><br><b>Only the proportions matter.</b> Each is divided by the sum of all three, so <b>1 / 1 / 1</b>, <b>10 / 10 / 10</b> and <b>33 / 33 / 33</b> are the same setting. The live percentage is shown on the button.<br><br><i>Default: 1</i>",
  "RRunNewVoidsUntilNew": "Extends void-map clearing to zones past your configured <b>Void Maps</b> zone, so newly obtained void maps don't sit unrun until your next visit there &mdash; the Universe 2 twin of <b>New Voids Mod</b>.<br><br><b>Ignored:</b> <b>0</b> disables the extension &mdash; only the exact Void Maps zone is cleared. Ignored during the Daily challenge.<br><br><b>Cannot:</b> Cannot run new voids below your Void Maps zone, only at or above it.<br><br>A positive number adds that many zones on top of Void Maps. A negative number removes the cap entirely, running new voids at every zone from Void Maps onward. Unlike the Universe 1 twin, there is no Poison-zone restriction here.<br><br><i>Default: 0</i>",
  "RScientistPercent": "What share of your Farmer / Lumberjack / Miner workforce should be Scientists.<br><br><b>Cannot:</b> <b>Unlike Universe 1, this DOES fire Scientists.</b> U2 rebalances all four worker types together, so lowering this below the share you currently have will fire Scientists down to it — and <b>0</b> fires <i>every</i> Scientist you own.<br><br><b>-1</b> = Auto: the built-in share (~4%).<br><b>0</b> = no Scientists at all (existing ones are fired).<br><b>1-90</b> = that percent. The rest is split between Farmer / Lumberjack / Miner by their ratios above.<br><br><i>Control only — this does not make your run faster.</i><br><br><i>Default: -1</i>",
  "RTrapTrimps": "Automatically traps trimps when needed in U2, including building traps.<br><br>If you turn this off, you may as well turn off the game's own Auto-Traps button too — leaving it on with AT's trapping off just lets the game trap for you instead.<br><br><i>Default: On</i>",
  "RVoidMaps": "The zone at which AutoTrimps clears out all of your void maps &mdash; the Universe 2 twin of <b>Void Maps</b>.<br><br><b>Ignored:</b> <b>0</b> disables void-clearing entirely. Ignored during the Daily challenge &mdash; <b>Daily Void Mod</b> controls Daily void zones instead.<br><br><b>Cannot:</b> The Universe 1 Combat setting \\"Only Rush Voids\\" does <b>not</b> affect Universe 2.<br><br>Runs them at cell 70 unless you set <b>Voids Cell</b> below otherwise &mdash; see <b>Voids Cell</b> below to change that. On Lead, use an odd zone.<br><br><b>U2 void rush (#44):</b> to start voids as early as possible, set this to your current zone, set <b>Voids Cell</b> to 1, and set <b>New Voids Mod</b> to -1 (no cap) &mdash; voids then run at cell 1 of every zone from here on.<br><br><i>Default: 0</i>",
  "RadonHourChallenge": "The challenge AT auto-selects for your next U2 run.<br><br><b>Ignored:</b> RAutoPortal is not set to Radon Per Hour or Custom.<br><br><i>Default: None</i>",
  "RadonHrBuffer": "How far your Rn/hr has to drop below your run-best before Radon Per Hour AutoPortal triggers.<br><br><b>Ignored:</b> RAutoPortal is not set to Radon Per Hour.<br><br>E.g. 5 portals once your Rn/hr falls to 95% of your best this run. Includes stuck protection: if you overshoot the buffer by 5x while stuck mid-zone, it portals anyway instead of waiting for cell 1.<br><br><i>Default: 0</i>",
  "Ralchfarmcell": "The cell to wait for before starting Alchemy Farming at the matching zone.<br><br><b>Ignored:</b> Universe 1, outside Alchemy, or while Alchemy is off.<br><br>Edited via the Alchemy Settings popup, not as its own row in the main list.<br><br><i>Default: -1</i>",
  "Ralchfarmfrag": "Farms map fragments instead when AT can't yet afford the map it needs for Alchemy Farming.<br><br><b>Ignored:</b> Universe 1, outside Alchemy, or while Alchemy is off.<br><br><i>Default: Off</i>",
  "Ralchfarmlevel": "How many map levels above the target zone to farm at for Alchemy, e.g. Level 5 at Zone 81 farms +5 maps.<br><br><b>Ignored:</b> Universe 1, outside Alchemy, or while Alchemy is off.<br><br>Edited via the Alchemy Settings popup, not as its own row in the main list.<br><br><i>Default: 0</i>",
  "Ralchfarmmaz": "Opens the Alchemy Farming settings popup: paired rows of zone, cell, potion target, map level and map type.<br><br><b>Ignored:</b> Universe 1, or while Alchemy is off.<br><br>Example: Zone 81, Cell 50, Potion h15, Level 5, Map Farmlands &rarr; farms at zone 81 from cell 50 onward, in a +5 Farmlands map, crafting toward 15 Herby Brews.",
  "Ralchfarmselection": "Which map type to use for Alchemy Farming at the matching zone (e.g. Farmlands for herb yield).<br><br><b>Ignored:</b> Universe 1, outside Alchemy, or while Alchemy is off.<br><br>Edited via the Alchemy Settings popup, not as its own row in the main list.<br><br><i>Default: l</i>",
  "Ralchfarmstack": "The potion and target amount for the matching zone, written as one letter plus a number, e.g. <code>h15</code> for 15 Herby Brews.<br><br><b>Ignored:</b> Universe 1, outside Alchemy, or while Alchemy is off.<br><br>Letters: h = Herby Brew, f = Potion of Finding, g = Gaseous Brew, v = Potion of the Void, s = Potion of Strength. AT crafts that potion automatically whenever your held amount is short of the target. Edited via the Alchemy Settings popup, not as its own row in the main list.<br><br><i>Default: </i>",
  "Ralchfarmzone": "The zone(s) at which AT farms for Alchemy potions.<br><br><b>Ignored:</b> Universe 1, outside Alchemy, or while Alchemy is off.<br><br>Edited via the Alchemy Settings popup, not as its own row in the main list.<br><br><i>Default: -1</i>",
  "Ralchon": "Turns on Alchemy Farming: keeps mapping at a configured zone/cell, crafting the potion set in AF: Potion, until the target amount is reached.<br><br><b>Ignored:</b> Universe 1, outside the Alchemy challenge, or unless at least one zone/potion row is configured via Alchemy Settings.<br><br><i>Default: Off</i>",
  "Rarchon": "Turns on AT's automatic Archaeology relic-buying string, switching which relic string it hands the game's own Archaeology Automator as you cross the zone breakpoints set in First/Second/Third String.<br><br><b>Ignored:</b> Universe 1, or unless First String, Second String AND Third String are all filled in — leaving any one of the three blank means none of them take effect, at any zone.<br><br><b>Cannot:</b> Cannot run on just one or two of the three strings.<br><br>Each string is the game's native automator format (e.g. <code>10a,10e</code> = buy relic 'a' to 10 points, then relic 'e' to 10), prefixed with the zone at which AT should move on to the next string; Third String has no leading zone — it just runs for every zone past Second String's breakpoint.<br><br><i>Default: Off</i>",
  "Rarchstring1": "The Archaeology relic string AT hands the game's automator up to the zone number at its own front, e.g. <code>70,10a,10e</code> switches away once you pass zone 70.<br><br><b>Ignored:</b> Universe 1, Archaeology is off, or Second String / Third String is left blank — all three are required together.<br><br><i>Default: </i>",
  "Rarchstring2": "The Archaeology relic string AT switches to after First String's zone, up to the zone number at its own front, e.g. <code>94,10a,10e</code> switches away once you pass zone 94.<br><br><b>Ignored:</b> Universe 1, Archaeology is off, or First String / Third String is left blank — all three are required together.<br><br><i>Default: </i>",
  "Rarchstring3": "The Archaeology relic string AT uses for every zone past Second String's breakpoint — just the relic string itself, with no leading zone number.<br><br><b>Ignored:</b> Universe 1, Archaeology is off, or First String / Second String is left blank — all three are required together.<br><br><i>Default: </i>",
  "Rautomapsalways": "Continuously forces <b>Auto Maps</b> to plain <b>On</b>, every tick it is not already on.<br><br><b>Cannot:</b> Cannot coexist with <b>Auto Maps No Unique</b> mode &mdash; if you pick No Unique, this setting flips it straight back to plain On.<br><br><i>Default: Off</i>",
  "Rautomapsportal": "Forces <b>Auto Maps</b> to turn <b>On</b> automatically the moment you portal into a fresh Universe 2 (Radon) run, if it is not already on.<br><br><b>Ignored:</b> Only fires once, at the very start of a new Universe 2 run. Does nothing for the rest of that run, and nothing at all in Universe 1.<br><br><b>Cannot:</b> Only ever sets Auto Maps to plain <b>On</b> &mdash; it never selects <b>No Unique</b> mode.<br><br><i>Default: Off</i>",
  "Ravoidempower": "Universe 2 twin of Avoid Empower: predicts whether the next enemy attack, boosted by your current Empower stacks, would wipe your army — and if so, retreats to the map screen just before that happens.<br><br><b>Ignored:</b> Bogged or Plague Dailies, which have their own health handling, or while already mapping.<br><br><i>Default: On</i>",
  "Rbattleradon": "Switches RAutoGoldenUpgrades from Battle back to Radon once this many Battle-pool goldens have been bought this run.<br><br><b>Ignored:</b> Only used when RAutoGoldenUpgrades is set to Battle. -1 disables it.<br><br><i>Default: -1</i>",
  "Rblackbog": "Turns on Black Bog running for the Quagmire challenge: once a zone's remaining Motivated-stack target is below what you still hold, AT queues and runs 'The Black Bog' unique map to burn stacks down.<br><br><b>Ignored:</b> Universe 1, outside the Quagmire challenge, before world 6, or unless Zone and Black Bogs are both set via Quagmire Settings.<br><br>Configure per-zone targets with Quagmire Settings below — for each zone you add, set how many Black Bogs you want run there. Motivated stacks start at 100 and count down as Black Bogs complete.<br><br><i>Default: Off</i>",
  "Rblackbogamount": "How many Black Bogs to run at the matching zone from Zone above, before AT considers that tier done.<br><br><b>Ignored:</b> Universe 1, outside Quagmire, or while Black Bog Running is off.<br><br>AT sums every zone's target up to and including the current one, and keeps running Black Bogs while your remaining Motivated stacks (100 at Quagmire's start) exceed what's left to reach that running total. Edited via the Quagmire Settings popup.<br><br><i>Default: -1</i>",
  "Rblackbogmaz": "Opens the Quagmire settings popup, where Zone and Black Bogs below are edited as paired rows.<br><br><b>Ignored:</b> Universe 1, or while Black Bog Running above is off.<br><br>Zone and Amount are not their own clickable rows in the main list — they only exist inside this popup.",
  "Rblackbogzone": "The zone(s) at which AT should run Black Bog maps for Quagmire — one entry per row.<br><br><b>Ignored:</b> Universe 1, outside Quagmire, or while Black Bog Running is off.<br><br>Edited via the Quagmire Settings popup, not as its own row in the main list.<br><br><i>Default: -1</i>",
  "RcAutoGoldenUpgrades": "The Challenge2 version of the U2 AutoGoldenUpgrades: automatically buys Golden Upgrades while a Challenge2 is running.<br><br><b>Ignored:</b> Only active during a Challenge2.<br><br><b>Cannot:</b> During the Mayhem, Pandemonium, or Desolation Challenge2s, this always buys Battle goldens no matter what you pick here.<br><br>Has no Radon option here &mdash; only Battle, Void, and Void + Battle.<br><br><i>Default: Off</i>",
  "Rcalcfrenzy": "Factors the Frenzy portal perk into AT's Universe 2 damage calc.<br><br><b>Cannot:</b> Will not farm as fast as the calc predicts if your actual Frenzy uptime is below 100%.<br><br>Boosts the calculated damage by 50% per Frenzy level, assuming 100% Frenzy uptime.<br><br><i>Default: Off</i>",
  "Rcalcmaxequality": "Controls whether AT's battle-survival math assumes Equality Scaling is maxed out, instead of using its real configured level.<br><br><b>Equality Calc Off</b> uses your actual Equality Scaling for both your damage and the enemy's incoming damage. <b>EC: On</b> assumes fully-scaled Equality for both sides. <b>EC: Health</b> assumes fully-scaled Equality only for the enemy's incoming damage (may speed up decisions by reading you as safer than you are), leaving your own damage estimate untouched.<br><br><i>Default: Equality Calc Off</i>",
  "Rcarmormagic": "Buys emergency Armor to avoid dying while running the Toxicity or Nom Challenge² in Universe 2, once your health drops to 40% of max.<br><br><b>Ignored:</b> You are not running the Toxicity or Nom Challenge² in Universe 2 — it has no effect anywhere else, including Dailies (use <b>Daily Armor Magic</b> for those).<br><br><b>Above 80%:</b> only once your world zone has reached 80% of your highest zone cleared.<br><b>H:D:</b> only once your H:D ratio (enemy health ÷ your damage) is at or above the cutoff you set in <b>Mapology H:D</b> — i.e. once you genuinely don't have enough damage.<br><b>Always:</b> active for the whole run.<br>All three still wait for the 40% health trigger before buying.<br><br><i>Default: C2 Armor Magic Off</i>",
  "Rchallengehide": "Reveals the eleven per-challenge \\"hide\\" toggles below (Quag, Arch, Mayhem, Storm, Insanity, Exterminate, Nurture, Pandemonium, Alchemy, Hypothermia, Desolation), so a challenge's settings can be tucked out of view once configured.<br><br><b>Ignored:</b> Universe 1 (Helium mode) — the whole Challenges tab is Universe 2 (Radon) only.<br><br>Purely cosmetic — it does not change what any automation does, only what you can see. Turn it off again once you've set the individual hide toggles you want.<br><br><i>Default: Off</i>",
  "Rchallengehidealchemy": "Hides the Alchemy settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehidearch": "Hides the Archaeology settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehidedeso": "Hides the Desolation settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehideexterminate": "Hides the Exterminate settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehidehypothermia": "Hides the Hypothermia settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehideinsanity": "Hides the Insanity settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehidemayhem": "Hides the Mayhem settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehidenurture": "Hides the Nurture setting from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehidepanda": "Hides the Pandemonium settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehidequag": "Hides the Quagmire (Black Bog) settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "Rchallengehidestorm": "Hides the Storm settings from the Challenges tab.<br><br><b>Ignored:</b> Universe 1, or while Hide Stuff above is off (this toggle is itself hidden then).<br><br><i>Default: Off</i>",
  "RdAMPraid": "Master switch for Daily Prestige Raiding in Universe 2: creates Maps with the Prestige option at the zones you configure, to farm prestige gear.<br><br><b>DPR: On</b> uses the Daily-specific zone/raid/cell lists below (edit them via DPR Settings). <b>DPR: Normal</b> reuses your regular (non-Daily) Prestige Raiding settings from the Raiding tab instead. Example: world 95, DPR Zone [95,105], DPR Raid [105,115], DPR Cell 1 — creates Maps 101–105 with Prestige at cell 1; if a Prestige Map can't be afforded it tries without, then falls back to the highest affordable Map. Runs the lowest created Map first, then works up; if DPR: Recycle is on it recycles finished raid Maps afterward.<br><br><i>Default: Daily Praiding Off</i>",
  "RdAMPraidcell": "The cell list for Universe 2 Daily Prestige Raiding, matched by position to DPR: Zone — the cell within each zone at which raiding may begin.<br><br>Edited through the <b>Daily Praiding Settings</b> popup — this row is not shown directly in the settings list. -1 starts at cell 1.<br><br><i>Default: -1</i>",
  "RdAMPraidfrag": "Controls whether Daily Prestige Raiding is willing to farm fragments to afford the Prestige Map options it wants.<br><br><b>DPR: Frag Min</b> farms only the minimum — no Prestige special, perfect sliders, random map, and cheapest difficulty/size — while still trying to afford better options first, prioritizing raiding the most Maps in sequence. <b>DPR: Frag Max</b> farms for the best possible raid, which usually costs more time up front but can save time during the raid itself. Use Min if your heirloom lacks frag-drop/explorer-efficiency bonuses; use Max if you're confident in your fragment income.<br><br><i>Default: DPR: Frag</i>",
  "RdAMPraidmaz": "Opens the Daily Prestige Raiding settings popup, where you configure the zone/raid/cell lists DPR: On uses.<br><br><b>Ignored:</b> Daily Prestige Raiding is off, or set to DPR: Normal.",
  "RdAMPraidraid": "The target-Map list for Universe 2 Daily Prestige Raiding, matched by position to DPR: Zone.<br><br>Edited through the <b>Daily Praiding Settings</b> popup — this row is not shown directly in the settings list. Example: DPR Zone 95,105 with this set to 105,115 raids up to Map 105 from zone 95, and up to 115 from zone 105.<br><br><i>Default: -1</i>",
  "RdAMPraidrecycle": "Recycles the Maps created during Universe 2 Daily Prestige Raiding once the raid finishes.<br><br><b>Ignored:</b> Daily Prestige Raiding (DPR: On) is off or set to DPR: Normal.<br><br><i>Default: Off</i>",
  "RdAMPraidzone": "The zone list for Universe 2 Daily Prestige Raiding — world zones at which raiding is triggered.<br><br>Edited through the <b>Daily Praiding Settings</b> popup — this row is not shown directly in the settings list. Matched by position to DPR: Raid and DPR: Cell.<br><br><i>Default: -1</i>",
  "RdAutoGoldenUpgrades": "The Daily version of the U2 AutoGoldenUpgrades: automatically buys Golden Upgrades while a Daily challenge is active, with the same Radon / Battle / Void / Void + Battle behavior.<br><br><b>Ignored:</b> Only active during a Daily.<br><br>Its own Radon/Battle switch-over and Void fallback zone are <b>Daily Radon Battle</b>, <b>Daily Battle Radon</b>, and <b>Daily Void Battle</b>.<br><br><i>Default: Off</i>",
  "RdCustomAutoPortal": "The zone after which Universe 2's Daily Portal (DP: Custom) portals you out of the Daily.<br><br><b>Ignored:</b> Universe 2's Daily Portal is not set to DP: Custom.<br><br>Example: setting this to 200 portals the moment you first clear level 200 and reach level 201.<br><br><i>Default: 999</i>",
  "RdHeHrDontPortalBefore": "Blocks Universe 2's Rn/Hr Daily AutoPortal from portaling before this level is reached.<br><br><b>Ignored:</b> Universe 2's Daily Portal is not set to DP: Rn/Hr.<br><br>An extra safety check on top of the Rn/Hr buffer, so a normal early-game dip in Radon/Hour doesn't trigger a premature portal. 0 or -1 disables the check.<br><br><i>Default: 999</i>",
  "RdHeliumHourChallenge": "Which challenge to auto-select for your next Universe 2 Daily's Rn/Hr or Custom AutoPortal, once you've cleared every Daily challenge currently available.<br><br>Portals after cell 100 of the zone you specify. Don't pick a challenge you haven't unlocked yet.<br><br><i>Default: None</i>",
  "RdHeliumHrBuffer": "How far your Radon/Hour is allowed to drop below this Daily run's best, before Universe 2's Daily Rn/Hr AutoPortal triggers.<br><br><b>Ignored:</b> Universe 2's Daily Portal is not set to DP: Rn/Hr.<br><br>Example: 5 portals once Rn/Hr falls to 95% of this run's best. Includes stuck protection: if Rn/Hr falls to 5x the buffer below best (e.g. 10% under a 2% buffer), AT will portal mid-zone instead of waiting for cell 1.<br><br><i>Default: 0</i>",
  "RdRunNewVoidsUntilNew": "Lets AT run newly-obtained Void Maps above your Universe 2 Daily Void Zone, during a Daily, by extending how far above that zone it's willing to go.<br><br><b>Cannot:</b> Unlike the Universe 1 twin, there is no Poison-only restriction for this setting — it runs new Voids regardless of Empowerment.<br><br>0 disables it. A positive number adds that many zones on top of Daily Void Zone. -1 removes the cap entirely. A high cap can slow you down badly by chasing Void Maps well above your normal farming zone.<br><br><i>Default: 0</i>",
  "Rdarmormagic": "Universe 2 twin of Daily Armor Magic: buys armor to try to survive Bleed/Plague/Bogged Dailies once your health drops to 40% or less.<br><br><b>Cannot:</b> The third option, <b>DAM: Always</b>, still only buys armor once health is at or below 40% — none of the three modes buy armor pre-emptively.<br><br><b>Above 80%:</b> only active once your world zone is at or above 80% of your highest zone ever cleared. <b>H:D:</b> only active once your H:D ratio is at or above the H:D cutoff set in the Maps tab (i.e. you don't have enough damage). <b>Always:</b> active any time your health is low enough, no zone or H:D gate.<br><br><i>Default: Daily Armor Magic Off</i>",
  "Rdbattleradon": "The Daily version of <b>Battle Radon</b>: switches Daily AutoGoldenUpgrades from Battle back to Radon once this many Battle-pool goldens have been bought in the Daily.<br><br><b>Ignored:</b> Only used during a Daily when Daily AutoGoldenUpgrades is set to Battle. -1 disables it.<br><br><i>Default: -1</i>",
  "RdesoHD": "The Health:Damage ratio target AT farms toward at D: Zone; past that zone the target grows by D: Multiplier per zone.<br><br><b>Ignored:</b> Universe 1, outside Desolation, while Desolation On is off, or unless D: Zone and D: Multiplier are also set.<br><br>Example: D: Zone 100, D: H:D 10, D: Multiplier 1.2 &rarr; the target is 10 at z100, 12 at z101, 14.4 at z102, and so on — so the target keeps pace as enemies get stronger instead of stalling forever at one low ratio.<br><br><i>Default: -1</i>",
  "Rdesomult": "The per-zone growth rate applied to D: H:D past D: Zone (see D: H:D's example).<br><br><b>Ignored:</b> Universe 1, outside Desolation, while Desolation On is off, or unless D: Zone and D: H:D are also set.<br><br><i>Default: -1</i>",
  "Rdesoon": "Turns on Desolation farming: forces mapping once your Health:Damage ratio climbs above a target that grows the deeper you go past D: Zone.<br><br><b>Ignored:</b> Universe 1, outside the Desolation challenge, or unless D: Zone, D: H:D and D: Multiplier are ALL set above their unset value — leaving any one of them unconfigured means Desolation farming never activates.<br><br><b>Cannot:</b> Cannot run with only Zone or only H:D configured — all three must be set together.<br><br><i>Default: Off</i>",
  "Rdesozone": "The zone at which AT starts applying the D: H:D target and D: Multiplier growth for Desolation farming.<br><br><b>Ignored:</b> Universe 1, outside Desolation, while Desolation On is off, or unless D: H:D and D: Multiplier are also set.<br><br><i>Default: -1</i>",
  "Rdfightforever": "Universe 2 twin of DFA: sends your army to fight instead of sitting idle on certain Daily debuffs.<br><br><b>DFA: Non-Empowered</b> only forces fighting on Bogged/Plague/Pressure Dailies that are not also Empowered. <b>DFA: All Dailies</b> forces fighting on any Bogged/Plague/Pressure Daily regardless of Empower. Neither option touches Bloodthirst or Plagued-formation-locked Dailies.<br><br><i>Default: DFA: Off</i>",
  "Rdhs": "Master switch for heirloom swapping during Universe 2 Dailies.<br><br><b>DHS: On</b> uses the Daily-specific shield/staff settings below. <b>DHS: Normal</b> reuses your regular (non-Daily) heirloom-swap settings instead.<br><br><i>Default: DHS: Off</i>",
  "Rdhs1": "The name of the first Shield heirloom to equip during Universe 2 Dailies, used below the zone set in DHSh: Zone.<br><br><i>Default: </i>",
  "Rdhs2": "The name of the second Shield heirloom to equip during Universe 2 Dailies, used at and above the zone set in DHSh: Zone.<br><br><i>Default: </i>",
  "Rdhsmapstaff": "The name of the Staff AT equips while mapping during Universe 2 Dailies.<br><br><b>Ignored:</b> Daily Staffs is off, you're outside a Map, or you're tribute farming with DHSt: Tribute set.<br><br><i>Default: </i>",
  "Rdhsshield": "Turns on Shield swapping (by zone) during Universe 2 Dailies.<br><br><b>Ignored:</b> Daily Heirloom Swapping (Rdhs) is off or set to DHS: Normal.<br><br><i>Default: Off</i>",
  "Rdhsstaff": "Turns on Staff swapping (world/map/tribute) during Universe 2 Dailies.<br><br><b>Ignored:</b> Daily Heirloom Swapping (Rdhs) is off or set to DHS: Normal.<br><br><i>Default: Off</i>",
  "Rdhstributestaff": "The name of the Staff AT equips while tribute farming during Universe 2 Dailies.<br><br><b>Ignored:</b> Daily Staffs is off, or you're not currently tribute farming in a Map.<br><br><i>Default: </i>",
  "Rdhsworldstaff": "The name of the Staff AT equips outside of Maps during Universe 2 Dailies.<br><br><b>Ignored:</b> Daily Staffs is off, or you're currently in a Map.<br><br><i>Default: </i>",
  "Rdhsz": "The zone at which Universe 2 Daily shield swapping switches from your first defined heirloom to your second.<br><br><b>Ignored:</b> Daily Shields is off, or this is 0 or negative (in which case swapping never triggers).<br><br>Example: 75 equips DHSh: First below zone 75 and switches to DHSh: Second at zone 75 and above.<br><br><i>Default: -1</i>",
  "Rdmgcuntoff": "Controls how aggressively AutoEquip levels weapons in U2.<br><br><b>Ignored:</b> AutoEquip (Requipon) is off.<br><br>While your Health:Damage ratio is at or above this value, AT keeps buying weapon levels regardless of the zone and percent overrides below. 1 is the historical default.<br><br><i>Default: 1</i>",
  "Rdradonbattle": "The Daily version of <b>Radon Battle</b>: switches Daily AutoGoldenUpgrades from Radon to Battle once this many goldens have been bought from that pool in the Daily.<br><br><b>Ignored:</b> Only used during a Daily when Daily AutoGoldenUpgrades is set to Radon. -1 disables it.<br><br><i>Default: -1</i>",
  "Rdshrine": "Spends Bone Shrine charges automatically while you are on a Universe 2 Daily.<br><br><b>Daily AutoShrine On</b> uses the Daily zone/cell/amount list — click <b>Daily AutoShrine Settings</b> to edit it.<br><br><b>DAS: Normal</b> uses your ordinary (non-daily) <b>AutoShrine</b> settings instead, so you do not have to configure a second list. Your normal AutoShrine must be switched on for it to do anything.<br><br><i>Default: Daily AutoShrine Off</i>",
  "Rdshrineamount": "The charge-amount list for Universe 2 Daily AutoShrine, matched by position to Daily AutoShrine's zone and cell lists.<br><br>Edited through the <b>Daily AutoShrine Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: -1</i>",
  "Rdshrinecell": "The cell list for Universe 2 Daily AutoShrine, matched by position to Daily AutoShrine's zone and amount lists.<br><br>Edited through the <b>Daily AutoShrine Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: -1</i>",
  "Rdshrinemaz": "Opens the Daily AutoShrine settings popup, where you configure the zone/cell/amount list Daily AutoShrine uses.<br><br><b>Zone:</b> world zone to spend a charge at. <b>Cell:</b> cell within that zone to spend it at — past cell 80 you get the benefit of all Bone Shrine books. <b>Amount:</b> how many charges to spend there. Example: Zone 40, Cell 10, Amount 3 spends 3 charges at zone 40, cell 10, during a Daily.",
  "Rdshrinezone": "The zone list for Universe 2 Daily AutoShrine, matched by position to Daily AutoShrine's cell and amount lists.<br><br>Edited through the <b>Daily AutoShrine Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: -1</i>",
  "Rdtimefarm": "Master switch for Time Farming during Universe 2 Dailies: sends all your workers to gather a chosen resource in a chosen Map for a fixed number of minutes.<br><br><b>DTF: On</b> uses the Daily-specific settings below (edit them via DTM Settings). <b>DTF: Normal</b> reuses your regular (non-Daily) Time Farm settings from the Maps tab instead.<br><br><i>Default: Daily Time Farm Off</i>",
  "Rdtimefarmcell": "The starting-cell list for Universe 2 Daily Time Farm, matched by position to DTF: Zone.<br><br>Edited through the <b>DTM Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: -1</i>",
  "Rdtimefarmgather": "The gathered-resource list for Universe 2 Daily Time Farm, matched by position to DTF: Zone.<br><br>Edited through the <b>DTM Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: </i>",
  "Rdtimefarmlevel": "The +level list for Universe 2 Daily Time Farm — how many levels above the farm zone the Map should be — matched by position to DTF: Zone.<br><br>Edited through the <b>DTM Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: 0</i>",
  "Rdtimefarmmap": "The Map-type list for Universe 2 Daily Time Farm (e.g. Gardens), matched by position to DTF: Zone.<br><br>Edited through the <b>DTM Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: </i>",
  "Rdtimefarmmaz": "Opens the Daily Time Farm settings popup, where you configure the zone/cell/time/level/map/special/gather values DTF: On uses.<br><br><b>Ignored:</b> Daily Time Farm is off, or set to DTF: Normal.<br><br><b>Zone:</b> zone to start time farming. <b>Cell:</b> cell within that zone to start at. <b>Time:</b> minutes to farm. <b>Level:</b> how many +levels above your zone to use. <b>Map:</b> which Map type to farm. <b>Special:</b> which Map special to look for. <b>Gather:</b> which resource to gather. Example: Zone 60, Cell 10, Time 3, Level 5, Map Gardens, Special Large Metal Cache, Gather Metal farms metal for 3 minutes at zone 60/cell 10 in a +5 Gardens map with a Large Metal Cache, during a Daily.",
  "Rdtimefarmspecial": "The Map-special list for Universe 2 Daily Time Farm (e.g. Large Metal Cache), matched by position to DTF: Zone.<br><br>Edited through the <b>DTM Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: </i>",
  "Rdtimefarmtime": "The farm-duration list (in minutes) for Universe 2 Daily Time Farm, matched by position to DTF: Zone.<br><br>Edited through the <b>DTM Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: -1</i>",
  "Rdtimefarmzone": "The zone list for Universe 2 Daily Time Farm, matched by position to the other DTF: lists.<br><br>Edited through the <b>DTM Settings</b> popup — this row is not shown directly in the settings list.<br><br><i>Default: -1</i>",
  "Rdumpgreed": "Redirects <b>Dump into Looting</b> to max out the Greed perk instead of Looting.<br><br><b>Ignored:</b> RAutoAllocatePerks is not set to Dump into Looting.<br><br><i>Default: Off</i>",
  "Rdvoidheliumbattle": "The Daily version of <b>Void Battle</b>: the world zone from which the Void fallback switches from Radon to Battle in Dailies, when Daily AutoGoldenUpgrades is set to Void.<br><br><b>Ignored:</b> Only used during a Daily when Daily AutoGoldenUpgrades is set to Void, and only once the Void pool has run out. -1 disables it.<br><br><i>Default: -1</i>",
  "Requip2": "Always buys level 2 of every U2 weapon and armor piece regardless of efficiency.<br><br><b>Ignored:</b> You are in the Pandemonium challenge.<br><br>Level 2 is disproportionately effective, so this lets AT grab it immediately rather than waiting its turn.<br><br><i>Default: On</i>",
  "Requipamount": "The batch size AT assumes it is about to buy when checking whether leveling gear right now would still leave enough resources for your Smithy reservation.<br><br><b>Ignored:</b> Smithy reservation logic (Rsmithylogic and its number/percent/seconds settings) is not configured — with it off, this setting is never read.<br><br>It does not multiply how many levels AutoEquip buys per pass — that is always bought one level at a time in a loop. This only feeds the affordability check used by Smithy reservation logic.<br><br><i>Default: 1</i>",
  "Requipcapattack": "What level to stop buying weapons at, in U2 AutoEquip.<br><br>Set to 0 or below for no cap.<br><br><i>Default: 50</i>",
  "Requipcaphealth": "What level to stop buying armor at, in U2 AutoEquip.<br><br>Set to 0 or below for no cap.<br><br><i>Default: 50</i>",
  "RequipfarmHD": "The starting H:D target AutoEquip Farm estimates your gear needs against, at <b>AEF: Zone</b>.<br><br><b>Ignored:</b> AE: Farm is off, or AE: Zone / AE: Multiplier is not set above 0.<br><br><i>Default: -1</i>",
  "Requipfarmhits": "How many hits you want it to take to kill an enemy while AutoEquip Farm has selected a farming map.<br><br><b>Ignored:</b> AutoEquip Farm has not triggered farming mode.<br><br><i>Default: -1</i>",
  "Requipfarmmult": "How much the AutoEquip Farm H:D target grows per zone past <b>AEF: Zone</b>.<br><br><b>Ignored:</b> AE: Farm is off, or AE: Zone / AE: H:D is not set above 0.<br><br>E.g. AEF: Zone 100, AEF: H:D 10, AEF: Multiplier 1.2 gives a target of 12 at z101, 14.4 at z102, and so on — scaling the target up so you are not farming for a target that is too low for how strong the zones have gotten.<br><br><i>Default: -1</i>",
  "Requipfarmon": "AutoEquip Farm — estimates the metal needed to reach your gear target and prioritizes farming for it rather than climbing.<br><br>Tries to buy the best map you can afford, but never a plus map — this is intended for use on deep push runs, not regular progression.<br><br><i>Default: Off</i>",
  "Requipfarmzone": "The zone AutoEquip Farm starts checking whether you have enough metal for your gear target.<br><br><b>Ignored:</b> AE: Farm is off, or AE: H:D / AE: Multiplier is not set above 0.<br><br><i>Default: -1</i>",
  "Requipon": "The U2 master switch for AutoEquip: buys Prestiges and levels up equipment automatically.<br><br>Only buys prestiges when it judges them worth it, and levels whichever piece is currently most cost-efficient.<br><br><i>Default: Off</i>",
  "Requippercent": "What percent of your owned wood/metal U2 AutoEquip is allowed to spend on a gear purchase before you reach <b>AE: Zone</b>.<br><br>A purchase is allowed through if its cost is within this percentage of what you currently own, even when your H:D ratio and zone would otherwise hold it back.<br><br><i>Default: 1</i>",
  "Requipzone": "The zone at which U2 AutoEquip stops caring about your H:D ratio or resource percentage, and buys prestiges and equipment as aggressively as it can afford.<br><br><i>Default: -1</i>",
  "Rexterminatecalc": "Sizes your damage and health math against Exterminate's toughest fixed mobs (Mantimp for attack, Beetlimp for health) instead of the normal zone-scaled enemy, so AT does not under-rate the swarm.<br><br><b>Ignored:</b> Universe 1, outside Exterminate, or with the <b>Exterminate</b> master switch off.<br><br><i>Default: Off</i>",
  "Rexterminateeq": "Manages Equality stacking against Exterminate's bug-type mobs (Arachnimp, Beetlimp, Mantimp, Butterflimp): builds Equality up while you lack the challenge's Experienced buff against them, and lets it decay once you have it.<br><br><b>Ignored:</b> Universe 1, outside Exterminate, or while you're inside a map — this only manages Equality on the world map.<br><br><i>Default: Off</i>",
  "Rexterminateon": "Turns on Exterminate-specific automation: the master switch for E: Calc and E: Equality.<br><br><b>Ignored:</b> Universe 1, outside the Exterminate challenge, or with both E: Calc and E: Equality off — it has no effect on its own.<br><br><i>Default: Off</i>",
  "Rfightforever": "Universe 2 twin of Fight Always &mdash; sends your squad out even when Better AutoFight decided not to.<br><br>Set to 0 to always send trimps out when they are not fighting. Set above 0 to only send them when your H:D ratio is at or below this number. -1 turns this off.<br><br><i>Default: -1</i>",
  "Rfrozencastle": "Runs the unique map <b>Frozen Castle</b> at a specific zone and cell.<br><br><b>Ignored:</b> <b>-1</b> disables it. Ignored during the Hypothermia challenge, which uses its own dedicated Frozen Castle settings instead. Requires <b>Auto Maps</b> set to plain \\"On\\" above &mdash; \\"Auto Maps No Unique\\" skips it.<br><br>Enter it as two numbers: zone, then cell &mdash; e.g. <code>200,91</code> runs Frozen Castle at zone 200, cell 91. Both values are required. Works in any challenge, so be careful.<br><br><i>Default: -1</i>",
  "Rhitssurvived": "Sets how many enemy attacks AutoTrimps wants to be able to survive before it considers its health \\"enough\\" &mdash; used for both map-farming decisions and gear-buying decisions in Universe 2.<br><br>The lower this is, the less health AutoTrimps will farm or buy toward. Set it too high and AutoTrimps will over-farm for health, so be careful.<br><br><i>Default: 10</i>",
  "Rhs": "Turns on U2 (Radon) heirloom swapping: a shield that changes at a zone threshold, plus a staff that changes between world fighting, mapping, and tribute farming.<br><br><b>Ignored:</b> During a Daily, this box is only read when <b>Daily Heirloom Swap</b> (Daily tab) is set to <b>DHS: Normal</b> &mdash; any other Daily Heirloom Swap choice uses the separate Daily settings instead and ignores this entirely.<br><br>Configure the shield swap under <b>Shields</b> and the staff swap under <b>Staffs</b>, both below.<br><br><i>Default: Off</i>",
  "Rhs1": "The exact, case-sensitive name of the shield U2 Heirloom Swapping equips before <b>HS: Zone</b> is reached.<br><br><b>Ignored:</b> Only used while Shields is on under Heirloom Swapping and HS: Zone is set above 0.<br><br><i>Default: </i>",
  "Rhs2": "The exact, case-sensitive name of the shield U2 Heirloom Swapping equips at or after <b>HS: Zone</b>.<br><br><b>Ignored:</b> Only used while Shields is on under Heirloom Swapping and HS: Zone is set above 0.<br><br><i>Default: </i>",
  "Rhsmapstaff": "The exact, case-sensitive name of the staff to equip while mapping.<br><br><b>Ignored:</b> Only used while Staffs is on and you are mapping &mdash; and only when you are not tribute farming with a <b>Tribute</b> staff set, which takes over instead. Leave blank to skip.<br><br><i>Default: </i>",
  "Rhsshield": "Turns on the shield half of U2 Heirloom Swapping: one shield below a zone threshold, a different one at or above it.<br><br><b>Ignored:</b> Does nothing unless <b>Heirloom Swapping</b> is on, and does nothing even then unless <b>HS: Zone</b> is set above 0 &mdash; neither shield equips at zone 0 or below.<br><br><i>Default: Off</i>",
  "Rhsstaff": "Turns on the staff half of U2 Heirloom Swapping: a staff for open-world fighting, a different one for mapping, and a third while tribute farming.<br><br><b>Ignored:</b> Does nothing unless <b>Heirloom Swapping</b> is on.<br><br>Set the three staff names under <b>World</b>, <b>Map</b>, and <b>Tribute</b> below.<br><br><i>Default: Off</i>",
  "Rhstributestaff": "The exact, case-sensitive name of the staff to equip while actively tribute farming inside a map.<br><br><b>Ignored:</b> Only used while Staffs is on, you are mapping, and tribute farming is active; otherwise <b>Map</b> (or <b>World</b>) takes over instead. Leave blank to skip.<br><br><i>Default: </i>",
  "Rhsworldstaff": "The exact, case-sensitive name of the staff to equip while out of maps (open-world fighting).<br><br><b>Ignored:</b> Only used while Staffs is on under Heirloom Swapping, and only while you are not currently mapping. Leave blank to skip.<br><br><i>Default: </i>",
  "Rhsz": "The world zone where U2 Heirloom Swapping switches your shield from <b>HS: First</b> to <b>HS: Second</b>.<br><br><b>Cannot:</b> A value of 0 or below does not fall back to always-equipping something &mdash; it disables the shield swap outright, even with Shields turned on.<br><br>Below this zone, HS: First stays equipped; at or above it, HS: Second is equipped instead.<br><br><i>Default: -1</i>",
  "Rhypocastle": "The zone at which AT starts running the 'Frozen Castle' unique map to help complete Hypothermia.<br><br><b>Ignored:</b> Universe 1, outside Hypothermia, or set to 0 or below — Frozen Castle is only ever selected once this is above 0.<br><br>Interacts with After Voids below — whether Frozen Castle waits for voids to finish first depends on that setting.<br><br><i>Default: -1</i>",
  "Rhypofarmcell": "The cell to wait for before starting Hypothermia Farming at the matching zone.<br><br><b>Ignored:</b> Universe 1, outside Hypothermia, or while Hypothermia is off.<br><br>Edited via the Hypothermia Settings popup, not as its own row in the main list.<br><br><i>Default: -1</i>",
  "Rhypofarmfrag": "Farms map fragments instead when AT can't yet afford the map it needs for Hypothermia Farming.<br><br><b>Ignored:</b> Universe 1, outside Hypothermia, or while Hypothermia is off.<br><br><i>Default: Off</i>",
  "Rhypofarmlevel": "How many map levels above the target zone to farm at for Hypothermia, e.g. Level 5 at Zone 17 farms +5 maps.<br><br><b>Ignored:</b> Universe 1, outside Hypothermia, or while Hypothermia is off.<br><br>Edited via the Hypothermia Settings popup, not as its own row in the main list.<br><br><i>Default: 0</i>",
  "Rhypofarmmaz": "Opens the Hypothermia Farming settings popup: paired rows of zone, cell, bonfire target and map level.<br><br><b>Ignored:</b> Universe 1, or while Hypothermia is off.<br><br>Example: Zone 17, Cell 50, Bonfire 5, Level 5 &rarr; farms at zone 17 from cell 50 onward, in a +5 map, until you hold 5 total Bonfires.",
  "Rhypofarmstack": "The total-Bonfire target for the matching zone: AT keeps holding back wood and crafting Bonfires until you've banked this many overall.<br><br><b>Ignored:</b> Universe 1, outside Hypothermia, or while Hypothermia is off.<br><br>Edited via the Hypothermia Settings popup, not as its own row in the main list.<br><br><i>Default: -1</i>",
  "Rhypofarmzone": "The zone(s) at which AT farms Bonfires for Hypothermia.<br><br><b>Ignored:</b> Universe 1, outside Hypothermia, or while Hypothermia is off.<br><br>Also used by HF: Storage above, which reads its final entry as the last zone Storage should hold wood back on. Edited via the Hypothermia Settings popup, not as its own row in the main list.<br><br><i>Default: -1</i>",
  "Rhypoon": "Turns on Hypothermia Farming: keeps mapping at a configured zone/cell, crafting Bonfires until the total set in HF: Bonfire is reached.<br><br><b>Ignored:</b> Universe 1, outside the Hypothermia challenge, or unless at least one zone/bonfire row is configured via Hypothermia Settings.<br><br><i>Default: Off</i>",
  "Rhypostorage": "Holds back on building Sheds during Hypothermia unless the extra wood capacity is needed to hit HF: Bonfire's price target, and disables AutoStorage until you reach the last configured Hypothermia Farming zone.<br><br><b>Ignored:</b> Universe 1, outside Hypothermia, or unless AT's own U2 AutoBuildings (the RBuyBuildingsNew setting) is on — this logic only runs inside that routine, so relying on the game's vanilla auto-building makes it a no-op.<br><br>Trades away some Smithy/Shield-prestige wood spending in exchange for not accidentally overshooting your Bonfire count.<br><br><i>Default: Off</i>",
  "Rhypovoids": "When on, holds off running Frozen Castle (from Frozen Castle Zone above) until every void map for the portal has been cleared; when off, runs it as soon as the zone is reached, voids or not.<br><br><i>Default: On</i>",
  "Rinsanityfarmcell": "The cell to wait for before starting Insanity Farming at the matching zone.<br><br><b>Ignored:</b> Universe 1, outside Insanity, or while Insanity is off.<br><br>Edited via the Insanity Settings popup, not as its own row in the main list. Leaving a row's cell unset starts it from cell 1.<br><br><i>Default: -1</i>",
  "Rinsanityfarmfrag": "Farms map fragments instead when AT can't yet afford the map it needs for Insanity Farming.<br><br><b>Ignored:</b> Universe 1, outside Insanity, or while Insanity is off.<br><br><i>Default: Off</i>",
  "Rinsanityfarmlevel": "How many map levels above the target zone to farm at for Insanity, e.g. Level 5 at Zone 60 farms +5 maps.<br><br><b>Ignored:</b> Universe 1, outside Insanity, or while Insanity is off.<br><br>Edited via the Insanity Settings popup, not as its own row in the main list.<br><br><i>Default: 0</i>",
  "Rinsanityfarmstack": "The Insanity stack target for the matching zone: AT keeps mapping there until you hold this many stacks (capped at the challenge's own maximum).<br><br><b>Ignored:</b> Universe 1, outside Insanity, or while Insanity is off.<br><br>Edited via the Insanity Settings popup, not as its own row in the main list.<br><br><i>Default: -1</i>",
  "Rinsanityfarmzone": "The zone(s) at which AT farms for Insanity stacks — one row per target.<br><br><b>Ignored:</b> Universe 1, outside Insanity, or while Insanity is off.<br><br>Edited via the Insanity Settings popup, not as its own row in the main list.<br><br><i>Default: -1</i>",
  "Rinsanitymaz": "Opens the Insanity Farming settings popup: paired rows of zone, cell, stack target and map level.<br><br><b>Ignored:</b> Universe 1, or while Insanity is off.<br><br>Example: Zone 60, Cell 50, Stacks 500, Level 5 &rarr; farms at zone 60 from cell 50 onward, in a +5 map, until you hold 500 Insanity stacks.",
  "Rinsanityon": "Turns on Insanity Farming: keeps mapping at a configured zone/cell until you've reached the Insanity stack target set for it.<br><br><b>Ignored:</b> Universe 1, outside the Insanity challenge, or unless at least one zone/stack pair is configured via Insanity Settings.<br><br><i>Default: Off</i>",
  "Rmanageequality": "Turns Equality Scaling on or off for you automatically based on the current enemy.<br><br>Turns scaling ON (letting your Equality stacks build) against fast enemies, the Glass challenge, void double-attack, Desolation maps, or a mutated cell. Otherwise turns scaling OFF and resets your Equality stacks to 0.<br><br><i>Default: Off</i>",
  "Rmapcuntoff": "Sets the Health:Damage ratio AutoTrimps uses to decide whether it has \\"enough damage\\" to stop mapping and push forward &mdash; the Universe 2 twin of <b>Map Cut Off</b>.<br><br>AutoTrimps expects to one-shot an enemy while your Health:Damage ratio stays at or below this number. Raise it to demand a bigger damage margin (more mapping); lower it to accept a thinner margin (less mapping).<br><br><i>Default: 1</i>",
  "Rmapselection": "Picks which biome AutoTrimps requests when it creates a new map &mdash; the Universe 2 twin of <b>Map Selection</b>.<br><br><b>Ignored:</b> Ignored while AutoTrimps is farming, or during the Transmute challenge &mdash; biome is forced to Plentiful instead, regardless of this setting.<br><br><i>Default: Mountain</i>",
  "Rmayhemabcut": "The hits-to-kill threshold M: Attack watches: mapping is forced once killing the world boss would take more than this many average hits.<br><br>A value of 0 or below falls back to a threshold of 100 hits.<br><br><i>Default: -1</i>",
  "Rmayhemamcut": "The hits-to-kill threshold M: Smart Map uses when sizing a plus-map: it looks for the highest +1..+6 map you can clear within this many hits per cell.<br><br><b>Ignored:</b> Only read when M: Maps is set to M: Smart Map.<br><br>A value of 0 or below falls back to a threshold of 100 hits.<br><br><i>Default: -1</i>",
  "Rmayhemattack": "Forces mapping when your Health:Damage ratio climbs above M: Attack Boss's cut-off — i.e. when it would take too many average hits to kill the current world boss.<br><br><b>Ignored:</b> Universe 1, outside Mayhem, while Mayhem On is off, or once the zone's Mayhem stacks have already been cleared to 0.<br><br><i>Default: Off</i>",
  "Rmayhemhcut": "The survival multiplier M: Health and M: Smart Map both use: your effective health must cover this many worst-case enemy hits.<br><br>A value of 0 or below falls back to a multiplier of 1 hit.<br><br><i>Default: -1</i>",
  "Rmayhemhealth": "Forces mapping when your effective health drops below M: Health Cut-off's multiple of the worst hit you'd take — i.e. when survival is getting tight.<br><br><b>Ignored:</b> Universe 1, outside Mayhem, while Mayhem On is off, or once the zone's Mayhem stacks have already been cleared to 0.<br><br><i>Default: Off</i>",
  "Rmayhemmap": "Chooses how AT picks a map once Mayhem forces mapping.<br><br><b>Ignored:</b> Universe 1, outside Mayhem, or while Mayhem On is off.<br><br><b>M: Highest Map</b> always grabs the highest-level map you own, from any source (Praiding, Time Farming, manually created). <b>M: Smart Map</b> calculates the strongest +1..+6 map you can both survive and clear within M: Attack Map / M: Health Cut-off, buying attributes like Fast Attack as needed.<br><br><i>Default: M: Maps Off</i>",
  "Rmayhemon": "Turns on Mayhem automation: lets M: Attack and/or M: Health override your normal farm settings and force mapping when the challenge gets dangerous.<br><br><b>Ignored:</b> Universe 1, outside the Mayhem challenge, or when both M: Attack and M: Health are off below — Mayhem On alone does nothing.<br><br><i>Default: Off</i>",
  "Rmeltpoint": "Runs the unique map <b>Melting Point</b> at a specific zone and cell.<br><br><b>Ignored:</b> <b>-1</b> disables it. Requires <b>Auto Maps</b> set to plain \\"On\\" above &mdash; \\"Auto Maps No Unique\\" skips it.<br><br>Enter it as two numbers: zone, then cell &mdash; e.g. <code>50,91</code> runs Melting Point at zone 50, cell 91. Both values are required. Works during the Melt and Trappapalooza challenges, and separately once you own enough Smithies via the Smithy Farm settings.<br><br><i>Default: -1</i>",
  "Rmeltsmithy": "Lets AT re-run the Melting Point map once you own at least this many Smithies, to farm one extra free Smithy.<br><br>-1 disables it. Only applies once the Melting Point map's free-Smithy reward is available to run again.<br><br><i>Default: -1</i>",
  "Rmutecalc": "The zone at which AT switches to a mutation-aware combat calc in Universe 2.<br><br>Only takes effect past z200, and only once your zone reaches this value. Use 0 to disable.<br><br><i>Default: -1</i>",
  "RnHrDontPortalBefore": "Blocks the Radon Per Hour AutoPortal from firing before this zone is reached, even if your Rn/hr has already dropped.<br><br><b>Ignored:</b> RAutoPortal is not set to Radon Per Hour.<br><br>Set to 0 or -1 to remove the check entirely.<br><br><i>Default: 999</i>",
  "Rnurtureon": "Lets AT auto-build Laboratories during the Nurture challenge (Laboratory only exists as a buildable building while Nurture is active).<br><br><b>Ignored:</b> Universe 1, or outside the Nurture challenge — Laboratory is locked away again the moment the challenge ends.<br><br>Each Laboratory raises Cruffys' (Scruffy's brother) experience gain, at the cost of tougher enemies. Still respects Max Labs if one is set.<br><br><i>Default: Off</i>",
  "Rpandahits": "The average-hits-to-kill ceiling P: Mapping sizes its plus-map against; it tries +6 down to +1, picking the highest level that still clears within this many hits, and runs a +1 map anyway if nothing fits.<br><br>A value of 0 or below falls back to a threshold of 10 hits.<br><br><i>Default: -1</i>",
  "Rpandamaps": "Automates mapping for Pandemonium: sizes a +1..+6 plus-map you can clear within P: Hits average hits per cell, and runs it.<br><br><b>Ignored:</b> Universe 1, outside Pandemonium, while Pandemonium On is off, before P: Zone, or while the challenge's own Pandemonium stacks are at 0.<br><br><i>Default: Off</i>",
  "Rpandaon": "Turns on Pandemonium automation, gated by P: Zone below.<br><br><b>Ignored:</b> Universe 1, outside the Pandemonium challenge, or before reaching P: Zone.<br><br><i>Default: Off</i>",
  "Rpandazone": "The zone Pandemonium mapping starts at — stacks accrued below this zone are ignored entirely.<br><br><b>Ignored:</b> Universe 1, outside Pandemonium, or while Pandemonium On is off.<br><br><i>Default: -1</i>",
  "Rprispalace": "Runs the unique map <b>Prismatic Palace</b> once it unlocks, to claim its Prismalicious reward.<br><br><b>Ignored:</b> Requires <b>Auto Maps</b> set to plain \\"On\\" above &mdash; \\"Auto Maps No Unique\\" skips it.<br><br>Only runs once you have reached zone 21, and only while your Health:Damage ratio is 25 or better (not too far behind).<br><br><i>Default: On</i>",
  "Rradonbattle": "Switches RAutoGoldenUpgrades from Radon to Battle once this many goldens have been bought from that pool this run.<br><br><b>Ignored:</b> Only used when RAutoGoldenUpgrades is set to Radon. -1 disables it.<br><br><i>Default: -1</i>",
  "Rshipfarmamount": "How many Worshippers to farm up to at each SF zone, paired position-by-position with <b>SF: Zone</b>.<br><br>Example: zones <b>59, 61</b> with amounts <b>50, 45</b> farms z59 up to 50 Worshippers, then z61 up to 45.<br><br><i>Default: -1</i>",
  "Rshipfarmcell": "Cell to start Ship Farming at, once you reach an SF zone.<br><br><b>-1</b> starts at cell 1.<br><br><i>Default: -1</i>",
  "Rshipfarmfrag": "Farms fragments first if you can't afford the map Ship Farming wants.<br><br><b>Cannot:</b> Without this, Ship Farming can get stuck trying to create a map it can never afford, forever.<br><br><i>Default: Off</i>",
  "Rshipfarmlevel": "Map level to Ship Farm at, paired position-by-position with <b>SF: Zone</b>.<br><br><b>-1</b> = one level below world (matches the Map Reducer mastery's loot-equivalent zone). <b>0</b> = world level. Any other number = world plus that many levels.<br><br>Setting the whole list to a single <b>0</b> uses world level for every SF zone.<br><br><i>Default: 0</i>",
  "Rshipfarmon": "Turns Ship Farming on: parks AT on Worshipper-farming maps at the zones you set below instead of normal map farming.<br><br><b>Cannot:</b> Requires <b>Large Savory Cache</b> unlocked. Use Time Farm instead if you don't have it yet.<br><br><i>Default: Off</i>",
  "Rshipfarmzone": "Which zones to Ship Farm at, paired position-by-position with <b>SF: Amount</b> below.<br><br>Example: <b>59, 61, 62</b> Ship Farms at those three zones in turn, each stopping once its own SF: Amount target is reached.<br><br><i>Default: -1</i>",
  "Rshowautomapstatus": "Shows a live status line describing what AutoMap is currently doing in Universe 2 (Radon), updated every tick.<br><br>Turning it off skips that per-tick update and hides the status line.<br><br><i>Default: On</i>",
  "Rshrine": "Turns on automatic Bone Shrine charge use at the zone(s), cell(s), and amount(s) you configure in <b>AutoShrine Settings</b> below &mdash; the Universe 2 twin of <b>AutoShrine</b>.<br><br><b>Cannot:</b> Requires Bone Shrine charges to actually be available, and is a separate mechanism from <b>Auto Bone Charge Max</b> elsewhere &mdash; the two do not interact.<br><br><i>Default: Off</i>",
  "Rshrineamount": "The list of charge counts (one per zone) AutoShrine spends &mdash; the raw storage behind the <b>AutoShrine Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length, in the same order, as its <b>Zone</b> and <b>Cell</b> siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rshrinecell": "The list of cells (one per zone) AutoShrine waits for before spending charges &mdash; the raw storage behind the <b>AutoShrine Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length, in the same order, as its <b>Zone</b> and <b>Amount</b> siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rshrinecharge": "Internal bookkeeping AutoTrimps uses to track how many Bone Shrine charges it has already spent at the current zone.<br><br><b>Cannot:</b> Not meant to be edited by hand &mdash; it resets to 0 automatically every time you enter a new zone.<br><br><i>Default: 0</i>",
  "Rshrinemaz": "Opens the AutoShrine editor: pick the zone, cell, and how many Bone Shrine charges to spend there.<br><br><b>Cannot:</b> The charge count resets every time you enter a new zone, so <b>Amount</b> means \\"how many to use at this zone\\", not a lifetime total.<br><br>Example: Zone 40, Cell 10, Amount 3 uses 3 Bone Shrine charges the first time you reach cell 10 of zone 40. Using it after cell 80 gets the benefit of all the books.",
  "Rshrinezone": "The list of zones AutoShrine triggers at &mdash; the raw storage behind the <b>AutoShrine Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length, in the same order, as its <b>Cell</b> and <b>Amount</b> siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rsmithyfarm": "Turns on Smithy Farming: parks AutoTrimps at a configured zone and cell until it has built a target number of Smithies.<br><br>Configure the zone, cell, and Smithy count in <b>Smithy Farm Settings</b> below.<br><br><i>Default: Off</i>",
  "Rsmithyfarmamount": "The list of Smithy-count targets, one per zone, Smithy Farming builds to &mdash; the raw storage behind the <b>Smithy Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rsmithyfarmcell": "The list of cells, one per zone, Smithy Farming waits for before it starts &mdash; the raw storage behind the <b>Smithy Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Smithys siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rsmithyfarmmaz": "Opens the Smithy Farm editor: pick the zone, cell, and how many Smithies to build there.<br><br>AutoTrimps generates a map that fills your resource needs and assigns gathering/jobs appropriately. Example: Zone 60, Cell 10, Smithys 2 farms at zone 60, cell 10, for a total of 2 Smithies.",
  "Rsmithyfarmzone": "The list of zones Smithy Farming triggers at &mdash; the raw storage behind the <b>Smithy Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Cell/Smithys siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rsmithylogic": "Smithy Savings — withholds a purchase when it's both small relative to your next Smithy's price and that Smithy is close to affordable, so resources pile up toward the Smithy instead.<br><br><b>Cannot:</b> Only affects <b>weapon and armor purchases</b> in practice. The underlying logic has branches for buildings too (Huts, Houses, Gateways...), but nothing in AT currently calls it for a building purchase, so those branches never run.<br><br>Requires <b>SS: Number</b>, <b>SS: Percent</b>, and <b>SS: Seconds</b> to all be set above 0 to activate at all.<br><br><i>Default: Off</i>",
  "Rsmithynumber": "Smithy Savings only starts withholding purchases once you own at least this many Smithies — below it, every purchase goes through as normal.<br><br>Example: set to 9 and AT buys freely until your 9th Smithy, then starts saving for the 10th.<br><br><i>Default: -1</i>",
  "Rsmithypercent": "Smithy Savings only withholds a purchase if it costs more than this percent of your next Smithy's price, in whichever resource the purchase shares with the Smithy.<br><br>Example: 1 means only purchases costing 1% or less of the Smithy's price are still allowed through once Smithy Savings is active.<br><br><i>Default: -1</i>",
  "Rsmithyseconds": "How close (in seconds, at your current income) you need to be to affording your next Smithy before Smithy Savings starts withholding other purchases.<br><br>Example: 120 means Smithy Savings only kicks in once your Smithy is 120 seconds away from being affordable in wood, metal, or gems.<br><br><i>Default: -1</i>",
  "RstormHD": "The Health:Damage ratio target AT farms toward at S: Zone; past that zone the target grows by S: Multiplier per zone.<br><br><b>Ignored:</b> Universe 1, outside Storm, while Storm On is off, or unless S: Zone and S: Multiplier are also set.<br><br>Example: S: Zone 100, S: H:D 10, S: Multiplier 1.2 &rarr; the target is 10 at z100, 12 at z101, 14.4 at z102, and so on — so the target keeps pace as enemies get stronger instead of stalling forever at one low ratio.<br><br><i>Default: -1</i>",
  "Rstormmult": "The per-zone growth rate applied to S: H:D past S: Zone (see S: H:D's example).<br><br><b>Ignored:</b> Universe 1, outside Storm, while Storm On is off, or unless S: Zone and S: H:D are also set.<br><br><i>Default: -1</i>",
  "Rstormon": "Turns on Storm farming: forces mapping once your Health:Damage ratio climbs above a target that grows the deeper you go past S: Zone.<br><br><b>Ignored:</b> Universe 1, outside the Storm challenge, or unless S: Zone, S: H:D and S: Multiplier are ALL set above their unset value — leaving any one of them unconfigured means Storm farming never activates.<br><br><b>Cannot:</b> Cannot run with only Zone or only H:D configured — all three must be set together.<br><br><i>Default: Off</i>",
  "Rstormzone": "The zone at which AT starts applying the S: H:D target and S: Multiplier growth for Storm farming.<br><br><b>Ignored:</b> Universe 1, outside Storm, while Storm On is off, or unless S: H:D and S: Multiplier are also set.<br><br><i>Default: -1</i>",
  "Rtimefarm": "Turns on Time Farming: parks AutoTrimps at a configured zone and cell for a set number of minutes, gathering a chosen resource, before it continues.<br><br>Configure the zone, cell, duration, and what to gather in <b>Time Farm Settings</b> below.<br><br><i>Default: Off</i>",
  "Rtimefarmcell": "The list of cells (one per zone) Time Farming waits for before it starts &mdash; the raw storage behind the <b>Time Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Time/Level/Map/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rtimefarmgather": "The list of resources, one per zone, Time Farming puts all your workers on &mdash; the raw storage behind the <b>Time Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Time/Level/Map/Special siblings, or the pairing breaks.<br><br><i>Default: </i>",
  "Rtimefarmlevel": "The list of map-level offsets, one per zone, Time Farming uses above your current zone &mdash; the raw storage behind the <b>Time Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Time/Map/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: 0</i>",
  "Rtimefarmmap": "The list of map biomes, one per zone, Time Farming creates &mdash; the raw storage behind the <b>Time Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Time/Level/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: </i>",
  "Rtimefarmmaz": "Opens the Time Farm editor: pick the zone, cell, duration, map, special, and resource to gather.<br><br>It also puts all your workers into gathering the chosen resource. Example: Zone 60, Cell 10, Time 3, Level 5, Map Gardens, Special Large Metal Cache, Gather Metal farms at zone 60, cell 10, for 3 minutes in a +5 Gardens map with a Large Metal Cache, gathering metal.",
  "Rtimefarmspecial": "The list of map special modifiers, one per zone, Time Farming requests &mdash; the raw storage behind the <b>Time Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Time/Level/Map/Gather siblings, or the pairing breaks.<br><br><i>Default: </i>",
  "Rtimefarmtime": "The list of durations, in minutes, one per zone, Time Farming runs for &mdash; the raw storage behind the <b>Time Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Level/Map/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rtimefarmzone": "The list of zones Time Farming triggers at &mdash; the raw storage behind the <b>Time Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length, in the same order, as its Cell/Time/Level/Map/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rtributefarm": "Turns on Tribute Farming: parks AutoTrimps at a configured zone and cell until it has gathered a target number of tributes.<br><br>Configure the zone, cell, tribute count, and what to gather in <b>Tribute Farm Settings</b> below.<br><br><i>Default: Off</i>",
  "Rtributefarmamount": "The list of tribute-count targets, one per zone, Tribute Farming gathers to &mdash; the raw storage behind the <b>Tribute Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Level/Map/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rtributefarmcell": "The list of cells, one per zone, Tribute Farming waits for before it starts &mdash; the raw storage behind the <b>Tribute Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Tributes/Level/Map/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rtributefarmlevel": "The list of map-level offsets, one per zone, Tribute Farming uses above your current zone &mdash; the raw storage behind the <b>Tribute Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Tributes/Map/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: 0</i>",
  "Rtributefarmmaz": "Opens the Tribute Farm editor: pick the zone, cell, tribute target, map, special, and resource to gather.<br><br>It also puts all your workers into gathering the chosen resource. Example: Zone 40, Cell 10, Tributes 1000, Level 5, Map Gardens, Special Large Savory Cache, Gather Food farms at zone 40, cell 10, for 1000 tributes in a +5 Gardens map with a Large Savory Cache, gathering food.",
  "Rtributefarmzone": "The list of zones Tribute Farming triggers at &mdash; the raw storage behind the <b>Tribute Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Cell/Tributes/Level/Map/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: -1</i>",
  "Rtributegatherselection": "The list of resources, one per zone, Tribute Farming puts all your workers on &mdash; the raw storage behind the <b>Tribute Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Tributes/Level/Map/Special siblings, or the pairing breaks.<br><br><i>Default: </i>",
  "Rtributemapselection": "The list of map biomes, one per zone, Tribute Farming creates &mdash; the raw storage behind the <b>Tribute Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Tributes/Level/Special/Gather siblings, or the pairing breaks.<br><br><i>Default: </i>",
  "Rtributespecialselection": "The list of map special modifiers, one per zone, Tribute Farming requests &mdash; the raw storage behind the <b>Tribute Farm Settings</b> popup above.<br><br><b>Cannot:</b> Edit through the popup rather than typing here directly. This array must stay the same length and order as its Zone/Cell/Tributes/Level/Map/Gather siblings, or the pairing breaks.<br><br><i>Default: </i>",
  "RunNewVoidsUntilNew": "Extends void-map clearing to zones past your configured <b>Void Maps</b> zone, so newly obtained void maps don't sit unrun until your next visit there.<br><br><b>Ignored:</b> <b>0</b> disables the extension &mdash; only the exact Void Maps zone is cleared. Ignored during the Daily challenge, which has its own equivalent setting.<br><br><b>Cannot:</b> Cannot run new voids below your Void Maps zone, only at or above it.<br><br>A positive number adds that many zones on top of Void Maps &mdash; e.g. Void Maps=187 and this=10 runs new voids through z197. A negative number removes the cap entirely, running new voids at every zone from Void Maps onward. See <b>New Voids Poison</b> below to restrict this extension to Poison-empowered zones only.<br><br><i>Default: 0</i>",
  "Rvoidheliumbattle": "The world zone from which the Void fallback switches from Radon to Battle, when RAutoGoldenUpgrades is set to Void.<br><br><b>Ignored:</b> Only used when RAutoGoldenUpgrades is set to Void, and only once the Void pool has run out. -1 disables it.<br><br>Below this zone, running out of Void upgrades falls back to Radon; at or above it, it falls back to Battle instead.<br><br><i>Default: -1</i>",
  "Rvoidscell": "The cell within the <b>Void Maps</b> zone at which AutoTrimps starts clearing void maps &mdash; the Universe 2 twin of <b>Voids Cell</b>.<br><br><b>-1</b> falls back to cell 70.<br><br><i>Default: -1</i>",
  "ScientistPercent": "What share of your Farmer / Lumberjack / Miner workforce should be Scientists.<br><br><b>Cannot:</b> <b>Only ADD scientists, never remove them.</b> In Universe 1 AutoTrimps never fires a Scientist, so a value BELOW the count you already have does nothing at all. (Auto gives ~9% until you have 100 Farmers — so setting 5% early looks like it did nothing. It did: you already had more.)<br><br><b>-1</b> = Auto: the built-in table (~4% normally, ~9% before 100 Farmers, ~1% past zone 300).<br><b>0</b> = hire no more Scientists; the ones you have stay.<br><b>1-90</b> = that percent. The rest is split between Farmer / Lumberjack / Miner by their ratios above.<br><br><i>Control only — this does not make your run faster.</i><br><br><i>Default: -1</i>",
  "ScryUseinIce": "Scryer behavior while under Ice Empowerment.<br><br><b>-1</b>: no special rule; falls through to the rest of the Scryer logic. <b>0</b>: never Scry under Ice. <b>Above 0</b>: forces Scry under Ice until you reach this zone, then treats it as Never past that point.<br><br><i>Default: -1</i>",
  "ScryUseinPoison": "Scryer behavior while under Poison Empowerment.<br><br><b>-1</b>: no special rule; falls through to the rest of the Scryer logic. <b>0</b>: never Scry under Poison. <b>Above 0</b>: forces Scry under Poison until you reach this zone, then treats it as Never past that point.<br><br><i>Default: -1</i>",
  "ScryUseinWind": "Scryer behavior while under Wind Empowerment.<br><br><b>-1</b>: no special rule; falls through to the rest of the Scryer logic. <b>0</b>: never Scry under Wind. <b>Above 0</b>: forces Scry under Wind until you reach this zone, then treats it as Never past that point.<br><br><i>Default: -1</i>",
  "ScryerDieZ": "Lets AT switch to Scryer even when doing so would kill you.<br><br><b>Cannot:</b> This can genuinely get your squad killed on purpose &mdash; use at your own risk.<br><br>Meant for when Skip Corrupteds pushed you into a regular X/H stance, the corrupted enemy died, and you would rather die and rebreed than miss Scryer on the next (non-corrupted) enemy for Dark Essence. -1 disables this. The value is the minimum zone this applies from &mdash; use a decimal to target a specific cell (e.g. 230.60 = zone 230, cell 60).<br><br><i>Default: 230.6</i>",
  "ScryerMaxZone": "The zone Scryer stops being allowed to run in via the Min/Max fallback.<br><br>Not inclusive; ignored by Overkill. 0 or -1 disables the cap.<br><br><i>Default: 230</i>",
  "ScryerMinZone": "The zone Scryer starts being allowed to run in, once none of the Never/Force rules above have already decided.<br><br>Inclusive; ignored by Overkill and by any Force rule. Needs to be set (and reachable) for the Maybe option on the other Scryer settings to matter. Set to 9999 to effectively disable this fallback.<br><br><i>Default: 181</i>",
  "ScryerSkipBoss2": "Scryer behavior on the world-boss cell (cell 98).<br><br><b>Boss: NEVER (All Levels)</b> blocks Scryer on cell 98 at every zone. <b>Boss: NEVER (Above VoidLevel)</b> only blocks it while your zone is below the zone set in <b>Void Maps</b> (Maps tab); once you reach that zone, the block turns off despite the option's name. <b>MAYBE</b> treats cell 98 like any other cell.<br><br><i>Default: Boss: NEVER (All Levels)</i>",
  "ScryerSkipCorrupteds2": "Scryer behavior against Corrupted-mutation enemies.<br><br><b>Cannot:</b> Only checked outside Maps. Inside a map, whether Scryer fires against a Corrupted enemy is decided by the Maps/Void/BW/Spire Force settings above, not by this one.<br><br><b>NEVER</b> blocks Scryer against Corrupted enemies. <b>FORCE</b> always switches to Scryer against them. <b>MAYBE</b> lets the rest of the rules decide. Magma-map enemies and some Void maps carry the Corrupted mutation, so this can matter there too.<br><br><i>Default: Corrupted: MAYBE</i>",
  "ScryerSkipHealthy": "Scryer behavior against Healthy-mutation enemies.<br><br><b>NEVER</b> blocks Scryer against Healthy enemies. <b>FORCE</b> always switches to Scryer against them. <b>MAYBE</b> lets the rest of the rules decide. Corrupted Void maps are classified as Healthy for this check.<br><br><i>Default: Healthy: MAYBE</i>",
  "ScryerUseWhenOverkill": "Switches to Scryer whenever doing so secures a free overkill, for double loot with no speed penalty.<br><br>Overrides every other Scryer rule except Never-in-Spire. If you only want Scryer during overkills, turn this on, set Min Zone to 9999, and turn everything else off.<br><br><i>Default: On</i>",
  "ScryerUseinBW": "Scryer behavior in Bionic War maps.<br><br><b>NEVER</b> blocks Scryer in BW maps. <b>FORCE</b> always switches to Scryer in them. <b>MAYBE</b> lets Overkill and the Min/Max Zone fallback decide.<br><br><i>Default: BW: NEVER</i>",
  "ScryerUseinMaps2": "Scryer behavior while you are in a regular map (not Void, not Bionic, not above your zone).<br><br><b>NEVER</b> blocks Scryer in these maps outright. <b>FORCE</b> always switches to Scryer in them. <b>MAYBE</b> lets Overkill and the Min/Max Zone fallback decide.<br><br><i>Default: Maps: MAYBE</i>",
  "ScryerUseinPMaps": "Scryer behavior in maps above your current zone (prestige / extra-level maps).<br><br><b>NEVER</b> blocks Scryer in them. <b>FORCE</b> always switches to Scryer in them. <b>MAYBE</b> lets Overkill and the Min/Max Zone fallback decide.<br><br><i>Default: P Maps: NEVER</i>",
  "ScryerUseinSpire2": "Scryer behavior in the Spire.<br><br><b>NEVER</b> blocks Scryer in the Spire. <b>FORCE</b> always switches to Scryer there. <b>MAYBE</b> lets Overkill and the Min/Max Zone fallback decide.<br><br><i>Default: Spire: NEVER</i>",
  "ScryerUseinVoidMaps2": "Scryer behavior while you are in a Void map.<br><br><b>Cannot:</b> FORCE here can switch you to Scryer inside a void map even with the master <b>Enable Scryer Stance</b> switch off, if <b>VM Scryer</b> (Maps tab) or <b>Daily VM Scryer</b> (Daily tab) is on.<br><br><b>NEVER</b> blocks Scryer in Void maps. <b>FORCE</b> always switches to Scryer in them. <b>MAYBE</b> lets Overkill and the Min/Max Zone fallback decide.<br><br><i>Default: VoidMaps: NEVER</i>",
  "SkipSpires": "Pushes through the Spire even undergeared, once <b>Farm Before Spire</b> (if set) is done — AT stops waiting for its usual health/damage bar and just keeps going.<br><br><b>Ignored:</b> Below your <b>Ignore Spires Until</b> zone, or you are not currently in an active Spire.<br><br>Useful to accept dying in the Spire rather than stalling there indefinitely once your gear can't keep up.<br><br><i>Default: Off</i>",
  "SpamBuilding": "Hides building notifications from the AutoTrimps message log — every building AT buys, including Storage.<br><br><i>Default: Off</i>",
  "SpamEquipment": "Hides equipment notifications from the AutoTrimps message log — buying, leveling and upgrading Armor and Weapons.<br><br><i>Default: On</i>",
  "SpamGeneral": "Hides general notifications from the AutoTrimps message log — misc alerts like using a Bone Charge or falling back to your highest map when Auto Gigastation can't find a target zone.<br><br><i>Default: On</i>",
  "SpamGraphs": "Hides a small group of notifications from the AutoTrimps message log — RoboTrimp's MagnetoShriek activating, and the dark-theme graph stylesheet loading or unloading.<br><br><i>Default: On</i>",
  "SpamJobs": "Hides job notifications from the AutoTrimps message log — hiring or firing Farmers, Lumberjacks, Miners and other workers.<br><br><i>Default: Off</i>",
  "SpamMagmite": "Hides Magmite and Magma notifications from the AutoTrimps message log — Magmite auto-spending and buying Magmamancers.<br><br><i>Default: On</i>",
  "SpamMaps": "Hides map notifications from the AutoTrimps message log — buying, picking and running maps, recycling, and \\"can't afford\\" messages.<br><br><i>Default: On</i>",
  "SpamNature": "Hides Nature notifications from the AutoTrimps message log — upgrading Empowerment or transfer rate, and converting Poison, Wind or Ice tokens.<br><br><i>Default: On</i>",
  "SpamOther": "Hides a catch-all group of notifications from the AutoTrimps message log — mostly Better Auto Fight, Trimpicide, AutoBreed/Genetics timer changes, and anything that doesn't fit the other Spam categories.<br><br><i>Default: On</i>",
  "SpamPerks": "Hides AutoPerks notifications from the AutoTrimps message log — helium allocation results and AutoPerks errors.<br><br><i>Default: On</i>",
  "SpamUpgrades": "Hides \\"Upgraded X\\" notifications from the AutoTrimps message log whenever AT buys a non-equipment upgrade.<br><br><i>Default: On</i>",
  "SpireBreedTimer": "Overrides the game's own GA (breed) timer while you are in an active, non-Daily Spire above <b>Ignore Spires Until</b>, so you can breed more or less aggressively than your normal target.<br><br>Your previous GA timer is remembered on the way in and put back when you leave the Spire. <b>-1</b> disables the override.<br><br><i>Default: -1</i>",
  "SupplyWall": "Throttles how eagerly AT buys Supply versus Capacity, when Ratio Spending is off.<br><br><b>Ignored:</b> Ignored when Ratio Spending is on. Ignored in Universe 2.<br><br>Only matters when Efficiency is not the better buy. <b>Positive, not 1</b> (e.g. 2.5): buys Capacity even when it costs up to 2.5&times; more than Supply &mdash; throttles Supply. <b>Negative</b> (e.g. -2.5): buys Supply even when it costs up to 2.5&times; more than Capacity &mdash; throttles Capacity instead. <b>1</b>: disables Supply entirely, spends only on Efficiency/Capacity/Overclocker, and tries to keep Supply near your HZE. <b>0</b>: ignores this setting and just buys whichever of the two is cheaper.<br><br><i>Default: 0.4</i>",
  "TrapTrimps": "Automatically traps trimps when needed in U1, including building traps.<br><br>If you turn this off, you may as well turn off the game's own Auto-Traps button too — leaving it on with AT's trapping off just lets the game trap for you instead.<br><br><i>Default: On</i>",
  "TrimpleZ": "Runs <b>Trimple Of Doom</b> for the Ancient Treasure at this zone, after farming and building up map stacks.<br><br><b>AT writes this box.</b> If you set a <b>negative</b> zone, AT resets this box to <b>0</b> once it has successfully run Trimple — so it fires once and then switches itself off, leaving you free to set a new zone next run.<br><br>A positive zone runs it every time you reach that zone. <b>0</b> is off.<br><br><i>Default: 0</i>",
  "UseAutoGen": "Master switch for the Auto Generator settings below.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>Takes effect from z230 onward.<br><br><i>Default: Off</i>",
  "UseScryerStance": "Master switch for Scryer stance automation &mdash; overrides AutoStance when your Scryer conditions are met.<br><br><b>Cannot:</b> Not quite \\"nothing else does anything\\": <b>VM Scryer</b> (Maps tab) / <b>Daily VM Scryer</b> (Daily tab) can still force Scryer inside void maps even with this off &mdash; their own tooltips already say they work without the Scryer options.<br><br>Leave regular Autostance on alongside this. Scryer gives double non-Helium/Nullifium resources and a chance at Dark Essence. Decision priority: Never &gt; Force &gt; Overkill &gt; Min/Max Zone.<br><br><i>Default: On</i>",
  "VoidMaps": "The zone at which AutoTrimps clears out all of your void maps.<br><br><b>Ignored:</b> Ignored during the Daily challenge &mdash; <b>Daily Void Mod</b> controls Daily void zones instead.<br><br>Runs them at cell 70 unless you set <b>Voids Cell</b> otherwise &mdash; see <b>Voids Cell</b> to change that. <b>0</b> disables void-clearing entirely. On Lead, use an odd zone.<br><br><i>Default: 0</i>",
  "WarpstationCap": "Stops AT from leveling Warpstations past what your current Gigastation cycle needs.<br><br><b>Ignored:</b> <b>Buy Warp to Hit Coord</b> can still buy a capped-out Warpstation anyway, if doing so would close the population gap for your next Coordination.<br><br>The cap is <b>First Gigastation</b> + (Gigastations owned &times; <b>Delta Gigastation</b>). It only starts enforcing once you've bought your first Gigastation (or <b>Auto Gigas</b> is off) — before that, Warpstations build up uncapped.<br><br><i>Default: On</i>",
  "WarpstationCoordBuy": "Lets AT buy a Warpstation that <b>Warpstation Cap</b> or <b>Warpstation Wall</b> would otherwise block, if that purchase gets you the population you need for your next Coordination.<br><br><b>Ignored:</b> Neither <b>Warpstation Cap</b> nor <b>Warpstation Wall</b> is currently blocking a Warpstation purchase — there is nothing for this to override.<br><br><i>Default: On</i>",
  "WarpstationWall3": "Slows Warpstation buying to conserve metal — only buys a Warpstation once you can afford <b>X</b> Warpstations' worth of metal (at the current price), so metal piles up for prestiges instead.<br><br><b>Ignored:</b> <b>Buy Warp to Hit Coord</b> is on and buying the Warpstation would close your Coordination population gap — that overrides the wall for that one purchase.<br><br><b>Cannot:</b> -1, 0, or 1 all disable it — it only starts conserving above 1.<br><br>In other words, only allows a purchase once it costs less than 1/X of your current metal.<br><br><i>Default: -1</i>",
  "WindStackingMax": "How many wind stacks to build before switching out of withholding into D stance.<br><br>During Wind Enlightenment, AT automatically adds 100 to whatever you set here &mdash; so <b>200</b> becomes a real target of 300 during Enlightenment.<br><br><i>Default: 200</i>",
  "WindStackingMin": "Zone from which Windstacking Stance is allowed to actually withhold damage to build wind stacks.<br><br><b>Ignored:</b> <b>AutoStance</b> is not set to <b>Windstacking</b>.<br><br>Below this zone AT stays in D stance and ignores every other Windstacking setting. At or above it, AT holds back in S stance until it hits its target stacks, switches to D, then repeats. Overrides your Scryer settings while active.<br><br><i>Default: -1</i>",
  "WindStackingMinHD": "H:D threshold that decides HOW AT windstacks once you're in a wind zone above <b>Windstack Min Zone</b>.<br><br>Below this H:D, AT uses W stance inside Windlight and S stance outside it. Above it, AT switches to manual windstacking via heirloom swapping and stance changes. Set this absurdly high (e.g. <b>1e30</b>) to just stay on W stance always.<br><br><i>Default: -1</i>",
  "addpoison": "Factors Poison Empowerment into AT's damage calc.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>Experimental. May speed up poison-zone clears by letting AT credit the extra poison damage when deciding stances and buys.<br><br><i>Default: Off</i>",
  "always2": "Treats any U1 weapon or armor piece below level 2 as the top priority to buy, regardless of its normal cost-efficiency ranking.<br><br>Level 2 is disproportionately effective, so this lets AT grab it immediately on new gear rather than waiting its turn.<br><br><i>Default: Off</i>",
  "amalcoord": "Skips buying the Coordination upgrade under the conditions below, to let your Amalgamator count grow instead.<br><br>Only takes effect while your H:D ratio is below <b>Amal Boost H:D</b>. It then keeps skipping Coordination either indefinitely (if <b>Amal Target</b> is disabled, until <b>Amal Boost End Z</b> if that is set) or until your owned Amalgamators reach <b>Amal Target</b> — whichever you have configured.<br><br><i>Default: Off</i>",
  "amalcoordhd": "The H:D ratio threshold for <b>Amal Boost</b> — Coordination is only skipped while your H:D ratio is below this value.<br><br><b>Ignored:</b> Amal Boost is off, or set to 0.<br><br>A higher number here means AT skips Coordination less often (a looser bar to clear).<br><br><i>Default: 0.0000025</i>",
  "amalcoordt": "The number of Amalgamators to aim for while <b>Amal Boost</b> is skipping Coordination purchases.<br><br><b>Ignored:</b> Amal Boost is off.<br><br>Once your owned Amalgamators reach this number, AT stops skipping Coordination for the target reason (it may still skip it for the zone-based reason below). Set to -1 to ignore the target and rely on <b>Amal Boost End Z</b> instead.<br><br><i>Default: -1</i>",
  "amalcoordz": "The zone at which <b>Amal Boost</b> stops skipping Coordination purchases, when <b>Amal Target</b> is disabled.<br><br><b>Ignored:</b> Amal Boost is off, or Amal Target is set to a positive value (the target takes over as the stopping condition instead).<br><br>Set to -1 to let the boost run indefinitely with no zone cutoff.<br><br><i>Default: -1</i>",
  "autoenlight": "Master switch for automatically buying Enlightenment (uber empowerment) once it is cheap enough.<br><br><b>Ignored:</b> Stops firing once you have reached Uber Nature &mdash; there is nothing left to enlighten. Ignored in Universe 2 (no U2 equivalent exists).<br><br>Applies from z230 onward, using the per-nature, per-context thresholds below.<br><br><i>Default: Off</i>",
  "autoheirlooms": "Turns on Auto Heirlooms: after every portal, AT scores your spare heirlooms and carries the best ones &mdash; by the type and rarity you choose below &mdash; into your carried slots.<br><br><b>Ignored:</b> Setting <b>Kept Type</b> to <b>None</b> disables this completely, even with this box checked.<br><br><b>Cannot:</b> AT only decides what to carry &mdash; it does not itself delete or recycle any heirloom.<br><br>Scoring: a spare heirloom earns +5 for each modifier slot that matches one of your picks below, a large bonus for meeting <b>Rarity to Keep</b>, and any unfilled modifier slot on the heirloom itself multiplies its score &times;4, regardless of your picks. A heirloom you have protected in the Extra list is carried first, ahead of scoring, and always keeps a slot.<br><br><i>Default: Off</i>",
  "automapsalways": "Continuously forces <b>Auto Maps</b> to plain <b>On</b>, every tick it is not already on.<br><br><b>Cannot:</b> Cannot coexist with <b>Auto Maps: Unique</b> mode &mdash; if you pick Unique, this setting flips it straight back to plain On.<br><br>Effectively makes it impossible to run Unique mode, or to leave Auto Maps off, while this is checked.<br><br><i>Default: Off</i>",
  "automapsportal": "Forces <b>Auto Maps</b> to turn <b>On</b> automatically the moment you portal into a fresh Universe 1 run, if it is not already on.<br><br><b>Ignored:</b> Only fires once, at the very start of a new Universe 1 run. Does nothing for the rest of that run, and nothing at all in Universe 2.<br><br><b>Cannot:</b> Only ever sets Auto Maps to plain <b>On</b> &mdash; it never selects <b>Unique</b> mode.<br><br><i>Default: Off</i>",
  "avoidempower": "Predicts whether the next enemy attack, boosted by your current Empower stacks, would wipe your army — and if so, retreats to the map screen just before that happens.<br><br><b>Ignored:</b> Bogged or Plague Dailies, which have their own health handling, or while already mapping.<br><br><i>Default: On</i>",
  "battleradon": "Switches AutoGoldenUpgrades from Battle back to Helium once this many Battle-pool goldens have been bought this run.<br><br><b>Ignored:</b> Only used when AutoGoldenUpgrades is set to Battle. -1 disables it.<br><br><i>Default: -1</i>",
  "beforegen": "Which Generator mode to use before you start fueling.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>Applies if you fuel later than z230 (see Start Fuel Z). Hybrid requires the Hybridization permanent generator upgrade; until you own it, AT silently substitutes Gain Mi instead.<br><br><i>Default: Gain Fuel</i>",
  "buyheliumy": "Spends the Daily's one-time Heliumy bonus (100 bones, one purchase per Daily) once the Daily's difficulty score is at or above this value.<br><br>The difficulty score comes from the game's own Daily-weight calculation. Only checked while a Daily is active and only if you can afford the 100 bones. -1 disables the purchase entirely.<br><br><i>Default: -1</i>",
  "buynojobsc": "Named \\"No F/L/M in C2\\" — but nothing in AutoTrimps reads this setting. Toggling it does nothing.<br><br><i>Default: Off</i>",
  "buyradony": "Spends the Daily's one-time Radonculous bonus (100 bones, one purchase per Daily) once the Daily's difficulty score is at or above this value.<br><br>The difficulty score comes from the game's own Daily-weight calculation. Only checked while a Daily is active and only if you can afford the 100 bones. -1 disables the purchase entirely.<br><br><i>Default: -1</i>",
  "buywepsvoid": "Buys weapons and armor while inside a void map, ignoring your usual Health:Damage buy gate.<br><br><b>Ignored:</b> Only applies at the exact zone set in <b>Void Maps</b> (or <b>Daily Void Mod</b> on a Daily) &mdash; void maps run at any other zone are not affected.<br><br>Useful if you want to overkill as much as possible while parked on your void-clearing zone.<br><br><i>Default: Off</i>",
  "bwraidcell": "Cell to start BW Raiding at, once you reach a BW Raiding zone.<br><br><b>-1</b> starts at cell 1. If you also run P Raiding, set this above your P Raiding cell.<br><br><i>Default: -1</i>",
  "c2runnerpercent": "The completeness threshold C2 Runner uses to decide which Challenge² needs running next.<br><br><b>Ignored:</b> <b>C2 Runner</b> is off, or <b>C2 Runner Portal</b> is not set.<br><br>For each Challenge², AT computes (that Challenge²'s highest zone ÷ your overall highest zone cleared) × 100. Any Challenge² below this percentage is considered behind and becomes a candidate to run. E.g. 85 only picks Challenge²s under 85% of your HZE.<br><br><i>Default: 85</i>",
  "c2runnerportal": "The zone C2 Runner abandons the current Challenge² and portals at.<br><br><b>Ignored:</b> <b>C2 Runner</b> is off.<br><br>AT abandons once your world zone passes this number (e.g. 200 portals after first reaching zone 201).<br><br><i>Default: 999</i>",
  "c2runnerstart": "Runs your Challenge²s automatically, one after another, working through whichever ones need updating most.<br><br>Each portal, it compares every unlocked Challenge²'s own highest zone against your overall highest zone cleared, as a percentage, and starts whichever one is furthest behind — skipping Challenge²s that are already close to your HZE. Needs <b>C2 Runner Portal</b> and <b>C2 Runner %</b> both set to take effect. Avoid manually abandoning or switching Challenge²s while this is running.<br><br><i>Default: Off</i>",
  "c2table": "Opens a table of all your Challenge² and Challenge³ runs, color-coded by how worth updating each one is.<br><br><b>Green</b> = not worth updating. <b>Yellow</b> = consider updating. <b>Red</b> = worth updating now. <b>Blue</b> = not yet unlocked or completed.",
  "cATGA2timer": "Breed timer ATGA uses in C2 (squared) challenges, overriding the base timer and Before/After Z.<br><br><b>Ignored:</b> Not running a squared challenge, the challenge is Electricity/Nom/Toxicity (those use the Hard C2 timer instead), or <b>ATGA: Timer</b> is not a positive number.<br><br><i>Default: -1</i>",
  "cAutoGoldenUpgrades": "The Challenge2 version of AutoGoldenUpgrades: automatically buys Golden Upgrades while a Challenge2 is running.<br><br><b>Ignored:</b> Only active during a Challenge2.<br><br>Has no Helium option here &mdash; only Battle, Void, and Void + Battle.<br><br><i>Default: Off</i>",
  "capratio": "Relative weight for Capacity when Ratio Spending is on.<br><br><b>Ignored:</b> Ignored unless Ratio Spending is on. Ignored in Universe 2.<br><br>0 or below excludes Capacity from ratio spending entirely.<br><br><i>Default: -1</i>",
  "carmormagic": "Buys emergency Armor to avoid dying while running the Toxicity or Nom Challenge², once your health drops to 40% of max.<br><br><b>Ignored:</b> You are not running the Toxicity or Nom Challenge² — it has no effect anywhere else, including Dailies (use <b>Daily Armor Magic</b> for those).<br><br><b>Above 80%:</b> only once your world zone has reached 80% of your highest zone cleared.<br><b>H:D:</b> only once your H:D ratio (enemy health ÷ your damage) is at or above the cutoff you set in <b>Mapology H:D</b> — i.e. once you genuinely don't have enough damage.<br><b>Always:</b> active for the whole run.<br>All three still wait for the 40% health trigger before buying.<br><br><i>Default: C2 Armor Magic Off</i>",
  "cfightforever": "Forces trimps to fight during the Electricity, Toxicity and Nom Challenge² runs, even when they would otherwise sit idle — ignoring your Better Auto Fight setting.<br><br><b>Ignored:</b> You are not running the Electricity, Toxicity or Nom Challenge² — it has no effect anywhere else, including Dailies (use <b>Daily Fight Always</b> for those).<br><br>Works the same way as <b>Fight Forever</b> (H:D) in the Combat tab, just scoped to only these three Challenge²s.<br><br><i>Default: Off</i>",
  "chATGA2timer": "Breed timer ATGA uses in the harder C2 (squared) challenges &mdash; Electricity, Nom, Toxicity &mdash; overriding the base timer, Before/After Z, and the normal C2 timer.<br><br><b>Ignored:</b> Not running one of those three squared challenges, or <b>ATGA: Timer</b> is not a positive number.<br><br><i>Default: -1</i>",
  "dATGA2Auto": "<b>EXPERIMENTAL.</b> Computes a Bogged/Plague-tuned breed timer automatically instead of using a fixed number, overriding every other ATGA Daily timer when it applies.<br><br><b>Ignored:</b> Not a Daily, the Daily is not Bogged or Plague, or <b>ATGA: Timer</b> is not a positive number.<br><br><b>Auto Dailies</b> applies whenever the active Daily is Bogged or Plague. <b>Auto No Spire</b> applies under that same Bogged/Plague condition, but only while a Daily Spire is also active &mdash; the opposite of what the name suggests, so double-check this matches what you expect before relying on it.<br><br><i>Default: ATGA: Auto Dailies</i>",
  "dATGA2timer": "Breed timer ATGA uses on ordinary Dailies (no Bogged/Plague/etc.), overriding the base timer and the Before/After Z overrides.<br><br><b>Ignored:</b> Not a Daily, or <b>ATGA: Timer</b> is not a positive number. Can itself be overridden by Hard Daily, Daily Spire, or Auto Dailies below.<br><br>Useful for pushing the last bit out of a Daily.<br><br><i>Default: -1</i>",
  "dAutoGoldenUpgrades": "The Daily version of AutoGoldenUpgrades: automatically buys Golden Upgrades while a Daily challenge is active, with the same Helium / Battle / Void / Void + Battle behavior.<br><br><b>Ignored:</b> Only active during a Daily.<br><br>Its own Helium/Battle switch-over and Void fallback zone are <b>Daily Helium Battle</b>, <b>Daily Battle Helium</b>, and <b>Daily Void Battle</b>.<br><br><i>Default: Off</i>",
  "dBWraidingmax": "Per-entry ceiling on how far Daily BW Raiding climbs, matched by position to the list in Daily Z to BW Raid.<br><br>Example: if Daily Z to BW Raid is 480,495 and this is 500,515, AT raids up to 500 from 480 and up to 515 from 495.<br><br><i>Default: -1</i>",
  "dBWraidingz": "The list of zones at which AT raids Bionic Werewolves for gear during a Daily.<br><br>Example: 495 raids every BW from 495 up for whatever gear you're missing, skipping BWs you already have enough damage to ignore. Once all gear is obtained, AT returns to normal farming. Accepts a comma-separated list, matched by position to Daily Max BW to raid — keep the two lists the same length or BW raiding may fail.<br><br><i>Default: -1</i>",
  "dCustomAutoPortal": "The zone after which Daily Portal (DP: Custom) portals you out of the Daily.<br><br><b>Ignored:</b> Daily Portal is not set to DP: Custom.<br><br>Example: setting this to 200 portals the moment you first clear level 200 and reach level 201.<br><br><i>Default: 999</i>",
  "dExitSpireCell": "The cell at which AT exits an active Spire during a Daily.<br><br><b>Ignored:</b> Universe 2, or before the zone set in Daily Ignore Spires Until is reached.<br><br><i>Default: -1</i>",
  "dHeHrDontPortalBefore": "Blocks the He/Hr Daily AutoPortal from portaling before this level is reached.<br><br><b>Ignored:</b> Daily Portal is not set to DP: He/Hr.<br><br>An extra safety check on top of the He/Hr buffer, so a normal early-game dip in Helium/Hour doesn't trigger a premature portal. 0 or -1 disables the check.<br><br><i>Default: 999</i>",
  "dHeliumHourChallenge": "Which challenge to auto-select for your next Daily's He/Hr or Custom AutoPortal, once you've cleared every Daily challenge currently available.<br><br>Portals after cell 100 of the zone you specify. Don't pick a challenge you haven't unlocked yet.<br><br><i>Default: None</i>",
  "dHeliumHrBuffer": "How far your Helium/Hour is allowed to drop below this Daily run's best, before Daily He/Hr AutoPortal triggers.<br><br><b>Ignored:</b> Daily Portal is not set to DP: He/Hr.<br><br>Example: 5 portals once He/Hr falls to 95% of this run's best. Includes stuck protection: if He/Hr falls to 5x the buffer below best (e.g. 10% under a 2% buffer), AT will portal mid-zone instead of waiting for cell 1.<br><br><i>Default: 0</i>",
  "dIgnoreSpiresUntil": "Zone-gates Spire automation during Dailies: Spire-specific behavior (like Daily Exit Spire Cell) only kicks in once your world zone reaches this value.<br><br>Set to 0 to disable the gate, so Daily Spire automation is active from zone 1.<br><br><i>Default: 200</i>",
  "dMaxPraidZone": "Per-entry ceiling on how far Daily P Raiding will go, matched by position to the list in Daily P Raiding Z.<br><br><b>Ignored:</b> Daily Hardcore P Raiding is off.<br><br>Example: if Daily P Raiding Z is 491,495 and this is 495,505, AT raids up to 495 from 491 and up to 505 from 495. Set an entry to -1 to always buy the highest prestige Map available (up to about +8, depending where your zone falls in its decade) instead of a fixed ceiling.<br><br><i>Default: -1</i>",
  "dPraidBeforeFarmZ": "Zones at which AT raids as far up as it can currently afford before switching to farming fragments toward the highest or targeted prestige Map.<br><br><b>Ignored:</b> Daily Hardcore P Raiding is off.<br><br>Mainly useful if a lucky Speedexplorer pickup makes raiding cheap, or fragment farming is unusually slow. -1 (the entry, not the whole setting) means never raid-before-farm at that zone.<br><br><i>Default: -1</i>",
  "dPraidFarmFragsZ": "Zones at which AT farms fragments until it can afford the highest (or targeted) prestige Map for Daily P Raiding.<br><br><b>Ignored:</b> Daily Hardcore P Raiding is off.<br><br>Set an entry to -1 to never farm fragments at that zone.<br><br><i>Default: -1</i>",
  "dPraidHarder": "(EXPERIMENTAL) Always buys the highest prestige Map you can afford while Daily P Raiding, instead of the exact zone you set, and can farm fragments toward it.<br><br><b>Ignored:</b> Daily P Raiding Z has no zones set.<br><br>Turning this on reveals the Daily Farm Frags Z, Dy Raid bef farm Z, and Daily Max P Raid Z settings below.<br><br><i>Default: Off</i>",
  "dPraidingHD": "The H:D ratio ceiling for Daily P Raiding: AT will not raid a +level Map whose predicted H:D exceeds this value.<br><br>Higher values let AT reach further +levels. 0 or -1 removes the check entirely (any +level is allowed).<br><br><i>Default: -1</i>",
  "dPraidingI": "Caps how many +levels Daily P Raiding will reach while in an Ice Empowerment, independent of the H:D check.<br><br><b>Ignored:</b> You are not currently in an Ice Empowerment.<br><br>E.g. 10 allows raiding up to +10 in Ice. Use this instead of Daily P Raiding HD if the H:D estimate is off for your build — the two can also be combined. 0 or -1 means no Ice-specific cap.<br><br><i>Default: -1</i>",
  "dPraidingP": "Caps how many +levels Daily P Raiding will reach while in a Poison Empowerment, independent of the H:D check.<br><br><b>Ignored:</b> You are not currently in a Poison Empowerment.<br><br>E.g. 10 allows raiding up to +10 in Poison. Use this instead of Daily P Raiding HD if the H:D estimate is off for your build — the two can also be combined. 0 or -1 means no Poison-specific cap.<br><br><i>Default: -1</i>",
  "dPraidingcell": "The cell at which Daily P Raiding is allowed to begin, once the raid zone is reached.<br><br>-1 starts raiding at cell 1. If you also use Daily BW Raiding, setting this lower than Daily BW Raiding Cell keeps the two from overlapping.<br><br><i>Default: -1</i>",
  "dPraidingzone": "The list of zones at which AT raids Maps for prestige gear during a Daily.<br><br>Example: 495 raids Maps at 501 (up to +6, see Daily Max P Raid Z). Once every gear piece is obtained from the raid, AT reverts to normal farming. Accepts a comma-separated list, e.g. 495,506,525.<br><br><i>Default: -1</i>",
  "dPreSpireNurseries": "Caps how many Nurseries AT will build in preparation for a Daily Spire.<br><br>While the Daily Spire gate (Daily Ignore Spires Until) is satisfied, this cap replaces — not adds to — your normal No Nurseries Until Z and Max Nurseries limits, so you can keep Spire nursery prep separate from your normal nursery settings. -1 disables it.<br><br><i>Default: -1</i>",
  "dRunNewVoidsUntilNew": "Lets AT run newly-obtained Void Maps above your Daily Void Zone, during a Daily, by extending how far above that zone it's willing to go.<br><br><b>Ignored:</b> Universe 2 (this setting only takes effect in Universe 1).<br><br>0 disables it. A positive number adds that many zones on top of Daily Void Zone — example: Daily Void Zone 187 and this set to 10 runs new Voids up through zone 197. -1 removes the cap entirely. A high cap can slow you down badly by chasing Void Maps well above your normal farming zone.<br><br><i>Default: 0</i>",
  "dWindStackingMax": "The number of Wind debuff stacks AT tries to reach before switching back to your normal high-damage heirloom during a Daily.<br><br>During Wind Enlightenment, 100 stacks are added on top of this value automatically.<br><br><i>Default: 200</i>",
  "dWindStackingMin": "The zone above which Daily windstacking is allowed to activate.<br><br><b>Ignored:</b> Daily Windstacking is off, or your world zone is below this value.<br><br>0 or a negative value disables Daily windstacking entirely regardless of the other windstack settings.<br><br><i>Default: -1</i>",
  "dWindStackingMinHD": "The H:D ratio below which AT switches straight into maximum windstacking during a Daily Wind Enlightenment.<br><br><b>Ignored:</b> Your world zone is below Daily Windstack Min Zone, or you're not in Wind Enlightenment with Empowerment active.<br><br><i>Default: 1e33</i>",
  "darmormagic": "Buys armor to try to survive Bleed/Plague/Bogged Dailies once your health drops to 40% or less.<br><br><b>Cannot:</b> The third option, <b>DAM: Always</b>, still only buys armor once health is at or below 40% — none of the three modes buy armor pre-emptively.<br><br><b>Above 80%:</b> only active once your world zone is at or above 80% of your highest zone ever cleared. <b>H:D:</b> only active once your H:D ratio is at or above the H:D cutoff set in the Maps tab (i.e. you don't have enough damage). <b>Always:</b> active any time your health is low enough, no zone or H:D gate.<br><br><i>Default: Daily Armor Magic Off</i>",
  "dbattleradon": "The Daily version of <b>Battle Helium</b>: switches Daily AutoGoldenUpgrades from Battle back to Helium once this many Battle-pool goldens have been bought in the Daily.<br><br><b>Ignored:</b> Only used during a Daily when Daily AutoGoldenUpgrades is set to Battle. -1 disables it.<br><br><i>Default: -1</i>",
  "dbwraidcell": "The cell at which Daily BW Raiding is allowed to begin, once the raid zone is reached.<br><br>-1 starts raiding at cell 1. If you also use Daily P Raiding, setting this higher than Daily P Raiding Cell keeps the two from overlapping.<br><br><i>Default: -1</i>",
  "defaultgen": "Which Generator mode to use after fueling ends.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>Hybrid requires the Hybridization permanent generator upgrade; until you own it, AT silently substitutes Gain Mi instead.<br><br><i>Default: Gain Fuel</i>",
  "dfightforever": "Sends your army to fight instead of sitting idle on certain Daily debuffs, even when Better Auto Fight would otherwise hold back.<br><br><b>DFA: Non-Empowered</b> only forces fighting on Bogged/Plague/Pressure Dailies that are not also Empowered. <b>DFA: All Dailies</b> forces fighting on any Bogged/Plague/Pressure Daily regardless of Empower. Neither option touches Bloodthirst or Plagued-formation-locked Dailies.<br><br><i>Default: DFA: Off</i>",
  "dhATGA2timer": "Breed timer ATGA uses on Hard Dailies &mdash; Bogged, Plague, Bloodthirst, or Dailies with heavy negative mods &mdash; overriding the base timer, Before/After Z, and the normal Daily timer.<br><br><b>Ignored:</b> Not a Daily, the Daily isn't Bogged/Plague/Pressure, or <b>ATGA: Timer</b> is not a positive number. Can itself be overridden by Daily Spire or Auto Dailies below.<br><br><i>Default: -1</i>",
  "dhighdmg": "The name of the high-damage heirloom AT equips normally during Dailies.<br><br>AT swaps to this heirloom whenever Daily windstacking (Daily Windstacking must be on) decides you should be doing full damage rather than stacking Wind debuffs; see Daily Windstack Low Damage for its counterpart.<br><br><i>Default: </i>",
  "dlowdmg": "The name of the low-damage heirloom AT swaps to for windstacking during Dailies.<br><br>AT swaps to this heirloom whenever Daily windstacking (Daily Windstacking must be on) decides you should be withholding damage to build up Wind debuff stacks; see Daily Windstack High Damage for its counterpart.<br><br><i>Default: </i>",
  "dmgcuntoff": "Controls how much damage margin AT wants before it stops leveling weapons.<br><br>AT judges itself to have \\"enough damage\\" once your damage times this value exceeds the enemy's health. A higher number reaches \\"enough\\" sooner, so AT stops leveling weapons earlier; a lower number keeps it leveling weapons more aggressively. 4 is the historical default.<br><br><i>Default: 4</i>",
  "dradonbattle": "The Daily version of <b>Helium Battle</b>: switches Daily AutoGoldenUpgrades from Helium to Battle once this many Helium-pool goldens have been bought in the Daily.<br><br><b>Ignored:</b> Only used during a Daily when Daily AutoGoldenUpgrades is set to Helium. -1 disables it.<br><br><i>Default: -1</i>",
  "drunnewvoidspoison": "Restricts Daily New Voids Mod to only run new Void Maps while you're in a Poison Empowerment.<br><br><b>Ignored:</b> Daily New Voids Mod is 0/disabled.<br><br><i>Default: Off</i>",
  "dsATGA2timer": "Breed timer ATGA uses while a Daily Spire is active, overriding the normal and Hard Daily timers.<br><br><b>Ignored:</b> Not a Daily, Ignore Spires is covering this zone, or <b>ATGA: Timer</b> is not a positive number. Can itself be overridden by <b>ATGA: Auto Dailies</b> below.<br><br><b>Cannot:</b> Do not also set the ATGA timer on the Spire tab &mdash; that one drives the game's own vanilla GA instead, and the two will fight.<br><br><i>Default: -1</i>",
  "dscryvoidmaps": "Uses the Scryer stance while running Void Maps during a Daily.<br><br><b>Ignored:</b> You don't have Scryhard II. It works independently of the other Scryer-stance settings.<br><br><i>Default: Off</i>",
  "dvoidheliumbattle": "The Daily version of <b>Void Battle</b>: the world zone from which the Void fallback switches from Helium to Battle in Dailies, when Daily AutoGoldenUpgrades is set to Void.<br><br><b>Ignored:</b> Only used during a Daily when Daily AutoGoldenUpgrades is set to Void, and only once the Void pool has run out. -1 disables it.<br><br><i>Default: -1</i>",
  "dvoidscell": "The cell at which AT starts running Void Maps during a Daily, once the Daily Void Zone is reached.<br><br>-1 uses the built-in default of cell 70.<br><br><i>Default: -1</i>",
  "dwindcutoff": "The damage cutoff AT uses to decide whether it has \\"enough\\" damage while windstacking a Daily, in place of the normal gear-buying cutoff.<br><br><b>Ignored:</b> Daily Windstack Min Zone is 0/off or your zone hasn't reached it, or Daily Windstacking (or Auto Stance's W option) is off.<br><br>A higher cutoff makes AT settle for less damage — i.e. it keeps buying less gear — which lets your Wind stacks climb higher before AT decides you're strong enough. -1 falls back to the normal (non-windstacking) cutoff.<br><br><i>Default: -1</i>",
  "dwindcutoffmap": "The same damage cutoff as Daily Wind Damage Cutoff, but for deciding when to take the Maps bonus while windstacking a Daily.<br><br><b>Ignored:</b> Daily Windstack Min Zone is 0/off or your zone hasn't reached it, or Daily Windstacking (or Auto Stance's W option) is off.<br><br><i>Default: -1</i>",
  "dwsmax": "The zone above which Daily WS MAX starts withholding damage to chase your maximum possible windstack count.<br><br>Works together with Daily WSM H:D: both must be a positive value for WS MAX to activate. -1 disables it.<br><br><i>Default: -1</i>",
  "dwsmaxhd": "The H:D ratio below which Daily WS MAX is allowed to withhold damage and keep stacking, once your zone has passed Daily WS MAX.<br><br><b>Ignored:</b> Daily WS MAX is -1/disabled, or this value is not positive.<br><br><i>Default: -1</i>",
  "effratio": "Relative weight for Efficiency when Ratio Spending is on.<br><br><b>Ignored:</b> Ignored unless Ratio Spending is on. Ignored in Universe 2.<br><br>0 or below excludes Efficiency from ratio spending entirely.<br><br><i>Default: -1</i>",
  "farmWonders": "During the Experience challenge, farms Wonders down to a target zone and finishes the challenge with a Bionic Wonderland run.<br><br><b>Ignored:</b> Only relevant during the Experience challenge, and requires <b>Wonders Amount</b> and <b>Max XP Zone</b> to be configured below.<br><br><i>Default: Off</i>",
  "fastallocate": "Switches Auto Allocate to a faster, less precise helium-spending algorithm.<br><br><b>Cannot:</b> This box only appears in the U1 (Helium) view, but the same stored value also controls whether U2's Radon Auto Allocate uses the fast algorithm — there is no separate control for U2.<br><br>Recommended once your helium is above roughly 500Qa, where the precise algorithm gets slow. Not recommended for smaller amounts of helium.<br><br><i>Default: Off</i>",
  "fightforever": "Sends your squad out to fight even when Better AutoFight decided not to.<br><br><b>Ignored:</b> Ignored in Universe 2 (use the Rfightforever twin instead).<br><br>Set to 0 to always send trimps out when they are not fighting. Set above 0 to only send them when your H:D (Health:Damage) ratio is at or below this number &mdash; i.e. send them out even though the fight looks risky. -1 turns this off.<br><br><i>Default: -1</i>",
  "finishExpOnBw": "The Bionic Wonderland zone AutoTrimps runs to finish the Experience challenge.<br><br><b>Cannot:</b> Cannot go below zone 125 &mdash; anything lower is treated as 125.<br><br>This level of BW should already be in your inventory &mdash; use the BW Raiding module first if you want to raid to a specific level before 601. Snapped to a valid BW zone (125, then every 15 zones after) if you enter one that doesn't exist &mdash; e.g. 606 runs 605.<br><br><i>Default: 605</i>",
  "fuckjobs": "Hides the Farmer / Lumberjack / Miner / Scientist / Max Explorers / Max Trainers boxes once they stop mattering.<br><br>Needs two things at once: the <b>AutoJobs</b> Bone Shrine mastery bought, and <b>Buy Jobs</b> set to <b>Don't Buy Jobs</b> (AutoJobs replaces this automation entirely once both are true).<br><br><i>Default: Off</i>",
  "fuelend": "The zone AT stops fueling and switches to your After Fuel setting.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>-1 fuels indefinitely.<br><br><i>Default: -1</i>",
  "fuellater": "The zone AT starts fueling the generator, instead of the default z230.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>Set lower than your usual max zone. Use 230 to just use your Before Fuel setting the whole time.<br><br><i>Default: -1</i>",
  "fullice": "Changes how AT estimates your damage bonus from Ice Empowerment.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br>On always assumes the full Ice damage bonus (x2, or x3 with Fluffy's Nature's Wrath reward) regardless of the current Ice debuff. Off scales the bonus with the enemy's actual Ice debuff level. Meant to stop AT's H:D readout from jumping around as the debuff fluctuates.<br><br><i>Default: Off</i>",
  "gathermetal": "While <b>Mining/Building Only</b> is selected, forces AT to always gather metal instead of letting your build queue take priority.<br><br><b>Ignored:</b> ManualGather2 is not set to Mining/Building Only, or you have not unlocked the Foremany mastery — this control is hidden in both cases.<br><br>Off, AT still finishes off its build queue first and only gathers metal once one item or fewer remains queued.<br><br><i>Default: Off</i>",
  "gearamounttobuy": "How many gear levels AT buys per purchase in U1.<br><br><b>Cannot:</b> Does not affect <b>Buy Armor on Death</b>, which always buys a fixed 10 levels regardless of this setting.<br><br>Recommended value: 1. Must always be greater than 0.<br><br><i>Default: 1</i>",
  "hidebuildings": "Hands ordinary building purchases (housing, storage, Wormholes, Tributes, Nurseries) over to the game's own AutoStructure mastery instead of AT buying them.<br><br><b>Cannot:</b> Cannot hide or affect Gym purchases. AutoStructure has no Gym automation of its own, so AT keeps buying Gyms (per <b>Max Gyms</b> / <b>Gym Wall</b>) even with this on — that's also why the Gym settings stay visible either way.<br><br>Only takes effect when <b>Buy Buildings</b> is set to <b>Buy Neither</b> — with any other Buy Buildings option, AT keeps buying those buildings regardless of this setting.<br><br><i>Default: Off</i>",
  "highdmg": "Names the heirloom (an exact, case-sensitive match) that Windstack combat equips as your 'high damage' shield.<br><br><b>Ignored:</b> During combat this only matters while your stance is on Windstack (<b>Auto Stance</b> = Windstack, or Daily Windstacking is on) &mdash; U2 has no windstacking automation of its own.<br><br>Also equipped once automatically right after every portal &mdash; including a Radon (U2) portal, by a long-standing quirk, since U2 has its own separate swap system below. Leave blank to skip.<br><br><i>Default: </i>",
  "ic2enlightthresh": "Buys the Ice Enlightenment during a Challenge Squared (C2) run once its cost drops to or below this token threshold.<br><br>Also requires having enough Ice tokens banked to afford it. -1 disables Ice Enlightenment in C2.<br><br><i>Default: -1</i>",
  "idailyenlightthresh": "Buys the Ice Enlightenment during a Daily Challenge once its cost drops to or below this token threshold.<br><br>Also requires having enough Ice tokens banked to afford it. -1 disables Ice Enlightenment in Dailies.<br><br><i>Default: -1</i>",
  "ifillerenlightthresh": "Buys the Ice Enlightenment (in normal play, not Dailies or Challenge Squared) once its cost drops to or below this token threshold.<br><br>Also requires having enough Ice tokens banked to afford it. -1 disables Ice Enlightenment in this context. When more than one nature is affordable at once, AT buys whichever has the biggest cost-under-threshold margin first.<br><br><i>Default: -1</i>",
  "keepcores": "Shows the per-slot Core modifier pickers below in the settings panel.<br><br><b>Cannot:</b> This is a display toggle only, same as Shields/Staffs above: the picks are scored regardless of whether this row is shown. Unlike Shields and Staffs, this checkbox does not hide itself when Auto Heirlooms is off &mdash; it stays visible either way, though it still has no effect until Auto Heirlooms is on.<br><br><i>Default: Off</i>",
  "keepshields": "Shows the per-slot Shield modifier pickers below in the settings panel.<br><br><b>Ignored:</b> The row itself stays hidden unless Auto Heirlooms is on.<br><br><b>Cannot:</b> This is a display toggle only. Whatever those pickers are set to is scored when ranking Shields for carrying whether this row is shown or hidden &mdash; hiding it does not turn the modifiers off.<br><br><i>Default: Off</i>",
  "keepstaffs": "Shows the per-slot Staff modifier pickers below in the settings panel.<br><br><b>Ignored:</b> The row itself stays hidden unless Auto Heirlooms is on.<br><br><b>Cannot:</b> This is a display toggle only. Whatever those pickers are set to is scored when ranking Staffs for carrying whether this row is shown or hidden &mdash; hiding it does not turn the modifiers off.<br><br><i>Default: Off</i>",
  "liqstack": "Forces the windstacking stance whenever you're in a liquid zone during Wind Enlightenment.<br><br>This check does not require a Daily to be active — despite living in this tab, it applies any time you're in Wind Enlightenment and standing in a liquid zone.<br><br><i>Default: Off</i>",
  "lowdmg": "Names the heirloom (an exact, case-sensitive match) that Windstack combat equips as your 'low damage' shield.<br><br><b>Ignored:</b> During combat this only matters while your stance is on Windstack (<b>Auto Stance</b> = Windstack, or Daily Windstacking is on).<br><br>Also equipped once automatically right after every portal, the same way <b>WS: High Damage</b> is. Leave blank to skip.<br><br><i>Default: </i>",
  "mapc2hd": "Overrides your map damage cutoff during the Mapology Challenge².<br><br><b>Ignored:</b> You are not running the Mapology Challenge².<br><br>AT compares your H:D ratio (enemy health ÷ your damage) against this value; it only enters maps once that ratio drops below it. A higher number is more lenient — AT is willing to map with worse H:D. Set to -1 to use the normal, non-Mapology map cutoff instead.<br><br><i>Default: -1</i>",
  "mapcuntoff": "Sets the Health:Damage ratio AutoTrimps uses to decide whether it has \\"enough damage\\" to stop mapping and push forward.<br><br><b>Ignored:</b> Temporarily replaced by the Wind Stacking cutoff or the Mapology challenge cutoff whenever either of those is active &mdash; this box's value doesn't change, but it briefly stops being read.<br><br>AutoTrimps expects to one-shot an enemy once your damage times this number exceeds the enemy's health. Raise it to demand a bigger damage margin (more mapping); lower it to accept a thinner margin (less mapping). This same threshold is also what the <b>CAM: H:D</b> Armor Magic option compares against.<br><br><i>Default: 4</i>",
  "mapselection": "Picks which biome AutoTrimps requests when it creates a new map.<br><br><b>Ignored:</b> Ignored while AutoTrimps is farming for map bonus, or during the Metal challenge &mdash; biome is forced to Plentiful (once decay is done) or Mountain instead, regardless of this setting.<br><br><b>Gardens</b> is sent to the game under its internal biome name, <b>Plentiful</b>.<br><br><i>Default: Mountain</i>",
  "maxExpZone": "The zone to start collecting Wonders from during the Experience challenge, counting down every 5 zones for however many Wonders you've requested.<br><br><b>Ignored:</b> Only relevant during the Experience challenge.<br><br><b>Cannot:</b> Must have a value, or the other Experience-challenge settings will not work.<br><br>If set above zone 600, AutoTrimps additionally finishes the Experience challenge by running BW at this zone.<br><br><i>Default: 600</i>",
  "novmsc2": "Stops AT from running Void Maps while any Challenge² is active.<br><br><b>Ignored:</b> No Challenge² is currently running.<br><br>Handy with C2 Runner, so Void Maps don't interrupt a sequence of Challenge² runs.<br><br><i>Default: Off</i>",
  "ocratio": "Relative weight for Overclocker when Ratio Spending is on.<br><br><b>Ignored:</b> Ignored unless Ratio Spending is on. Ignored in Universe 2.<br><br>0 or below excludes Overclocker from ratio spending entirely.<br><br><i>Default: -1</i>",
  "onlyminmaxworld": "Restricts the Min/Max-Zone Scryer fallback to the World screen only.<br><br><b>Cannot:</b> Does not override the explicit per-context Never/Force rules (Maps / Void / BW / Spire / P Maps) &mdash; those still apply inside Maps regardless of this setting. A related internal three-way check in the code can never trigger its third branch, because this control only ever stores on/off.<br><br>When on, the plain Min Zone / Max Zone check (the one that runs once none of the per-context Never/Force rules above applied) only fires outside Maps; inside Maps that fallback is skipped, leaving Maps scrying to the Maps-specific rules.<br><br><i>Default: Off</i>",
  "onlystackedvoids": "Restricts void-map clearing to void maps that already have accumulated stacks (Stacked &gt; 0), skipping fresh unstacked voids.<br><br><b>Ignored:</b> Ignored during the Daily challenge.<br><br><i>Default: Off</i>",
  "pc2enlightthresh": "Buys the Poison Enlightenment during a Challenge Squared (C2) run once its cost drops to or below this token threshold.<br><br>Also requires having enough Poison tokens banked to afford it. -1 disables Poison Enlightenment in C2.<br><br><i>Default: -1</i>",
  "pdailyenlightthresh": "Buys the Poison Enlightenment during a Daily Challenge once its cost drops to or below this token threshold.<br><br>Also requires having enough Poison tokens banked to afford it. -1 disables Poison Enlightenment in Dailies.<br><br><i>Default: -1</i>",
  "pfillerenlightthresh": "Buys the Poison Enlightenment (in normal play, not Dailies or Challenge Squared) once its cost drops to or below this token threshold.<br><br>Also requires having enough Poison tokens banked to afford it. -1 disables Poison Enlightenment in this context. When more than one nature is affordable at once, AT buys whichever has the biggest cost-under-threshold margin first.<br><br><i>Default: -1</i>",
  "radonbattle": "Switches AutoGoldenUpgrades from Helium to Battle once this many Helium-pool goldens have been bought this run.<br><br><b>Ignored:</b> Only used when AutoGoldenUpgrades is set to Helium. -1 disables it.<br><br><i>Default: -1</i>",
  "radonsettings": "Switches which settings tabs you are viewing: U1 (Helium) or U2 (Radon).<br><br>Display only — it does not change which universe your run is actually in, only which set of controls this settings page shows you.<br><br><i>Default: Helium</i>",
  "raretokeep": "The rarity threshold Auto Heirlooms favors when scoring your spare heirlooms for carrying.<br><br><b>Ignored:</b> Has no effect unless Auto Heirlooms is on and Kept Type is not None.<br><br>A heirloom at or above this rarity gets a very large scoring bonus over one below it, so those tend to get carried first. It is a scoring weight, not a hard filter &mdash; a lower-rarity heirloom can still be carried if slots remain.<br><br><i>Default: Any</i>",
  "ratiospend": "Switches Magmite spending to a ratio you define below, instead of AT's built-in priority order.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br><b>Cannot:</b> If you turn this on without setting any ratio above (all four left at their disabling value), AT spends nothing &mdash; there is no fallback to the default order.<br><br>Set Efficiency / Capacity / Supply / Overclocker below to the relative weight you want each to get.<br><br><i>Default: Off</i>",
  "runnewvoidspoison": "Restricts the <b>New Voids Mod</b> zone extension to Poison-empowered zones only.<br><br><b>Ignored:</b> Does nothing unless <b>New Voids Mod</b> is actually extending void clearing past your Void Maps zone (i.e. is nonzero). Ignored during the Daily challenge, which has its own equivalent setting.<br><br><i>Default: Off</i>",
  "sATGA2timer": "Breed timer ATGA uses while an ordinary (non-Daily) Spire is active, overriding every timer above it.<br><br><b>Ignored:</b> A Daily is active, Ignore Spires is covering this zone, or <b>ATGA: Timer</b> is not a positive number.<br><br><b>Cannot:</b> Do not also set the ATGA timer on the Spire tab &mdash; that one drives the game's own vanilla GA instead, and the two will fight.<br><br>Nothing else in ATGA can override this once it applies &mdash; every timer with higher priority than it only takes effect during a Daily, which this excludes.<br><br><i>Default: -1</i>",
  "screwessence": "Turns off Scryer once there is no Dark Essence left worth farming.<br><br>Outside Maps, stops using Scryer entirely once the remaining enemies with essence drops to 0. Also gates the Die To Use S suicide logic on essence being available &mdash; with this off, AT will die-to-scry regardless of remaining essence.<br><br><i>Default: Off</i>",
  "scryvoidmaps": "Forces AutoTrimps to use Scryer stance while inside a Void map.<br><br><b>Ignored:</b> Ignored during the Daily challenge &mdash; the separate Daily VM Scryer setting controls Daily void maps instead.<br><br><b>Cannot:</b> Does nothing without the Scryhard II perk.<br><br>Applies on top of &mdash; and independently of &mdash; the <b>Use Scryer Stance</b> and <b>Scryer: Void Maps</b> settings elsewhere; it works even if those are off.<br><br><i>Default: Off</i>",
  "showautomapstatus": "Shows a live status line describing what AutoMap is currently doing in Universe 1, updated every tick.<br><br>Turning it off skips that per-tick update and hides the status line.<br><br><i>Default: On</i>",
  "showbreedtimer": "Shows a live countdown to when your next batch of Trimps finishes breeding, updated every tick.<br><br>Turning it off skips that per-tick update and hides the countdown.<br><br><i>Default: On</i>",
  "slot1modcr": "Gives a Core a +5 carrying-score bonus when its Modifier 1 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Cores unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Core whose Modifier 1 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Core multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot1modsh": "Gives a Shield a +5 carrying-score bonus when its Modifier 1 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Shields unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Shield whose Modifier 1 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Shield multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot1modst": "Gives a Staff a +5 carrying-score bonus when its Modifier 1 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Staffs unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Staff whose Modifier 1 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Staff multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot2modcr": "Gives a Core a +5 carrying-score bonus when its Modifier 2 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Cores unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Core whose Modifier 2 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Core multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot2modsh": "Gives a Shield a +5 carrying-score bonus when its Modifier 2 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Shields unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Shield whose Modifier 2 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Shield multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot2modst": "Gives a Staff a +5 carrying-score bonus when its Modifier 2 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Staffs unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Staff whose Modifier 2 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Staff multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot3modcr": "Gives a Core a +5 carrying-score bonus when its Modifier 3 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Cores unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Core whose Modifier 3 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Core multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot3modsh": "Gives a Shield a +5 carrying-score bonus when its Modifier 3 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Shields unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Shield whose Modifier 3 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Shield multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot3modst": "Gives a Staff a +5 carrying-score bonus when its Modifier 3 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Staffs unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Staff whose Modifier 3 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Staff multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot4modcr": "Gives a Core a +5 carrying-score bonus when its Modifier 4 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Cores unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Core whose Modifier 4 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Core multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot4modsh": "Gives a Shield a +5 carrying-score bonus when its Modifier 4 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Shields unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Shield whose Modifier 4 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Shield multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot4modst": "Gives a Staff a +5 carrying-score bonus when its Modifier 4 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Staffs unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Staff whose Modifier 4 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Staff multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot5modsh": "Gives a Shield a +5 carrying-score bonus when its Modifier 5 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Shields unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Shield whose Modifier 5 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Shield multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot5modst": "Gives a Staff a +5 carrying-score bonus when its Modifier 5 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Staffs unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Staff whose Modifier 5 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Staff multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot6modsh": "Gives a Shield a +5 carrying-score bonus when its Modifier 6 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Shields unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Shield whose Modifier 6 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Shield multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot6modst": "Gives a Staff a +5 carrying-score bonus when its Modifier 6 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Staffs unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Staff whose Modifier 6 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Staff multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot7modsh": "Gives a Shield a +5 carrying-score bonus when its Modifier 7 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Shields unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Shield whose Modifier 7 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Shield multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "slot7modst": "Gives a Staff a +5 carrying-score bonus when its Modifier 7 matches this pick.<br><br><b>Cannot:</b> Still scored even while its picker row is hidden (Staffs unticked above) &mdash; hiding the row does not turn this pick off.<br><br><b>empty</b> matches a Staff whose Modifier 7 slot is itself unfilled. Separately, ANY unfilled modifier slot on a Staff multiplies its whole score &times;4 automatically, no matter what this dropdown is set to.<br><br><i>Default: empty</i>",
  "spendmagmite": "When AT auto-spends any Magmite you have not manually allocated.<br><br><b>Ignored:</b> Ignored in Universe 2.<br><br><b>Spend Magmite OFF</b> never auto-spends. <b>Spend Magmite (Portal)</b> spends right before you portal. <b>Spend Magmite Always</b> spends every tick.<br><br><i>Default: Spend Magmite (Portal)</i>",
  "spendmagmitesetting": "Which parts of the default (non-ratio) Magmite spending order AT actually runs.<br><br><b>Ignored:</b> Ignored when Ratio Spending is on. Ignored in Universe 2.<br><br><b>Normal</b> buys the one-and-done upgrades, then Overclocker repeatedly, then loops Efficiency/Capacity/Supply. <b>Normal & No OC</b> is the same but stops buying Overclocker after its first level. <b>OneTime Only</b> buys only the one-and-done upgrades plus one Overclocker level &mdash; no Efficiency/Capacity/Supply loop. <b>OneTime & OC</b> buys the one-and-done upgrades and keeps buying Overclocker repeatedly, but skips the Efficiency/Capacity/Supply loop entirely.<br><br><i>Default: Normal</i>",
  "spireshitbuy": "Buys Weapons and Armor while in the Spire regardless of your H:D ratio, so you keep gearing up even when AT would normally consider you strong enough already.<br><br><b>Ignored:</b> Below your <b>Ignore Spires Until</b> zone, or you are not currently in an active Spire.<br><br>Still respects your max gear level cap.<br><br><i>Default: Off</i>",
  "supratio": "Relative weight for Supply when Ratio Spending is on.<br><br><b>Ignored:</b> Ignored unless Ratio Spending is on. Ignored in Universe 2.<br><br>0 or below excludes Supply from ratio spending entirely.<br><br><i>Default: -1</i>",
  "tokenthresh": "A token reserve AT will not dip below when spending or converting Nature tokens.<br><br>0 or below means no reserve &mdash; AT will spend down to whatever a purchase or conversion costs.<br><br><i>Default: -1</i>",
  "trimpsnotdie": "Continuously tops up armor to your Armor Level Cap while you are not actively fighting, buying 10 levels at a time.<br><br>Despite the name and label, this is not tied to any trimps actually dying — it simply runs on every tick where you are not in active combat or the map pre-battle screen, using a fixed batch of 10 levels regardless of Gear Levels to Buy.<br><br><i>Default: Off</i>",
  "turnwson": "A reminder checkbox, not a control &mdash; toggling it changes nothing.<br><br><b>Cannot:</b> Cannot turn Windstacking on for you. Go to <b>Combat &rarr; AutoStance</b> and pick <b>Windstacking</b> there; once you do, this reminder disappears and the settings below become live.<br><br><i>Default: Off</i>",
  "typetokeep": "Which category of spare heirlooms Auto Heirlooms carries into your carried slots after each portal.<br><br><b>Cannot:</b> Choosing <b>None</b> disables Auto Heirlooms entirely for every portal, even while the <b>Auto Heirlooms</b> master box is checked.<br><br><b>Shields</b> / <b>Staffs</b> / <b>Cores</b> carry only that type. <b>All</b> cycles Shield, then Staff, then Core, repeatedly, until your carried slots are full or you run out of spares &mdash; it does not guarantee an even split between the three.<br><br><i>Default: None</i>",
  "u1daily": "Tells AT that your Daily challenge should be run in Universe 1, even while your main run is in Universe 2.<br><br>Used together with Auto Start Daily so AT knows which universe's Daily settings to follow when it portals you between universes.<br><br><i>Default: Off</i>",
  "u2daily": "Tells AT that your Daily challenge should be run in Universe 2, even while your main run is in Universe 1.<br><br>Used together with Auto Start Daily / Universe 2's Auto Start Daily so AT knows which universe's Daily settings to follow when it portals you between universes.<br><br><i>Default: Off</i>",
  "use3daily": "Forces the Windstacking (W) stance during Dailies, the same way Auto Combat Stance's own W option does outside Dailies.<br><br>This is the master switch for the Daily windstacking settings below it — they only take effect while this is on.<br><br><i>Default: Off</i>",
  "voidheliumbattle": "The world zone from which the Void fallback switches from Helium to Battle, when AutoGoldenUpgrades is set to Void.<br><br><b>Ignored:</b> Only used when AutoGoldenUpgrades is set to Void, and only once the Void pool has run out. -1 disables it (always falls back to Helium).<br><br>Below this zone, running out of Void upgrades falls back to Helium; at or above it, it falls back to Battle instead.<br><br><i>Default: -1</i>",
  "voidscell": "The cell within the <b>Void Maps</b> zone at which AutoTrimps starts clearing void maps.<br><br><b>-1</b> falls back to cell 70.<br><br><i>Default: -1</i>",
  "wc2enlightthresh": "Buys the Wind Enlightenment during a Challenge Squared (C2) run once its cost drops to or below this token threshold.<br><br>Also requires having enough Wind tokens banked to afford it. -1 disables Wind Enlightenment in C2.<br><br><i>Default: -1</i>",
  "wdailyenlightthresh": "Buys the Wind Enlightenment during a Daily Challenge once its cost drops to or below this token threshold.<br><br>Also requires having enough Wind tokens banked to afford it. -1 disables Wind Enlightenment in Dailies.<br><br><i>Default: -1</i>",
  "wfillerenlightthresh": "Buys the Wind Enlightenment (in normal play, not Dailies or Challenge Squared) once its cost drops to or below this token threshold.<br><br>Also requires having enough Wind tokens banked to afford it. -1 disables Wind Enlightenment in this context. When more than one nature is affordable at once, AT buys whichever has the biggest cost-under-threshold margin first.<br><br><i>Default: -1</i>",
  "windcutoff": "Replaces AT's usual gear-buying damage cutoff while Windstacking, so it can hold your damage down instead of maximizing it.<br><br><b>Ignored:</b> Your world zone is below <b>Windstack Min Zone</b>.<br><br>Normally, a higher cutoff makes AT decide it has \\"enough\\" damage sooner and buy less. Set this high (e.g. <b>160</b>) and AT resists buying more weapon damage until your damage is wildly overkill for the zone &mdash; keeping it low so you accumulate wind stacks instead of one-shotting through them. <b>-1</b> disables this override and falls back to the normal Equipment Cut Off.<br><br><i>Default: -1</i>",
  "windcutoffmap": "Same idea as <b>Wind Damage Cutoff</b>, but for the map-bonus decision instead of gear-buying.<br><br><b>Ignored:</b> Your world zone is below <b>Windstack Min Zone</b>.<br><br>Set high, it holds off getting the max map bonus the same way Wind Damage Cutoff holds off buying gear. <b>-1</b> disables this override and falls back to the normal Map Cut Off.<br><br><i>Default: -1</i>",
  "windstackingfiller": "A label, not a control &mdash; toggling it changes nothing.<br><br>It exists only to point out that <b>Daily</b> Windstacking has its own settings on the <b>Daily</b> tab; the boxes below only apply to normal runs.<br><br><i>Default: Off</i>",
  "wondersAmount": "How many Wonders to collect during the Experience challenge.<br><br><b>Ignored:</b> <b>0</b> disables Wonder farming. Only relevant during the Experience challenge, and only while <b>Farm Wonders</b> is on.<br><br>Wonders are collected every 5 zones below <b>Max XP Zone</b> &mdash; with a Max XP Zone of 600 and this set to 3, Wonders are obtained at 600, 595, and 590.<br><br><i>Default: 0</i>",
  "wsmax": "Zone from which AT withholds Coordination purchases entirely, to squeeze the maximum possible wind stacks out of every wind zone.<br><br><b>Ignored:</b> <b>WSM H:D</b> is not a positive number, or your current H:D is already above it.<br><br>Not recommended for normal play &mdash; this deliberately keeps your damage down for a whole run. Useful for pushing a personal best. <b>-1</b> disables it.<br><br><i>Default: -1</i>",
  "wsmaxhd": "H:D threshold used by <b>WS MAX</b> to decide when to withhold Coordination.<br><br>Works the same way as the normal H:D setting used elsewhere. Only matters once <b>WS MAX</b>'s zone has been reached.<br><br><i>Default: -1</i>",
  "zATGA2timer": "Zone below which ATGA switches from the base timer to <b>ATGA: T: BZT</b>.<br><br><b>Ignored:</b> <b>ATGA: T: BZT</b> is not a positive number, or <b>ATGA: Timer</b> is not a positive number.<br><br>Useful for pushing content like Liquimp faster.<br><br><i>Default: -1</i>",
  "zonetracker": "Internal bookkeeping, not a visible setting — AT stores the last zone number it saw here, refreshed on every zone change. This box never appears in the settings UI, and nothing else in AutoTrimps reads the value.<br><br><i>Default: 1</i>",
  "ztATGA2timer": "Breed timer ATGA uses below the zone set in <b>ATGA: T: Before Z</b>, overriding the base timer.<br><br><b>Ignored:</b> <b>ATGA: T: Before Z</b> is not a positive number, or <b>ATGA: Timer</b> is not a positive number.<br><br><b>Cannot:</b> Does not apply during challenges.<br><br><i>Default: -1</i>",
}
`;
