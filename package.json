{
  "name": "autotrimps",
  "private": true,
  "version": "6.0.0-dev.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "trimpsGame": {
    "repo": "Trimps/Trimps.github.io",
    "sha": "b9edb1dfee270ebf81bef8d934dc71276bf8d963",
    "version": "5.10.1"
  },
  "scripts": {
    "build": "node scripts/build-userscript.mjs",
    "build:watch": "node scripts/build-userscript.mjs --watch",
    "serve": "node scripts/serve-game.mjs",
    "postinstall": "node scripts/fetch-game-clone.mjs",
    "game:fetch": "node scripts/fetch-game-clone.mjs",
    "sim:coverage": "node scripts/sim/coverage.mjs",
    "sim:record": "node scripts/sim/record-oracle.mjs",
    "lint": "oxlint src tests scripts --deny-warnings",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=json --outputFile=.vitest-report.json && node scripts/ci/assert-no-skips.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "decimal.js": "7.2.4",
    "echarts": "^5.6.0",
    "esbuild": "^0.28.0",
    "jsdom": "29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
